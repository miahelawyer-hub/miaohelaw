---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	ogType?: string;
}

/** Single source of truth for canonical URLs: always match trailingSlash: 'always' in astro.config.mjs */
const rawPath = Astro.url.pathname;
const canonicalPath =
	rawPath === '/' || rawPath.endsWith('/') ? rawPath : `${rawPath}/`;
const canonicalURL = new URL(canonicalPath, Astro.site);
const {
	title,
	description,
	image = 'https://www.miaohelaw.ca/miao-he-lawyer.jpeg',
	ogType = 'website',
} = Astro.props;

/** Absolute favicon URLs help crawlers (e.g. Googlebot-Image) resolve icons consistently */
const origin = (Astro.site ?? new URL('https://www.miaohelaw.ca/')).origin;
const abs = (path: string) => new URL(path, `${origin}/`).href;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Favicons: Google recommends a square icon &gt;48px; put ico + 192 first for search + crawlers -->
<link rel="icon" href={abs('/favicon.ico')} />
<link rel="icon" type="image/png" sizes="192x192" href={abs('/favicon-192.png')} />
<link rel="icon" type="image/png" sizes="32x32" href={abs('/favicon-32.png')} />
<link rel="icon" type="image/png" sizes="16x16" href={abs('/favicon-16.png')} />
<link rel="apple-touch-icon" sizes="180x180" href={abs('/apple-touch-icon.png')} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Noto+Serif+SC:wght@400;500;600;700&display=swap"
	rel="stylesheet"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />
<!-- Google Analytics -->
<script defer src="https://www.googletagmanager.com/gtag/js?id=G-Z66X0QGEV7"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-Z66X0QGEV7');
</script>
{Astro.url.pathname === '/' || Astro.url.pathname === '/en/' ? (
	<link rel="preload" as="image" href="/images/hero-home-court-interior.webp" fetchpriority="high" />
) : null}
