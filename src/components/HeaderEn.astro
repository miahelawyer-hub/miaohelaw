<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #ffffff !important;
		box-shadow: 0 2px 8px rgba(0,0,0,0.08);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.8em 0;
	}
	nav a {
		padding: 0.5em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		gap: 0.5em;
		align-items: center;
	}
	.lang-switch {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: #7A5A1A !important;
		border: 1px solid #C8A86A;
		border-radius: 4px;
		padding: 0.2rem 0.6rem !important;
		border-bottom: 1px solid #C8A86A !important;
		line-height: 1.4;
	}
	.lang-switch:hover {
		background: #7A5A1A;
		color: #fff !important;
	}
	/* Dropdown */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropdown-trigger {
		padding: 0.5em 0.5em;
		color: var(--black);
		cursor: pointer;
		font-size: 1em;
		border-bottom: 4px solid transparent;
		white-space: nowrap;
	}
	.dropdown-trigger:hover {
		border-bottom-color: var(--accent);
	}
	.dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		background: white;
		border: 1px solid #e8e0d5;
		border-radius: 10px;
		box-shadow: 0 8px 24px rgba(0,0,0,0.12);
		padding: 1.25rem;
		min-width: 480px;
		z-index: 1000;
		display: none;
		flex-direction: row;
		gap: 1.5rem;
	}
	.dropdown:hover .dropdown-menu {
		display: flex;
	}
	.dropdown-col {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 130px;
	}
	.dropdown-heading {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #9A8060;
		margin-bottom: 0.35rem;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid #f0ebe3;
	}
	.dropdown-menu a {
		font-size: 0.875rem;
		color: #2C1810;
		text-decoration: none;
		padding: 0.2rem 0;
		border-bottom: none !important;
	}
	.dropdown-menu a:hover {
		color: #9A8060;
	}
	.hamburger {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
	}
	.hamburger span {
		display: block;
		width: 24px;
		height: 2px;
		background: #2C1810;
		border-radius: 2px;
		transition: all 0.2s;
	}
	@media (max-width: 720px) {
		.hamburger { display: flex; }
		.social-links { display: none; }
		h2 { font-size: 0.9em; }
		nav {
			padding: 0.5em 0;
			flex-wrap: wrap;
			align-items: center;
		}
		.internal-links {
			display: none;
			flex-direction: column;
			width: 100%;
			border-top: 1px solid #EDE8DF;
			padding: 0.5rem 0;
			gap: 0;
		}
		.internal-links.open { display: flex; }
		.internal-links a {
			padding: 0.6em 1em;
			font-size: 0.95rem;
			border-bottom: none;
			border-left: 3px solid transparent;
		}
		.internal-links a:hover { border-left-color: #D4A853; }
		.dropdown { width: 100%; }
		.dropdown-trigger {
			display: block;
			width: 100%;
			padding: 0.6em 1em;
			font-size: 0.95rem;
		}
		.dropdown-menu {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			border-radius: 0;
			min-width: unset;
			width: 100%;
			flex-direction: column;
			gap: 0;
			padding: 0 0 0 1.5rem;
			background: #FDFBF7;
			display: none;
		}
		.dropdown.open .dropdown-menu { display: flex; }
		.dropdown-col { gap: 0; }
		.dropdown-heading { margin-top: 0.5rem; }
		.dropdown-menu a { padding: 0.4em 0; }
	}
.wechat-bar {
    background: #F5EFE0;
    border-bottom: 1px solid #EDE8DF;
    padding: 0.5rem 1.5rem;
}
.wechat-bar-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
}
.wechat-qr {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    object-fit: cover;
}
.wechat-bar-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
}
.wechat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #1A1208;
}
.wechat-id {
    font-size: 0.75rem;
    color: #6B5A3A;
}
.wechat-phone {
    margin-left: auto;
    background: #7A5A1A;
    color: #FDFBF7;
    padding: 0.4rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
}
.wechat-phone:hover {
    background: #4A3A0A;
    color: #FDFBF7;
}
@media (max-width: 720px) {
    .dropdown-trigger { font-size: 0.82rem; padding: 0.4em 0.4em; }
    .dropdown-menu {
        position: static;
        transform: none;
        box-shadow: none;
        border: 1px solid #e8e0d5;
        border-radius: 6px;
        min-width: unset;
        width: 100%;
        flex-direction: column;
        gap: 0.5rem;
        padding: 0.75rem;
        display: none;
    }
    .dropdown:hover .dropdown-menu,
    .dropdown.open .dropdown-menu { display: flex; }
    .wechat-bar { padding: 0.5rem 1rem; }
    .wechat-bar-inner { gap: 0.75rem; }
    .wechat-label { font-size: 0.75rem; }
    .wechat-id { display: none; }
    .wechat-phone { font-size: 0.8rem; padding: 0.4rem 1rem; }
}
</style>
<script>
  // Hamburger menu
  const hamburger = document.getElementById('en-hamburger');
  const navLinks = document.getElementById('en-nav-links');
  if (hamburger && navLinks) {
    hamburger.addEventListener('click', (e) => {
      e.stopPropagation();
      navLinks.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      navLinks.classList.remove('open');
    });
    navLinks.addEventListener('click', (e) => e.stopPropagation());
  }
  // Dropdown
  const trigger = document.querySelector('.dropdown-trigger');
  const dropdown = document.querySelector('.dropdown');
  if (trigger && dropdown) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      dropdown.classList.remove('open');
    });
  }
</script>