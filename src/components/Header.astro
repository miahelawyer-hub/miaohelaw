---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<button class="hamburger" id="zh-hamburger" type="button" aria-label="打开菜单" aria-expanded="false" aria-controls="zh-nav-links">
			<span></span><span></span><span></span>
		</button>
		<div class="internal-links" id="zh-nav-links">
			<HeaderLink href="/">首页</HeaderLink>
			<div class="dropdown">
				<span class="dropdown-trigger">家庭法服务 ▾</span>
				<div class="dropdown-menu">
					<div class="dropdown-col">
						<span class="dropdown-heading">离婚</span>
						<a href="/family-law/divorce-litigation">离婚诉讼</a>
						<a href="/family-law/mediation">调解与仲裁</a>
					</div>
					<div class="dropdown-col">
						<span class="dropdown-heading">子女</span>
						<a href="/family-law/child-custody">子女监护权</a>
						<a href="/family-law/support">子女抚养费</a>
						<a href="/family-law/support#spousal">配偶赡养费</a>
					</div>
					<div class="dropdown-col">
						<span class="dropdown-heading">协议与财产</span>
						<a href="/family-law/common-law">Common-law 同居</a>
						<a href="/family-law/domestic-contracts">婚前协议</a>
						<a href="/family-law/domestic-contracts#separation">分居协议</a>
						<a href="/family-law/cross-border-assets">跨境资产分割</a>
					</div>
					<div class="dropdown-col">
						<span class="dropdown-heading">文件服务</span>
						<a href="/hague-apostille">海牙认证 · 中加文件</a>
						<a href="/notary-public/">公证服务 · Ontario</a>
					</div>
				</div>
			</div>
			<div class="dropdown">
				<span class="dropdown-trigger">内容中心 ▾</span>
				<div class="dropdown-menu">
					<div class="dropdown-col">
						<span class="dropdown-heading">文章</span>
						<a href="/blog">博客文章</a>
					</div>
					<div class="dropdown-col">
						<span class="dropdown-heading">视频</span>
						<a href="/videos/">法律视频</a>
					</div>
				</div>
			</div>
			<HeaderLink href="/testimonials">客户评价</HeaderLink>
			<HeaderLink href="/case-results">案例结果</HeaderLink>
			<HeaderLink href="/pricing">费用说明</HeaderLink>
			<HeaderLink href="/faq/">常见问题</HeaderLink>
			<HeaderLink href="/about">关于律师</HeaderLink>
			<HeaderLink href="/contact">联系我们</HeaderLink>
			<a href="/en/" class="lang-switch-mobile">English · EN</a>
		</div>
		<div class="social-links">
			<a href="/en/" class="lang-switch">EN</a>
			<a href="https://www.linkedin.com/in/mia-he-93422b160/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
					<path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
				</svg>
			</a>
			<a href="mailto:miao@miaohelaw.ca">
				<span class="sr-only">Email</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
					<path fill="currentColor" d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.8em 0;
	}
	/* :global(a) so HeaderLink and other child roots receive nav link colors */
	nav :global(a) {
		padding: 0.5em 0.5em;
		color: var(--text-heading);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav :global(a.active) {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		gap: 0.5em;
		align-items: center;
	}
	.lang-switch {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: #7A5A1A !important;
		border: 1px solid #C8A86A;
		border-radius: 4px;
		padding: 0.2rem 0.6rem !important;
		border-bottom: 1px solid #C8A86A !important;
		line-height: 1.4;
	}
	.lang-switch:hover {
		background: #7A5A1A;
		color: #fff !important;
	}
	/* Dropdown */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropdown-trigger {
		padding: 0.5em 0.5em;
		color: var(--text-heading);
		cursor: pointer;
		font-size: 1em;
		border-bottom: 4px solid transparent;
		white-space: nowrap;
	}
	.dropdown-trigger:hover {
		border-bottom-color: var(--accent);
	}
	.dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		background: white;
		border: 1px solid #e8e0d5;
		border-radius: 10px;
		box-shadow: 0 8px 24px rgba(0,0,0,0.12);
		padding: 1.25rem;
		min-width: 480px;
		z-index: 1000;
		display: none;
		flex-direction: row;
		gap: 1.5rem;
	}
	.dropdown:hover .dropdown-menu {
		display: flex;
	}
	.dropdown-col {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 130px;
	}
	.dropdown-heading {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #9A8060;
		margin-bottom: 0.35rem;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid #f0ebe3;
	}
	.dropdown-menu a {
		font-size: 0.875rem;
		color: var(--text-heading);
		text-decoration: none;
		padding: 0.2rem 0;
		border-bottom: none !important;
	}
	.dropdown-menu a:hover {
		color: #9A8060;
	}
	/* 桌面端：语言切换放在右侧 social，不在主导航重复 */
	.lang-switch-mobile {
		display: none;
	}
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 6px;
		-webkit-tap-highlight-color: transparent;
	}
	.hamburger span {
		display: block;
		width: 24px;
		height: 2px;
		background: var(--text-heading);
		border-radius: 2px;
		transition: opacity 0.2s, transform 0.2s;
	}
	@media (max-width: 720px) {
		.hamburger {
			display: flex;
			flex-shrink: 0;
		}
		.social-links {
			display: none;
		}
		h2 {
			display: block;
			flex: 1;
			min-width: 0;
			font-size: 0.82rem;
			line-height: 1.35;
			text-align: left;
		}
		nav {
			padding: 0.5em 0;
			flex-wrap: wrap;
			align-items: center;
			justify-content: space-between;
			gap: 0;
		}
		.internal-links {
			display: none;
			flex-direction: column;
			width: 100%;
			border-top: 1px solid #ede8df;
			padding: 0.35rem 0 0.5rem;
			gap: 0;
		}
		.internal-links.open {
			display: flex;
		}
		.internal-links :global(a) {
			padding: 0.6em 1em;
			font-size: 0.95rem;
			border-bottom: none;
			border-left: 3px solid transparent;
		}
		.internal-links :global(a:hover) {
			border-left-color: #d4a853;
		}
		.lang-switch-mobile {
			display: block;
			margin-top: 0.25rem;
			font-weight: 700;
			color: #7a5a1a !important;
			border-top: 1px solid rgba(237, 232, 223, 0.95);
			padding-top: 0.65rem !important;
		}
		.dropdown {
			width: 100%;
		}
		.dropdown-trigger {
			display: block;
			width: 100%;
			padding: 0.6em 1em;
			font-size: 0.95rem;
			box-sizing: border-box;
		}
		.dropdown-menu {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			border-radius: 0;
			min-width: unset;
			width: 100%;
			flex-direction: column;
			gap: 0;
			padding: 0 0 0 1.5rem;
			background: #fdfbf7;
			display: none;
		}
		.dropdown.open .dropdown-menu {
			display: flex;
		}
		.dropdown-col {
			gap: 0;
		}
		.dropdown-heading {
			margin-top: 0.5rem;
		}
		.dropdown-menu a {
			padding: 0.4em 0;
		}
	}
</style>
<script src="/js/site-header-nav.js" defer></script>
