<style>
	.trust-bar {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem 2rem;
  padding: 1rem 1rem 0.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  margin-bottom: 1rem;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  color: rgb(var(--gray));
}
.trust-item a {
  color: rgb(var(--gray));
  text-decoration: underline;
  text-underline-offset: 2px;
}
.trust-item a:hover {
  color: #D4A853;
}
.trust-icon {
  font-size: 0.9rem;
}
footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
		align-items: center;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.wechat-section {
		margin-top: 2em;
	}
	.wechat-label {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 0.75em;
	}
	.wechat-qr {
		width: 120px;
		height: 120px;
		border-radius: 8px;
		border: 1px solid #EDE8DF;
	}
	.wechat-id {
		font-size: 0.8rem;
		color: rgb(var(--gray));
		margin-top: 0.5em;
	}
	.footer-legal {
		margin-top: 1.5em;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	.footer-legal a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.footer-legal a:hover {
		color: #D4A853;
	}
	.footer-legal span {
		opacity: 0.4;
	}
</style>