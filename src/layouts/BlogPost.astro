---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/blog-prose-body-color.css';
import { SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry['blog']['data'];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  keywords,
  tags,
  relatedIntro,
  relatedReading,
  pairedArticlePath,
  faqStructured,
} = Astro.props;

const faqPageMainEntity =
  faqStructured && faqStructured.length > 0
    ? faqStructured.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      }))
    : [
        {
          '@type': 'Question',
          name: title,
          acceptedAnswer: {
            '@type': 'Answer',
            text: description,
          },
        },
      ];

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(pathname, Astro.site).href;
const pathCore = pathname.replace(/\/$/, '') || '/';
const publishedIso = pubDate.toISOString();
const modifiedIso = (updatedDate ?? pubDate).toISOString();
const articleAuthorUrl = 'https://www.miaohelaw.ca/about/';
const siteBase = Astro.site ?? new URL('https://www.miaohelaw.ca/');
function absoluteUrl(path: string) {
  const p = path.startsWith('/') ? path : `/${path}`;
  return new URL(p, siteBase).href;
}

// 获取其他博文用于侧边栏；全量用于解析延伸阅读 slug → 标题
const allBlogEntries = await getCollection('blog');
const allPosts = allBlogEntries
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((p) => `/blog/${p.id}` !== pathCore && `/blog/${p.id}/` !== pathname)
  .slice(0, 4);

function titleForBlogSlug(slug: string): string {
  return allBlogEntries.find((p) => p.id === slug)?.data.title ?? slug;
}

const defaultRelatedIntro =
  '如果您在阅读本文之外，还想延伸了解下列话题，欢迎继续阅读站内相关文章：';

const siteOrigin = SITE_URL.replace(/\/$/, '');
const webPageId = `${canonicalUrl}#webpage`;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  datePublished: publishedIso,
  dateModified: modifiedIso,
  inLanguage: 'zh-CN',
  isAccessibleForFree: true,
  image: [`${siteOrigin}/miao-he-lawyer.jpeg`],
  author: {
    '@type': 'Person',
    '@id': `${siteOrigin}/#person`,
    name: 'Miao He',
    alternateName: ['何淼', 'Mia He'],
    jobTitle: 'Family Law Lawyer',
    url: `${siteOrigin}/`,
    telephone: '+1-647-930-6688',
  },
  publisher: {
    '@type': 'Person',
    '@id': `${siteOrigin}/#person`,
    name: 'Miao He',
    url: `${siteOrigin}/`,
  },
  provider: { '@id': `${siteOrigin}/#legalservice` },
  about: {
    '@type': 'LegalService',
    name: 'Ontario Family Law',
    areaServed: ['Greater Toronto Area', 'Ontario'],
  },
  ...(keywords
    ? {
        keywords: keywords
          .split(/[,，]/)
          .map((s) => s.trim())
          .filter(Boolean),
      }
    : {}),
  articleSection: 'Ontario family law',
  mainEntityOfPage: { '@type': 'WebPage', '@id': webPageId },
};

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': webPageId,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: 'zh-CN',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteOrigin}/#website`,
    url: `${siteOrigin}/`,
    name: SITE_TITLE,
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: `${siteOrigin}/miao-he-lawyer.jpeg`,
  },
  datePublished: publishedIso,
  dateModified: modifiedIso,
  breadcrumb: { '@id': breadcrumbId },
};

const webSiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: `${siteOrigin}/`,
  name: SITE_TITLE,
  alternateName: ['miaohelaw.ca', '何淼律师', 'Miao He Law'],
  inLanguage: ['zh-CN', 'en-CA'],
  publisher: { '@id': `${siteOrigin}/#person` },
};

const legalServiceLd = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  '@id': `${siteOrigin}/#legalservice`,
  name: 'H. LAW FIRM 恒. 律师事务所',
  alternateName: ['H. LAW FIRM', '恒律师事务所', 'H Law Firm Ontario'],
  description:
    '安省家庭法：离婚与分居、子女监护与抚养、财产分割、婚前及分居协议、跨境资产等。普通话及英文服务，面向多伦多、万锦、列治文山、士嘉堡及安省客户。',
  url: `${siteOrigin}/contact/`,
  image: `${siteOrigin}/miao-he-lawyer.jpeg`,
  telephone: '+1-647-930-6688',
  email: 'miao@miaohelaw.ca',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '208-7050 Woodbine Ave',
    addressLocality: 'Markham',
    addressRegion: 'ON',
    postalCode: 'L3R 4G8',
    addressCountry: 'CA',
  },
  areaServed: [
    { '@type': 'City', name: 'Toronto' },
    { '@type': 'City', name: 'Markham' },
    { '@type': 'City', name: 'Richmond Hill' },
    { '@type': 'City', name: 'Vaughan' },
    { '@type': 'City', name: 'Mississauga' },
    { '@type': 'City', name: 'Scarborough' },
    { '@type': 'AdministrativeArea', name: 'Greater Toronto Area' },
    { '@type': 'AdministrativeArea', name: 'Ontario' },
  ],
  sameAs: ['https://www.linkedin.com/in/mia-he-93422b160/'],
  founder: { '@id': `${siteOrigin}/#person` },
};

const faqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqPageMainEntity,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: '博客', item: `${siteOrigin}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

const structuredDataJson = JSON.stringify([
  articleLd,
  webPageLd,
  webSiteLd,
  legalServiceLd,
  faqPageLd,
  breadcrumbLd,
]);
---

<html lang="zh">
  <head>
    <BaseHead title={title} description={description} ogType="article" />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="zh_CN" />
    {pairedArticlePath && <meta property="og:locale:alternate" content="en_CA" />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="article:published_time" content={publishedIso} />
    <meta property="article:modified_time" content={modifiedIso} />
    <meta property="article:author" content={articleAuthorUrl} />
    <meta name="author" content="何淼律师 Miao He" />
    {pairedArticlePath && (
      <>
        <link rel="alternate" hreflang="zh-CN" href={canonicalUrl} />
        <link rel="alternate" hreflang="en" href={absoluteUrl(pairedArticlePath)} />
        <link rel="alternate" hreflang="x-default" href={absoluteUrl(pairedArticlePath)} />
      </>
    )}
    <script type="application/ld+json" set:html={structuredDataJson} />
    <style is:global>
      * { box-sizing: border-box; }
      body { background: var(--bg); margin: 0; }

      /* 正文色：与全站 global.css（Sentinel 蓝）一致 */

      /* ── Hero ── */
      .post-hero {
        background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0, 0, 0, 0.35);
        padding: 3rem 1.5rem 2.5rem;
        text-align: center;
      }
      .post-hero .breadcrumb {
        font-size: 0.78rem;
        color: #c9a96e;
        margin-bottom: 1.2rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .post-hero .breadcrumb a { color: #c9a96e; text-decoration: none; }
      .post-hero .breadcrumb a:hover { color: #D4A853; }
      .post-hero h1 {
        color: #ffffff;
        font-size: clamp(1.5rem, 3.5vw, 2.1rem);
        line-height: 1.35;
        margin: 0 auto 1.2rem;
        max-width: 820px;
        font-weight: 700;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5), 0 3px 24px rgba(0, 0, 0, 0.45);
      }
      .post-hero .meta {
        color: #D4A853;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
      }

      /* ── 主体布局：正文 + 侧边栏 ── */
      .post-layout {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2.5rem;
        align-items: start;
      }

      /* ── 正文 ── */
      /* 正文：与全站中文栈一致（无衬线），加大行距与段距，避免长文「挤」 */
      /* Sentinel 蓝写在本块内，避免依赖外链顺序下 :root 变量是否已就绪 */
      .prose {
        --text-primary: #3d4f6f;
        --text-heading: #2a3544;
        background: #ffffff;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 2px 12px rgba(44,24,16,0.07);
        color: #3d4f6f;
        font-family: var(--font-zh-body);
        font-size: 1.02rem;
        font-weight: 400;
        line-height: 2;
        letter-spacing: 0.02em;
        min-width: 0;
      }
      .prose h2 {
        font-size: 1.15rem;
        margin: 3.25rem 0 1.35rem;
        padding: 0.55rem 1.1rem 0.55rem 1rem;
        background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 100%);
        color: #ffffff;
        border-radius: 6px;
        border-bottom: none;
        letter-spacing: 0.01em;
      }
      .prose h3 {
        color: #2a3544;
        font-size: 1.08rem;
        margin: 2.2rem 0 0.8rem;
        padding-left: 0.85rem;
        border-left: 3px solid #D4A853;
      }
      .prose p,
      .prose li,
      .prose ol,
      .prose ul,
      .prose em {
        color: #3d4f6f;
      }
      .prose p { margin: 0 0 1.85rem; }
      .prose strong { color: #2a3544; }
      .prose blockquote {
        border-left: 4px solid #D4A853;
        background: #fdf6ec;
        margin: 1.5rem 0;
        padding: 1rem 1.5rem;
        border-radius: 0 8px 8px 0;
        color: #2a3544;
        font-style: italic;
      }
      /* 文首「要点速览」：略小于正文、可读；正文内 HTML 使用 class="blog-tldr" */
      .prose .blog-tldr {
        margin: 0 0 1.35rem;
        padding: 0.85rem 1rem 0.9rem 0.9rem;
        background: #f9f5ef;
        border-left: 3px solid #c9a168;
        border-radius: 0 6px 6px 0;
        font-size: 1rem;
        line-height: 1.72;
        letter-spacing: 0.015em;
        color: #3a2e22;
        font-style: normal;
      }
      .prose .blog-tldr-kicker {
        margin: 0 0 0.55rem;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: none;
        color: #5c4010;
      }
      .prose .blog-tldr ul {
        margin: 0;
        padding-left: 1.15rem;
        list-style: disc;
      }
      .prose .blog-tldr li {
        margin-bottom: 0.5rem;
        line-height: 1.68;
      }
      .prose .blog-tldr li:last-child {
        margin-bottom: 0;
      }
      .prose ul, .prose ol { padding-left: 1.5rem; margin: 0 0 1.5rem; }
      .prose li { margin-bottom: 0.85rem; line-height: 2; }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.95rem;
        border-radius: 8px;
        overflow: hidden;
      }
      .prose th {
        background: #2C1810;
        color: #D4A853;
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.9rem;
      }
      .prose td {
        padding: 0.65rem 1rem;
        border-bottom: 1px solid #e8e0d5;
        color: #3d4f6f;
      }
      .prose tr:nth-child(even) td { background: #fdf6ec; }
      .prose hr { border: none; border-top: 1px solid #e8e0d5; margin: 2rem 0; }

      /* ── 文末 CTA：与首页 contact-cta 同款（金标题 / 暖灰正文 / 费用 pill / 电话 + 邮箱） ── */
      .cta-box {
        margin-top: 2.5rem;
        padding: 2rem 1.35rem;
        text-align: center;
        border-radius: 12px;
        color: #fff;
        background: #1c2b3f;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.14);
      }
      /* 与首页 contact-cta 同色；思源宋加粗，避免细体在深蓝底上发灰 */
      .cta-box-heading {
        font-family: "Noto Serif SC", "Songti SC", Georgia, "Times New Roman", serif !important;
        font-size: clamp(1.28rem, 2.8vw, 1.6rem);
        font-weight: 700 !important;
        color: #fac775 !important;
        margin: 0 0 0.55rem;
        line-height: 1.35;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
      }
      .cta-box-intro {
        color: #d4cfc3;
        font-size: 0.86rem;
        line-height: 1.6;
        max-width: 34rem;
        margin: 0 auto 1rem;
      }
      .cta-box-fee {
        display: inline-block;
        background: #263649;
        color: rgba(232, 217, 184, 0.92);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        border-radius: 20px;
        margin-bottom: 1.15rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .cta-box-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .cta-box .btn-cta-phone {
        display: inline-block;
        background: #c9a168;
        color: #1c1810;
        padding: 0.72rem 1.35rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.38);
        transition: filter 0.15s ease, box-shadow 0.15s ease;
      }
      .cta-box .btn-cta-phone:hover {
        filter: brightness(1.04);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.42);
      }
      .cta-box .btn-cta-email {
        display: inline-block;
        background: transparent;
        color: rgba(232, 217, 184, 0.95);
        border: 1px solid #c9a168;
        padding: 0.72rem 1.35rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }
      .cta-box .btn-cta-email:hover {
        background: rgba(201, 161, 104, 0.14);
        border-color: #d4b47e;
        color: #fdfbf7;
      }

      /* 侧边栏：服务地区 + 长尾内链 */
      .sidebar-regions-intro {
        font-size: 0.8rem;
        color: #6b5a48;
        line-height: 1.55;
        margin: 0 0 0.85rem;
      }
      .region-link-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .region-link-list li {
        border-bottom: 1px solid #f0ebe3;
        padding: 0.5rem 0;
      }
      .region-link-list li:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .region-link-list a {
        display: block;
        text-decoration: none;
        color: #4a2c1a;
      }
      .region-link-list a:hover .r-main {
        color: #7a5a1a;
      }
      .region-link-list .r-main {
        display: block;
        font-size: 0.86rem;
        font-weight: 700;
        line-height: 1.35;
      }
      .region-link-list .r-tail {
        display: block;
        font-size: 0.72rem;
        color: #8a7a68;
        font-weight: 500;
        margin-top: 0.15rem;
        line-height: 1.35;
      }
      .sidebar-address {
        margin: 0.85rem 0 0;
        padding-top: 0.85rem;
        border-top: 1px solid #e8e0d5;
        font-size: 0.78rem;
        line-height: 1.5;
      }
      .sidebar-address a {
        color: #5a6d85;
        font-weight: 600;
        text-decoration: none;
      }
      .sidebar-address a:hover {
        color: #7a5a1a;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .sidebar-member-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .sidebar-member-list li {
        font-size: 0.84rem;
        padding: 0.55rem 0;
        border-bottom: 1px solid #f0ebe3;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
        line-height: 1.45;
      }
      .sidebar-member-list li:last-child {
        border-bottom: none;
      }
      .sidebar-member-list a {
        color: #7a5a1a;
        text-decoration: none;
        font-weight: 600;
        flex: 1;
        min-width: 0;
      }
      .sidebar-member-list a:hover {
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .sidebar-member-note {
        font-size: 0.72rem;
        color: #9a8060;
        white-space: nowrap;
        flex-shrink: 0;
      }
      /* ── 侧边栏 ── */
      .sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

      .sidebar-card {
        background: white;
        border: 1px solid #e8e0d5;
        border-radius: 10px;
        padding: 1.25rem;
        box-shadow: 0 2px 8px rgba(44,24,16,0.05);
      }
      .sidebar-card h3 {
        color: var(--text-heading);
        font-size: 0.88rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #D4A853;
      }

      /* 联系卡片 */
      .contact-card { background: linear-gradient(135deg, #2C1810, #4A2C1A); border: none; }
      .contact-card h3 { color: #D4A853; border-bottom-color: rgba(212,168,83,0.4); }
      .contact-card p { color: rgba(255,255,255,0.85); font-size: 0.88rem; margin: 0 0 1rem; line-height: 1.6; }
      .contact-card a.call-btn {
        display: block; background: #D4A853; color: var(--text-heading);
        text-align: center; padding: 0.65rem; border-radius: 6px;
        text-decoration: none; font-weight: 700; font-size: 0.92rem; margin-bottom: 0.5rem;
      }
      .contact-card a.email-btn {
        display: block; background: transparent; color: white;
        text-align: center; padding: 0.65rem; border-radius: 6px;
        text-decoration: none; font-weight: 600; font-size: 0.88rem;
        border: 1px solid rgba(255,255,255,0.4);
      }

      /* 相关文章 */
      .related-list { list-style: none; padding: 0; margin: 0; }
      .related-list li { border-bottom: 1px solid #f0ebe3; padding: 0.6rem 0; }
      .related-list li:last-child { border-bottom: none; padding-bottom: 0; }
      .related-list a {
        color: #4A2C1A; text-decoration: none; font-size: 0.88rem;
        line-height: 1.45; display: block;
      }
      .related-list a:hover { color: #D4A853; }
      .related-list .rdate { font-size: 0.75rem; color: #9A8060; margin-top: 0.2rem; }

      /* 延伸阅读（带一句场景说明的内链） */
      .sidebar-related-intro {
        font-size: 0.84rem;
        color: #6b5a48;
        line-height: 1.65;
        margin: 0 0 1rem;
      }
      .related-reading-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .related-reading-list li {
        padding: 0.85rem 0;
        border-bottom: 1px solid #f0ebe3;
      }
      .related-reading-list li:first-child {
        padding-top: 0;
      }
      .related-reading-list li:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .related-reading-list a {
        color: #4a2c1a;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.4;
        display: block;
      }
      .related-reading-list a:hover {
        color: #d4a853;
      }
      .related-reading-teaser {
        margin: 0.4rem 0 0;
        font-size: 0.8rem;
        color: #7a6a58;
        line-height: 1.55;
        font-weight: 500;
      }

      /* 服务导航 */
      .service-list { list-style: none; padding: 0; margin: 0; }
      .service-list li { padding: 0.3rem 0; border-bottom: 1px solid #f0ebe3; font-size: 0.88rem; }
      .service-list li:last-child { border-bottom: none; }
      .service-list a { color: #9A8060; text-decoration: none; }
      .service-list a:hover { color: var(--text-heading); }

      @media (max-width: 900px) {
        .post-layout { grid-template-columns: 1fr; }
        /* sidebar stays below on mobile */
        .contact-card { display: none; }
      }
