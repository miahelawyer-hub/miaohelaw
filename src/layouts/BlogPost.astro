---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry['blog']['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const slug = Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = `https://www.miaohelaw.ca${slug}`;
const dateStr = pubDate.toISOString().split('T')[0];
const updatedStr = updatedDate ? updatedDate.toISOString().split('T')[0] : dateStr;

// 获取其他博文用于侧边栏
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).filter(p => `/blog/${p.id}` !== slug && `/blog/${p.id}/` !== slug).slice(0, 4);
---

<html lang="zh">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="zh_CN" />
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "url": canonicalUrl,
        "datePublished": dateStr,
        "dateModified": updatedStr,
        "inLanguage": "zh",
        "author": {
          "@type": "Person",
          "@id": "https://www.miaohelaw.ca/#person",
          "name": "Miao He",
          "alternateName": ["何淼", "Mia He"],
          "jobTitle": "Family Law Lawyer",
          "url": "https://www.miaohelaw.ca",
          "telephone": "+1-647-930-6688"
        },
        "publisher": {
          "@type": "Person",
          "@id": "https://www.miaohelaw.ca/#person",
          "name": "Miao He",
          "url": "https://www.miaohelaw.ca"
        },
        "about": {
          "@type": "LegalService",
          "name": "Ontario Family Law",
          "areaServed": "Greater Toronto Area"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://www.miaohelaw.ca/" },
          { "@type": "ListItem", "position": 2, "name": "博客", "item": "https://www.miaohelaw.ca/blog/" },
          { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
        ]
      }
    ])} />
    <style>
      * { box-sizing: border-box; }
      body { background: #faf8f5; margin: 0; }

      /* ── Hero ── */
      .post-hero {
        background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 100%);
        padding: 3rem 1.5rem 2.5rem;
        text-align: center;
      }
      .post-hero .breadcrumb {
        font-size: 0.78rem;
        color: #c9a96e;
        margin-bottom: 1.2rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .post-hero .breadcrumb a { color: #c9a96e; text-decoration: none; }
      .post-hero .breadcrumb a:hover { color: #D4A853; }
      .post-hero h1 {
        color: #ffffff;
        font-size: clamp(1.5rem, 3.5vw, 2.1rem);
        line-height: 1.35;
        margin: 0 auto 1.2rem;
        max-width: 820px;
        font-weight: 700;
      }
      .post-hero .meta {
        color: #D4A853;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
      }

      /* ── 主体布局：正文 + 侧边栏 ── */
      .post-layout {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2.5rem;
        align-items: start;
      }

      /* ── 正文 ── */
      .prose {
        background: #ffffff;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 2px 12px rgba(44,24,16,0.07);
        color: #2C1810;
        font-size: 1.05rem;
        line-height: 1.85;
        min-width: 0;
      }
      .prose h2 {
        color: #2C1810;
        font-size: 1.3rem;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.45rem;
        border-bottom: 2px solid #D4A853;
      }
      .prose h3 {
        color: #4A2C1A;
        font-size: 1.08rem;
        margin: 1.8rem 0 0.6rem;
      }
      .prose p { margin: 0 0 1.25rem; }
      .prose strong { color: #2C1810; }
      .prose blockquote {
        border-left: 4px solid #D4A853;
        background: #fdf6ec;
        margin: 1.5rem 0;
        padding: 1rem 1.5rem;
        border-radius: 0 8px 8px 0;
        color: #4A2C1A;
        font-style: italic;
      }
      .prose ul, .prose ol { padding-left: 1.5rem; margin: 0 0 1.25rem; }
      .prose li { margin-bottom: 0.5rem; }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.95rem;
        border-radius: 8px;
        overflow: hidden;
      }
      .prose th {
        background: #2C1810;
        color: #D4A853;
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.9rem;
      }
      .prose td {
        padding: 0.65rem 1rem;
        border-bottom: 1px solid #e8e0d5;
        color: #2C1810;
      }
      .prose tr:nth-child(even) td { background: #fdf6ec; }
      .prose hr { border: none; border-top: 1px solid #e8e0d5; margin: 2rem 0; }

      /* ── 文末 CTA ── */
      .cta-box {
        background: linear-gradient(135deg, #2C1810, #4A2C1A);
        color: white;
        padding: 2rem;
        border-radius: 12px;
        margin-top: 2.5rem;
        text-align: center;
      }
      .cta-box h3 { color: #D4A853; margin: 0 0 0.6rem; font-size: 1.1rem; }
      .cta-box p { color: rgba(255,255,255,0.92); margin: 0 0 1.25rem; font-size: 0.95rem; }
      .cta-links { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
      .btn-primary {
        display: inline-block; background: #D4A853; color: #2C1810;
        padding: 0.7rem 1.5rem; border-radius: 6px; text-decoration: none;
        font-weight: 700; font-size: 0.92rem;
      }
      .btn-secondary {
        display: inline-block; background: transparent; color: white;
        border: 2px solid white; padding: 0.7rem 1.5rem; border-radius: 6px;
        text-decoration: none; font-weight: 700; font-size: 0.92rem;
      }

      /* ── 侧边栏 ── */
      .sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

      .sidebar-card {
        background: white;
        border: 1px solid #e8e0d5;
        border-radius: 10px;
        padding: 1.25rem;
        box-shadow: 0 2px 8px rgba(44,24,16,0.05);
      }
      .sidebar-card h3 {
        color: #2C1810;
        font-size: 0.88rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #D4A853;
      }

      /* 联系卡片 */
      .contact-card { background: linear-gradient(135deg, #2C1810, #4A2C1A); border: none; }
      .contact-card h3 { color: #D4A853; border-bottom-color: rgba(212,168,83,0.4); }
      .contact-card p { color: rgba(255,255,255,0.85); font-size: 0.88rem; margin: 0 0 1rem; line-height: 1.6; }
      .contact-card a.call-btn {
        display: block; background: #D4A853; color: #2C1810;
        text-align: center; padding: 0.65rem; border-radius: 6px;
        text-decoration: none; font-weight: 700; font-size: 0.92rem; margin-bottom: 0.5rem;
      }
      .contact-card a.email-btn {
        display: block; background: transparent; color: white;
        text-align: center; padding: 0.65rem; border-radius: 6px;
        text-decoration: none; font-weight: 600; font-size: 0.88rem;
        border: 1px solid rgba(255,255,255,0.4);
      }

      /* 相关文章 */
      .related-list { list-style: none; padding: 0; margin: 0; }
      .related-list li { border-bottom: 1px solid #f0ebe3; padding: 0.6rem 0; }
      .related-list li:last-child { border-bottom: none; padding-bottom: 0; }
      .related-list a {
        color: #4A2C1A; text-decoration: none; font-size: 0.88rem;
        line-height: 1.45; display: block;
      }
      .related-list a:hover { color: #D4A853; }
      .related-list .rdate { font-size: 0.75rem; color: #9A8060; margin-top: 0.2rem; }

      /* 服务导航 */
      .service-list { list-style: none; padding: 0; margin: 0; }
      .service-list li { padding: 0.3rem 0; border-bottom: 1px solid #f0ebe3; font-size: 0.88rem; }
      .service-list li:last-child { border-bottom: none; }
      .service-list a { color: #9A8060; text-decoration: none; }
      .service-list a:hover { color: #2C1810; }

      @media (max-width: 900px) {
        .post-layout { grid-template-columns: 1fr; }
        .sidebar { order: -1; }
        .contact-card { display: none; }
      }
      @media (max-width: 600px) {
        .post-hero { padding: 2rem 1rem 1.5rem; }
        .post-hero h1 { font-size: 1.35rem; }
        .prose { padding: 1.5rem 1.1rem; font-size: 1rem; }
        .post-layout { padding: 1.5rem 1rem; gap: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <!-- Hero -->
        <div class="post-hero">
          <p class="breadcrumb">
            <a href="/">首页</a> &rsaquo;
            <a href="/blog">博客文章</a> &rsaquo;
            法律指南
          </p>
          <h1>{title}</h1>
          <p class="meta">
            何淼律师 Miao He &nbsp;·&nbsp;
            <FormattedDate date={pubDate} />
            {updatedDate && <span>&nbsp;（更新：<FormattedDate date={updatedDate} />）</span>}
            &nbsp;·&nbsp; H. LAW FIRM 恒. 律师事务所
          </p>
        </div>

        <!-- 正文 + 侧边栏 -->
        <div class="post-layout">

          <!-- 正文 -->
          <div class="prose">
            <slot />
            <!-- 文末 CTA -->
            <div class="cta-box">
              <h3>预约初次法律咨询</h3>
              <p>何淼律师提供 30 分钟初次咨询（$220+HST）。了解您的权利、评估案件走向、制定处理方案。普通话 · 英文双语服务。</p>
              <div class="cta-links">
                <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
                <a href="/contact" class="btn-secondary">在线预约</a>
              </div>
            </div>
          </div>

          <!-- 侧边栏 -->
          <aside class="sidebar">

            <!-- 联系卡片 -->
            <div class="sidebar-card contact-card">
              <h3>预约咨询</h3>
              <p>何淼律师 · 普通话 · 英文<br/>初次咨询 30 分钟 $220+HST<br/>Markham · 服务 GTA 全区</p>
              <a href="tel:6479306688" class="call-btn">📞 647-930-6688</a>
              <a href="mailto:miao@miaohelaw.ca" class="email-btn">✉ miao@miaohelaw.ca</a>
            </div>

            <!-- 相关文章 -->
            {allPosts.length > 0 && (
              <div class="sidebar-card">
                <h3>相关文章</h3>
                <ul class="related-list">
                  {allPosts.map(post => (
                    <li>
                      <a href={`/blog/${post.id}`}>
                        {post.data.title}
                      </a>
                      <div class="rdate"><FormattedDate date={post.data.pubDate} /></div>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- 服务导航 -->
            <div class="sidebar-card">
              <h3>家庭法服务</h3>
              <ul class="service-list">
                <li><a href="/family-law/divorce-litigation">离婚诉讼</a></li>
                <li><a href="/family-law/child-custody">子女监护权</a></li>
                <li><a href="/family-law/support">抚养费</a></li>
                <li><a href="/family-law/domestic-contracts">婚前协议</a></li>
                <li><a href="/family-law/cross-border-assets">跨境资产</a></li>
                <li><a href="/family-law/mediation">调解</a></li>
              </ul>
            </div>

          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
