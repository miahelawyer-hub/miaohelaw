---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import HeaderEn from '../components/HeaderEn.astro';
import '../styles/blog-prose-body-color.css';
import { SITE_TITLE, SITE_URL } from '../consts';

type RelatedReadingItem = { slug: string; line: string };

type FaqStructuredItem = { question: string; answer: string };

type Props = {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  keywords?: string;
  tags?: string[];
  relatedIntro?: string;
  relatedReading?: RelatedReadingItem[];
  pairedArticlePath?: string;
  faqStructured?: FaqStructuredItem[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  keywords,
  tags,
  relatedIntro,
  relatedReading,
  pairedArticlePath,
  faqStructured,
} = Astro.props;

const faqPageMainEntity =
  faqStructured && faqStructured.length > 0
    ? faqStructured.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      }))
    : [
        {
          '@type': 'Question',
          name: title,
          acceptedAnswer: { '@type': 'Answer', text: description },
        },
      ];

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(pathname, Astro.site).href;
const pathCore = pathname.replace(/\/$/, '') || '/';
const publishedIso = pubDate.toISOString();
const modifiedIso = (updatedDate ?? pubDate).toISOString();
const articleAuthorUrl = 'https://www.miaohelaw.ca/en/about/';
const siteBase = Astro.site ?? new URL('https://www.miaohelaw.ca/');
function absoluteUrl(path: string) {
  const p = path.startsWith('/') ? path : `/${path}`;
  return new URL(p, siteBase).href;
}

const siteOrigin = SITE_URL.replace(/\/$/, '');
const webPageId = `${canonicalUrl}#webpage`;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;

const articleLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  datePublished: publishedIso,
  dateModified: modifiedIso,
  inLanguage: 'en-CA',
  isAccessibleForFree: true,
  image: [`${siteOrigin}/miao-he-lawyer.jpeg`],
  author: {
    '@type': 'Person',
    '@id': `${siteOrigin}/#person`,
    name: 'Miao He',
    alternateName: ['何淼', 'Mia He'],
    jobTitle: 'Family Law Lawyer',
    url: `${siteOrigin}/`,
    telephone: '+1-647-930-6688',
  },
  publisher: {
    '@type': 'Person',
    '@id': `${siteOrigin}/#person`,
    name: 'Miao He',
    url: `${siteOrigin}/`,
  },
  provider: { '@id': `${siteOrigin}/#legalservice` },
  about: {
    '@type': 'LegalService',
    name: 'Ontario Family Law',
    areaServed: ['Greater Toronto Area', 'Ontario'],
  },
  articleSection: 'Ontario family law',
  mainEntityOfPage: { '@type': 'WebPage', '@id': webPageId },
};
if (keywords) {
  articleLd.keywords = keywords
    .split(/[,，]/)
    .map((s) => s.trim())
    .filter(Boolean);
}

const faqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqPageMainEntity,
};

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': webPageId,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: 'en-CA',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteOrigin}/#website`,
    url: `${siteOrigin}/`,
    name: SITE_TITLE,
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: `${siteOrigin}/miao-he-lawyer.jpeg`,
  },
  datePublished: publishedIso,
  dateModified: modifiedIso,
  breadcrumb: { '@id': breadcrumbId },
};

const webSiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: `${siteOrigin}/`,
  name: SITE_TITLE,
  alternateName: ['miaohelaw.ca', '何淼律师', 'Miao He Law'],
  inLanguage: ['zh-CN', 'en-CA'],
  publisher: { '@id': `${siteOrigin}/#person` },
};

const legalServiceLd = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  '@id': `${siteOrigin}/#legalservice`,
  name: 'H. LAW FIRM',
  alternateName: ['H. LAW FIRM 恒. 律师事务所', '恒律师事务所', 'Miao He Law Firm Ontario'],
  description:
    'Ontario family law: divorce and separation, parenting and support, property division, domestic contracts, and cross-border issues. Mandarin and English. Serving Toronto, Markham, Richmond Hill, Scarborough, the GTA, and province-wide.',
  url: `${siteOrigin}/en/contact/`,
  image: `${siteOrigin}/miao-he-lawyer.jpeg`,
  telephone: '+1-647-930-6688',
  email: 'miao@miaohelaw.ca',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '208-7050 Woodbine Ave',
    addressLocality: 'Markham',
    addressRegion: 'ON',
    postalCode: 'L3R 4G8',
    addressCountry: 'CA',
  },
  areaServed: [
    { '@type': 'City', name: 'Toronto' },
    { '@type': 'City', name: 'Markham' },
    { '@type': 'City', name: 'Richmond Hill' },
    { '@type': 'City', name: 'Vaughan' },
    { '@type': 'City', name: 'Mississauga' },
    { '@type': 'City', name: 'Scarborough' },
    { '@type': 'AdministrativeArea', name: 'Greater Toronto Area' },
    { '@type': 'AdministrativeArea', name: 'Ontario' },
  ],
  sameAs: ['https://www.linkedin.com/in/mia-he-93422b160/'],
  founder: { '@id': `${siteOrigin}/#person` },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteOrigin}/en/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

const structuredDataJson = JSON.stringify([
  articleLd,
  webPageLd,
  webSiteLd,
  legalServiceLd,
  faqPageLd,
  breadcrumbLd,
]);

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
}

const allBlogEntriesEn = await getCollection('blog-en');
const allPosts = allBlogEntriesEn
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter((p) => `/en/blog/${p.id}` !== pathCore && `/en/blog/${p.id}/` !== pathname)
  .slice(0, 4);

function titleForEnBlogSlug(slug: string): string {
  return allBlogEntriesEn.find((p) => p.id === slug)?.data.title ?? slug;
}

const defaultRelatedIntroEn =
  'If you want to go deeper on related topics, you may find these earlier articles helpful:';
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogType="article" />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_CA" />
    {pairedArticlePath && <meta property="og:locale:alternate" content="zh_CN" />}
    <meta property="article:published_time" content={publishedIso} />
    <meta property="article:modified_time" content={modifiedIso} />
    <meta property="article:author" content={articleAuthorUrl} />
    <meta name="author" content="Miao He" />
    <meta property="og:url" content={canonicalUrl} />
    {pairedArticlePath ? (
      <>
        <link rel="alternate" hreflang="en" href={canonicalUrl} />
        <link rel="alternate" hreflang="zh-CN" href={absoluteUrl(pairedArticlePath)} />
        <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
      </>
    ) : (
      <link rel="alternate" hreflang="en" href={canonicalUrl} />
    )}
    <script type="application/ld+json" set:html={structuredDataJson} />
    <style is:global>
      * { box-sizing: border-box; }
      body { background: var(--bg); margin: 0; font-family: Georgia, serif; }

      .post-hero { background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0, 0, 0, 0.35); padding: 3rem 1.5rem 2.5rem; text-align: center; }
      .post-hero .breadcrumb { font-size: 0.78rem; color: #c9a96e; margin-bottom: 1.2rem; letter-spacing: 0.04em; text-transform: uppercase; }
      .post-hero .breadcrumb a { color: #c9a96e; text-decoration: none; }
      .post-hero .breadcrumb a:hover { color: #D4A853; }
      .post-hero h1 { color: #ffffff; font-size: clamp(1.5rem, 3.5vw, 2.1rem); line-height: 1.35; margin: 0 auto 1.2rem; max-width: 820px; font-weight: 700; text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5), 0 3px 24px rgba(0, 0, 0, 0.45); }
      .post-hero .meta { color: #D4A853; font-size: 0.82rem; letter-spacing: 0.04em; }
      .post-layout { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; align-items: start; }
      .prose {
        background: #ffffff;
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 2px 12px rgba(44,24,16,0.07);
        color: var(--text-primary);
        font-family: var(--font-en-body);
        font-size: 1.02rem;
        line-height: 2;
        letter-spacing: 0.02em;
        min-width: 0;
      }
      .prose h2 { font-size: 1.15rem; margin: 3.25rem 0 1.35rem; padding: 0.55rem 1.1rem 0.55rem 1rem; background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 100%); color: #ffffff; border-radius: 6px; }
      .prose h3 { color: var(--text-heading); font-size: 1.08rem; margin: 2.2rem 0 0.8rem; padding-left: 0.85rem; border-left: 3px solid #D4A853; }
      .prose p,
      .prose li,
      .prose ol,
      .prose ul,
      .prose em {
        color: var(--text-primary);
      }
      .prose p { margin: 0 0 1.85rem; }
      .prose strong { color: var(--text-heading); }
      .prose blockquote { border-left: 4px solid #D4A853; background: #fdf6ec; margin: 1.5rem 0; padding: 1rem 1.5rem; border-radius: 0 8px 8px 0; color: var(--text-heading); font-style: italic; }
      .prose .blog-tldr {
        margin: 0 0 1.35rem;
        padding: 0.85rem 1rem 0.9rem 0.9rem;
        background: #f9f5ef;
        border-left: 3px solid #c9a168;
        border-radius: 0 6px 6px 0;
        font-size: 1rem;
        line-height: 1.72;
        letter-spacing: 0.015em;
        color: #3a2e22;
        font-style: normal;
      }
      .prose .blog-tldr-kicker {
        margin: 0 0 0.55rem;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: none;
        color: #5c4010;
      }
      .prose .blog-tldr ul {
        margin: 0;
        padding-left: 1.15rem;
        list-style: disc;
      }
      .prose .blog-tldr li {
        margin-bottom: 0.5rem;
        line-height: 1.68;
      }
      .prose .blog-tldr li:last-child {
        margin-bottom: 0;
      }
      .prose ul, .prose ol { padding-left: 1.5rem; margin: 0 0 1.5rem; }
      .prose li { margin-bottom: 0.85rem; line-height: 2; }
      .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; border-radius: 8px; overflow: hidden; }
      .prose th { background: #2C1810; color: #D4A853; padding: 0.75rem 1rem; text-align: left; font-weight: 600; font-size: 0.9rem; }
      .prose td { padding: 0.65rem 1rem; border-bottom: 1px solid #e8e0d5; color: var(--text-primary); }
      .prose tr:nth-child(even) td { background: #fdf6ec; }
      .prose hr { border: none; border-top: 1px solid #e8e0d5; margin: 2rem 0; }
      .cta-box {
        margin-top: 2.5rem;
        padding: 2rem 1.35rem;
        text-align: center;
        border-radius: 12px;
        color: #fff;
        background: #1c2b3f;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 14px 32px rgba(12, 22, 38, 0.35);
      }
      .cta-box-heading {
        font-family: "Playfair Display", Georgia, "Times New Roman", serif !important;
        font-size: clamp(1.28rem, 2.8vw, 1.6rem);
        font-weight: 600 !important;
        color: #fac775 !important;
        margin: 0 0 0.55rem;
        line-height: 1.35;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
      }
      .cta-box-intro {
        color: #d4cfc3;
        font-size: 0.88rem;
        font-weight: 500;
        line-height: 1.65;
        max-width: 34rem;
        margin: 0 auto 1rem;
      }
      .cta-box-fee {
        display: inline-block;
        background: #263649;
        color: rgba(248, 250, 252, 0.92);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        border-radius: 20px;
        margin-bottom: 1.15rem;
        border: 1px solid rgba(255, 255, 255, 0.14);
      }
      .cta-box-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .cta-box .btn-cta-phone {
        display: inline-block;
        background: #c9a168;
        color: #1c2b3f;
        padding: 0.72rem 1.35rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.38);
        transition: filter 0.15s ease, box-shadow 0.15s ease;
      }
      .cta-box .btn-cta-phone:hover {
        filter: brightness(1.04);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.42);
      }
      .cta-box .btn-cta-email {
        display: inline-block;
        background: transparent;
        color: rgba(248, 250, 252, 0.95);
        border: 1px solid #c9a168;
        padding: 0.72rem 1.35rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }
      .cta-box .btn-cta-email:hover {
        background: rgba(201, 161, 104, 0.14);
        border-color: #d4b47e;
        color: #fdfbf7;
      }
      .sidebar-regions-intro {
        font-size: 0.8rem;
        color: #6b5a48;
        line-height: 1.55;
        margin: 0 0 0.85rem;
      }
      .region-link-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .region-link-list li {
        border-bottom: 1px solid #f0ebe3;
        padding: 0.5rem 0;
      }
      .region-link-list li:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .region-link-list a {
        display: block;
        text-decoration: none;
        color: #4a2c1a;
      }
      .region-link-list a:hover .r-main {
        color: #7a5a1a;
      }
      .region-link-list .r-main {
        display: block;
        font-size: 0.86rem;
        font-weight: 700;
        line-height: 1.35;
      }
      .region-link-list .r-tail {
        display: block;
        font-size: 0.72rem;
        color: #8a7a68;
        font-weight: 500;
        margin-top: 0.15rem;
        line-height: 1.35;
      }
      .sidebar-address {
        margin: 0.85rem 0 0;
        padding-top: 0.85rem;
        border-top: 1px solid #e8e0d5;
        font-size: 0.78rem;
        line-height: 1.5;
      }
      .sidebar-address a {
        color: #5a6d85;
        font-weight: 600;
        text-decoration: none;
      }
      .sidebar-address a:hover {
        color: #7a5a1a;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .author-bio { margin-top: 2.5rem; border-top: 2px solid #e8e0d5; padding-top: 1.5rem; }
      .author-bio-text p { margin: 0 0 0.6rem; font-size: 0.92rem; color: var(--text-primary); line-height: 1.65; }
      .author-bio-name { font-size: 1rem !important; font-weight: 700; color: var(--text-heading) !important; }
      .author-bio-title { font-size: 0.82rem !important; color: #9A8060 !important; letter-spacing: 0.03em; }
      .author-bio-links a { color: #9A8060; text-decoration: none; font-size: 0.85rem; }
      .author-bio-links a:hover { color: var(--text-heading); }
      .sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
      .sidebar-card { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.25rem; box-shadow: 0 2px 8px rgba(44,24,16,0.05); }
      .sidebar-card h3 { color: var(--text-heading); font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #D4A853; }
      .contact-card { background: linear-gradient(135deg, #2C1810, #4A2C1A); border: none; }
      .contact-card h3 { color: #D4A853; border-bottom-color: rgba(212,168,83,0.4); }
      .contact-card p { color: rgba(255,255,255,0.85); font-size: 0.88rem; margin: 0 0 1rem; line-height: 1.6; }
      .contact-card a.call-btn { display: block; background: #D4A853; color: var(--text-heading); text-align: center; padding: 0.65rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.92rem; margin-bottom: 0.5rem; }
      .contact-card a.email-btn { display: block; background: transparent; color: white; text-align: center; padding: 0.65rem; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.88rem; border: 1px solid rgba(255,255,255,0.4); }
      .related-list { list-style: none; padding: 0; margin: 0; }
      .related-list li { border-bottom: 1px solid #f0ebe3; padding: 0.6rem 0; }
      .related-list li:last-child { border-bottom: none; padding-bottom: 0; }
      .related-list a { color: #4A2C1A; text-decoration: none; font-size: 0.88rem; line-height: 1.45; display: block; }
      .related-list a:hover { color: #D4A853; }
      .related-list .rdate { font-size: 0.75rem; color: #9A8060; margin-top: 0.2rem; }
      .sidebar-related-intro {
        font-size: 0.84rem;
        color: #6b5a48;
        line-height: 1.65;
        margin: 0 0 1rem;
      }
      .related-reading-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .related-reading-list li {
        padding: 0.85rem 0;
        border-bottom: 1px solid #f0ebe3;
      }
      .related-reading-list li:first-child {
        padding-top: 0;
      }
      .related-reading-list li:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .related-reading-list a {
        color: #4a2c1a;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.4;
        display: block;
      }
      .related-reading-list a:hover {
        color: #d4a853;
      }
      .related-reading-teaser {
        margin: 0.4rem 0 0;
        font-size: 0.8rem;
        color: #7a6a58;
        line-height: 1.55;
        font-weight: 500;
      }
      .service-list { list-style: none; padding: 0; margin: 0; }
      .service-list li { padding: 0.3rem 0; border-bottom: 1px solid #f0ebe3; font-size: 0.88rem; }
      .service-list li:last-child { border-bottom: none; }
      .service-list a { color: #9A8060; text-decoration: none; }
      .service-list a:hover { color: var(--text-heading); }
      .sidebar-member-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .sidebar-member-list li {
        font-size: 0.84rem;
        padding: 0.55rem 0;
        border-bottom: 1px solid #f0ebe3;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
        line-height: 1.45;
      }
      .sidebar-member-list li:last-child {
        border-bottom: none;
      }
      .sidebar-member-list a {
        color: #7a5a1a;
        text-decoration: none;
        font-weight: 600;
        flex: 1;
        min-width: 0;
      }
      .sidebar-member-list a:hover {
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .sidebar-member-note {
        font-size: 0.72rem;
        color: #9a8060;
        white-space: nowrap;
        flex-shrink: 0;
      }
      @media (max-width: 900px) { .post-layout { grid-template-columns: 1fr; } .contact-card { display: none; } }
      @media (max-width: 600px) { .post-hero { padding: 2rem 1rem 1.5rem; } .post-hero h1 { font-size: 1.35rem; } .prose { padding: 1.5rem 1.1rem; font-size: 0.96rem; line-height: 1.95; } .post-layout { padding: 1.5rem 1rem; gap: 1.5rem; } }
    </style>
  </head>
  <body>
    <HeaderEn />
    <main>
      <article>
        <div class="post-hero">
          <p class="breadcrumb">
            <a href="/en/">Home</a> &rsaquo;
            <a href="/en/blog">Blog</a> &rsaquo;
            Family Law
          </p>
          <h1>{title}</h1>
          <p class="meta">
            Miao He &nbsp;·&nbsp; {formatDate(pubDate)}
            {updatedDate && <span>&nbsp;(Updated: {formatDate(updatedDate)})</span>}
            &nbsp;·&nbsp; H. LAW FIRM
          </p>
          <p class="post-meta-updated">
            Page last updated: <FormattedDate date={updatedDate ?? pubDate} />
          </p>
        </div>

        <div class="post-layout">
          <div class="prose">
            <slot />
            <div class="cta-box">
              <h3 class="cta-box-heading">Speak with Miao He</h3>
              <p class="cta-box-intro">Mandarin & English · Markham office · GTA &amp; Ontario</p>
              <div class="cta-box-fee">Initial consultation 30 min · $220 + HST · billed in 6-minute units</div>
