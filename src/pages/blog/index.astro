---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date) {
  return new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="博客文章 | 何淼律师 — Ontario家庭法律师"
    description="何淼律师撰写的Ontario家庭法文章，涵盖离婚、子女监护、财产分割、婚前协议、跨境资产等华人最关心的法律问题。"
  />
  <meta name="keywords" content="Ontario家庭法博客,华人离婚指南,离婚法律知识,子女监护权Ontario,婚前协议,何淼律师" />
  <meta property="og:title" content="博客文章 | 多伦多华人家庭法律师 何淼" />
  <meta property="og:description" content="何淼律师分享安省家庭法实用知识，涵盖离婚、子女监护、财产分割、婚前协议等。普通话全程服务，647-930-6688。" />
  <meta property="og:url" content="https://www.miaohelaw.ca/blog" />
  <meta property="og:type" content="website" />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "何淼律师博客 | 多伦多华人家庭法",
    "url": "https://www.miaohelaw.ca/blog",
    "description": "何淼律师分享加拿大安省家庭法知识",
    "publisher": {"@type":"Person","name":"何淼律师 Miao He","url":"https://www.miaohelaw.ca"}
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"首页","item":"https://www.miaohelaw.ca/"},
      {"@type":"ListItem","position":2,"name":"博客","item":"https://www.miaohelaw.ca/blog"}
    ]
  }</script>
  <style is:global>
    * { box-sizing: border-box; }
    body { background: #faf8f5; margin: 0; }

    .page-hero {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      padding: 3rem 1.5rem 2.5rem;
    }
    .page-hero .inner { max-width: 1100px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; }
    .page-hero p { color: #D4A853; margin: 0; font-size: 0.92rem; }

    .main-wrap { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

    /* ── 置顶大卡片 ── */
    .featured-card {
      display: grid;
      grid-template-columns: 280px 1fr;
      background: white;
      border-radius: 12px;
      box-shadow: 0 2px 16px rgba(44,24,16,0.09);
      overflow: hidden;
      margin-bottom: 2rem;
      text-decoration: none;
      border: 1px solid #e8e0d5;
      transition: box-shadow 0.2s;
    }
    .featured-card:hover { box-shadow: 0 6px 28px rgba(44,24,16,0.14); }

    .featured-left {
      background: linear-gradient(160deg, #2C1810 0%, #4A2C1A 60%, #3a2015 100%);
      padding: 2rem 1.75rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }
    .featured-left::before {
      content: '法';
      position: absolute;
      right: -0.5rem;
      bottom: -1rem;
      font-size: 8rem;
      color: rgba(212,168,83,0.07);
      font-weight: 900;
      line-height: 1;
      pointer-events: none;
    }
    .featured-tag {
      display: inline-block;
      background: rgba(212,168,83,0.15);
      border: 1px solid rgba(212,168,83,0.4);
      color: #D4A853;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      width: fit-content;
    }
    .featured-quote {
      color: rgba(255,255,255,0.75);
      font-size: 0.85rem;
      line-height: 1.7;
      margin: 1.25rem 0 0;
    }
    .featured-quote strong {
      color: #D4A853;
      display: block;
      font-size: 1rem;
      margin-bottom: 0.4rem;
    }
    .featured-author {
      color: rgba(255,255,255,0.45);
      font-size: 0.72rem;
      margin-top: 1.5rem;
      letter-spacing: 0.04em;
    }

    .featured-right { padding: 2rem 2rem 2rem 1.75rem; display: flex; flex-direction: column; justify-content: center; }
    .featured-date { color: #9A8060; font-size: 0.78rem; margin: 0 0 0.6rem; }
    .featured-title { color: #2C1810; font-size: 1.2rem; font-weight: 700; line-height: 1.4; margin: 0 0 0.85rem; }
    .featured-desc { color: #4A2C1A; font-size: 0.9rem; line-height: 1.75; margin: 0 0 1.25rem; }
    .featured-more {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: white;
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      padding: 0.55rem 1.2rem;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      width: fit-content;
    }

    /* ── 卡片网格 ── */
    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .card {
      background: white;
      border-radius: 10px;
      border: 1px solid #e8e0d5;
      box-shadow: 0 2px 8px rgba(44,24,16,0.05);
      padding: 1.5rem;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.2s, border-color 0.2s;
    }
    .card:hover { box-shadow: 0 4px 18px rgba(44,24,16,0.11); border-color: #D4A853; }
    .card-date { color: #9A8060; font-size: 0.75rem; margin: 0 0 0.5rem; }
    .card-title { color: #2C1810; font-size: 0.95rem; font-weight: 600; line-height: 1.45; margin: 0 0 0.65rem; flex: 1; }
    .card-desc { color: #6B5040; font-size: 0.82rem; line-height: 1.6; margin: 0 0 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 0.75rem; border-top: 1px solid #f0ebe3; }
    .card-arrow { color: #D4A853; font-size: 1rem; }

    /* ── 加载更多 ── */
    .load-more-wrap { text-align: center; margin: 0.5rem 0 2rem; }
    .load-more-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: white;
      border: 2px solid #D4A853;
      color: #2C1810;
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-size: 0.92rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .load-more-btn:hover { background: #D4A853; color: white; }
    .load-more-btn.hidden { display: none; }
    .card[data-hidden="true"] { display: none; }
    .card.hidden { display: none; }

    /* ── CTA ── */
    .cta-box {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
    }
    .cta-box h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.1rem; }
    .cta-box p { color: rgba(255,255,255,0.88); margin: 0 0 1.25rem; font-size: 0.9rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-gold { background: #D4A853; color: #2C1810; padding: 0.65rem 1.4rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem; }
    .btn-outline { background: transparent; color: white; border: 2px solid rgba(255,255,255,0.6); padding: 0.65rem 1.4rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem; }

    @media (max-width: 900px) {
      .grid { grid-template-columns: repeat(2, 1fr); }
      .featured-card { grid-template-columns: 1fr; }
      .featured-left { padding: 1.5rem; }
      .featured-left::before { font-size: 5rem; }
    }
    @media (max-width: 600px) {
      .grid { grid-template-columns: 1fr; }
      .main-wrap { padding: 1.5rem 1rem 3rem; }
      .featured-right { padding: 1.5rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/">首页</a> › 博客文章</p>
        <h1>法律知识 · 博客文章</h1>
        <p>何淼律师撰写 · 普通话全程服务 · 647-930-6688</p>
      </div>
    </div>

    <div class="main-wrap">
      <!-- 置顶第一篇 -->
      {posts.length > 0 && (
        <a href={`/blog/${posts[0].id}/`} class="featured-card">
          <div class="featured-left">
            <div>
              <span class="featured-tag">最新文章</span>
              <p class="featured-quote">
                <strong>何淼律师说</strong>
                了解法律，才能保护自己的权益。每一个决定，都值得在充分知情的情况下做出。
              </p>
            </div>
            <p class="featured-author">何淼律师 · LSO #83315K · 中加双执照</p>
          </div>
          <div class="featured-right">
            <p class="featured-date">{formatDate(posts[0].data.pubDate)}</p>
            <p class="featured-title">{posts[0].data.title}</p>
            <p class="featured-desc">{posts[0].data.description}</p>
            <span class="featured-more">阅读全文 →</span>
          </div>
        </a>
      )}

      <!-- 其余文章网格，默认显示6篇 -->
      <div class="grid" id="post-grid">
        {posts.slice(1).map((post, i) => (
          
            href={`/blog/${post.id}/`}
            class="card"
            data-hidden={i >= 6 ? 'true' : 'false'}
            data-index={i}
          >
            <p class="card-date">{formatDate(post.data.pubDate)}</p>
            <p class="card-title">{post.data.title}</p>
            <p class="card-desc">{post.data.description}</p>
            <div class="card-footer">
              <span style="font-size:0.75rem;color:#9A8060;">何淼律师</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

      <!-- 加载更多按钮 -->
      {posts.length > 7 && (
        <div class="load-more-wrap">
          <button class="load-more-btn" id="load-more-btn">
            查看更多文章 ↓
          </button>
        </div>
      )}

      <div class="cta-box">
        <h2>预约初次法律咨询</h2>
        <p>何淼律师 · 30分钟初次咨询 $220+HST · 普通话 · Markham · 服务Ontario全省</p>
        <div class="cta-btns">
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="/contact" class="btn-outline">在线预约</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <script>
    const btn = document.getElementById('load-more-btn');
    const grid = document.getElementById('post-grid');
    const dataEl = document.getElementById('more-posts-data');
    if (btn && grid && dataEl) {
      const morePosts = JSON.parse(dataEl.textContent);
      if (morePosts.length === 0) btn.style.display = 'none';
      btn.addEventListener('click', () => {
        morePosts.forEach(p => {
          const a = document.createElement('a');
          a.href = p.url;
          a.className = 'card';
          a.innerHTML = `<p class="card-date">${p.date}</p><p class="card-title">${p.title}</p><p class="card-desc">${p.desc}</p><div class="card-footer"><span style="font-size:0.75rem;color:#9A8060;">何淼律师</span><span class="card-arrow">→</span></div>`;
          grid.appendChild(a);
        });
        btn.style.display = 'none';
      });
    }
  </script>
</body>
</html>
