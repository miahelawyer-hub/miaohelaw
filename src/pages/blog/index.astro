---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date) {
  return new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="博客文章 | 何淼律师 — Ontario家庭法律师"
    description="何淼律师撰写的Ontario家庭法文章，涵盖离婚、子女监护、财产分割、婚前协议、跨境资产等华人最关心的法律问题。"
  />
  <meta name="keywords" content="Ontario家庭法博客,华人离婚指南,离婚法律知识,子女监护权Ontario,婚前协议,何淼律师" />
  <style>
    * { box-sizing: border-box; }
    body { background: #faf8f5; margin: 0; }

    .page-hero {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      padding: 3rem 1.5rem 2.5rem;
    }
    .page-hero .container { max-width: 900px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.6); margin-bottom: 0.5rem; }
    .breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.5rem; }
    .page-hero p { color: #D4A853; margin: 0; font-size: 0.95rem; }

    .container { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; }
    .posts-section { padding: 2.5rem 0 4rem; }

    .post-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1px; background: #e8e0d5; border: 1px solid #e8e0d5; border-radius: 12px; overflow: hidden; }

    .post-item { background: white; }
    .post-link { display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem 1.5rem; text-decoration: none; transition: background 0.15s; }
    .post-link:hover { background: #faf8f5; }

    .post-num { font-size: 0.75rem; color: #D4A853; font-weight: 700; min-width: 1.5rem; text-align: right; flex-shrink: 0; }
    .post-body { flex: 1; min-width: 0; }
    .post-title { color: #2C1810; font-size: 0.98rem; font-weight: 600; line-height: 1.45; margin: 0 0 0.25rem; }
    .post-date { color: #9A8060; font-size: 0.78rem; margin: 0; }
    .post-arrow { color: #D4A853; font-size: 0.9rem; flex-shrink: 0; opacity: 0.7; }

    .post-link:hover .post-title { color: #4A2C1A; }
    .post-link:hover .post-arrow { opacity: 1; }

    .cta-box {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      margin-top: 2.5rem;
    }
    .cta-box h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.15rem; }
    .cta-box p { color: rgba(255,255,255,0.88); margin: 0 0 1.25rem; font-size: 0.92rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-gold { background: #D4A853; color: #2C1810; padding: 0.7rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem; }
    .btn-outline { background: transparent; color: white; border: 2px solid white; padding: 0.7rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem; }

    @media (max-width: 600px) {
      .post-link { padding: 1rem 1.1rem; gap: 0.9rem; }
      .post-title { font-size: 0.92rem; }
      .post-num { display: none; }
    }
  </style>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "何淼律师博客 | 多伦多华人家庭法",
    "url": "https://www.miaohelaw.ca/blog",
    "description": "何淼律师分享加拿大安省家庭法知识，涵盖离婚、子女监护、财产分割、婚前协议等实用法律信息。",
    "publisher": {"@type":"Person","name":"何淼律师 Miao He","url":"https://www.miaohelaw.ca"}
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"首页","item":"https://www.miaohelaw.ca/"},
      {"@type":"ListItem","position":2,"name":"博客","item":"https://www.miaohelaw.ca/blog"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "何淼律师博客 | 多伦多华人家庭法",
    "url": "https://www.miaohelaw.ca/blog",
    "description": "何淼律师分享加拿大安省家庭法知识，涵盖离婚、子女监护、财产分割、婚前协议等实用法律信息。",
    "publisher": {"@type":"Person","name":"何淼律师 Miao He","url":"https://www.miaohelaw.ca"}
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"首页","item":"https://www.miaohelaw.ca/"},
      {"@type":"ListItem","position":2,"name":"博客","item":"https://www.miaohelaw.ca/blog"}
    ]
  }</script>
</head>
<body>
  <Header />
  <main>
    <div class="page-hero">
      <div class="container">
        <p class="breadcrumb"><a href="/">首页</a> › 博客文章</p>
        <h1>博客文章</h1>
        <p>何淼律师撰写 · 普通话全程服务 · 647-930-6688</p>
      </div>
    </div>

    <div class="container">
      <div class="posts-section">
        <ul class="post-list">
          {posts.map((post, i) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} class="post-link">
                <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
                <div class="post-body">
                  <p class="post-title">{post.data.title}</p>
                  <p class="post-date">{formatDate(post.data.pubDate)}</p>
                </div>
                <span class="post-arrow">›</span>
              </a>
            </li>
          ))}
        </ul>

        <div class="cta-box">
          <h2>预约初次法律咨询</h2>
          <p>何淼律师 · 30分钟初次咨询 $220+HST · 普通话 · Markham · 服务Ontario全省</p>
          <div class="cta-btns">
            <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
            <a href="/contact" class="btn-outline">在线预约</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
