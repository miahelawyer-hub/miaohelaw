---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_LAST_UPDATED_ZH, SITE_URL } from '../../../consts';
import { isBlogEnPostRoutable, isBlogPostRoutable } from '../../../lib/blogPublished';

export const getStaticPaths = (async () => {
	const posts = (await getCollection('blog'))
		.filter(isBlogPostRoutable)
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
	const enPosts = (await getCollection('blog-en'))
		.filter(isBlogEnPostRoutable)
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
	const n = posts.length;
	const totalPages = Math.max(1, Math.ceil(n / 10));
	const enTotalPages = Math.max(1, Math.ceil(enPosts.length / 10));
	const paths: {
		params: { page: string };
		props: {
			currentPage: number;
			pagePosts: typeof posts;
			totalPages: number;
			totalPosts: number;
			enTotalPages: number;
		};
	}[] = [];
	for (let p = 2; p <= totalPages; p++) {
		paths.push({
			params: { page: String(p) },
			props: {
				currentPage: p,
				pagePosts: posts.slice((p - 1) * 10, p * 10),
				totalPages,
				totalPosts: n,
				enTotalPages,
			},
		});
	}
	return paths;
}) satisfies GetStaticPaths;

const { currentPage, pagePosts, totalPages, totalPosts, enTotalPages } = Astro.props;

function formatDate(date: Date) {
	return new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

const canonicalUrl = `${SITE_URL}/blog/page/${currentPage}/`;
const prevUrl =
	currentPage === 2 ? `${SITE_URL}/blog/` : `${SITE_URL}/blog/page/${currentPage - 1}/`;
const nextUrl = currentPage < totalPages ? `${SITE_URL}/blog/page/${currentPage + 1}/` : null;

const emitHreflang = currentPage <= enTotalPages;

const itemListJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: pagePosts.map((post, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: `${SITE_URL}/blog/${post.id}/`,
		name: post.data.title,
	})),
};

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '首页', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: '博客', item: `${SITE_URL}/blog/` },
		{ '@type': 'ListItem', position: 3, name: `第${currentPage}页`, item: canonicalUrl },
	],
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title={`博客文章 · 第${currentPage}页 | 何淼律师 — Ontario家庭法律师`}
    description={`何淼律师家庭法博客第${currentPage}页，共 ${totalPosts} 篇文章。涵盖离婚、子女监护、财产分割、婚前协议等安省家庭法实用内容。`}
  />
  <meta name="robots" content="index,follow" />
  <link rel="prev" href={prevUrl} />
  {nextUrl && <link rel="next" href={nextUrl} />}
  {emitHreflang && (
    <>
      <link rel="alternate" hreflang="zh-CN" href={canonicalUrl} />
      <link rel="alternate" hreflang="en" href={`${SITE_URL}/en/blog/page/${currentPage}/`} />
      <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/en/blog/page/${currentPage}/`} />
    </>
  )}
  <meta name="keywords" content="Ontario家庭法博客,华人离婚指南,离婚法律知识,子女监护权Ontario,婚前协议,何淼律师" />
  <meta property="og:title" content={`博客文章 · 第${currentPage}页 | 何淼律师`} />
  <meta property="og:description" content={`何淼律师博客第${currentPage}页，共 ${totalPosts} 篇安省家庭法文章。`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="zh_CN" />
  {emitHreflang && <meta property="og:locale:alternate" content="en_CA" />}
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <style is:global>
    * { box-sizing: border-box; }
    body { background: var(--bg); margin: 0; }

    .page-hero { background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0,0,0,0.35);
      padding: 3rem 1.5rem 2.5rem;
    }
    .page-hero .inner { max-width: 1100px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; }
    .page-hero .hero-stat { color: #F5E6C8; margin: 0 0 0.45rem; font-size: 0.96rem; font-weight: 600; letter-spacing: 0.02em; }
    .page-hero .hero-sub { color: #D4A853; margin: 0; font-size: 0.92rem; }

    .main-wrap { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

    .blog-search {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      margin: 0 0 1.25rem;
      padding: 0.85rem;
      border-radius: 14px;
      background: rgba(255,255,255,0.75);
      border: 1px solid rgba(237,232,223,0.95);
      box-shadow: 0 1px 0 rgba(44,24,16,0.02);
    }
    .blog-search-input{
      flex: 1;
      min-width: 0;
      border: 1px solid rgba(212,168,83,0.28);
      background: #fff;
      color: var(--text-heading);
      border-radius: 12px;
      padding: 0.85rem 0.95rem;
      font-size: 1rem;
      line-height: 1.2;
      outline: none;
    }
    .blog-search-input:focus{
      border-color: rgba(212,168,83,0.6);
      box-shadow: 0 0 0 4px rgba(212,168,83,0.18);
    }
    .blog-search-clear{
      flex: none;
      background: transparent;
      border: 1px solid rgba(44,24,16,0.22);
      color: #4A2C1A;
      border-radius: 12px;
      padding: 0.7rem 0.9rem;
      font-size: 0.92rem;
      cursor: pointer;
      white-space: nowrap;
    }
    .blog-search-clear:hover{
      border-color: rgba(212,168,83,0.6);
      background: rgba(212,168,83,0.08);
    }
    .blog-search-meta{
      margin: 0 0 1.25rem;
      color: #6b5a48;
      font-size: 0.88rem;
      line-height: 1.5;
      min-height: 1.35em;
    }
    .blog-search-results { margin: 0 0 1.25rem; }
    .blog-search-results ul { list-style: none; margin: 0; padding: 0; }
    .blog-search-results li { margin: 0 0 0.5rem; }
    .blog-search-results a {
      display: block;
      padding: 0.65rem 0.85rem;
      border-radius: 10px;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(237,232,223,0.95);
      color: var(--text-heading);
      text-decoration: none;
      font-size: 0.92rem;
    }
    .blog-search-results a:hover { border-color: rgba(212,168,83,0.45); }
    .sr-only{
      position:absolute;
      width:1px;
      height:1px;
      padding:0;
      margin:-1px;
      overflow:hidden;
      clip:rect(0,0,0,0);
      white-space:nowrap;
      border:0;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .card {
      background: white;
      border-radius: 10px;
      border: 1px solid #e8e0d5;
      box-shadow: 0 2px 8px rgba(44,24,16,0.05);
      padding: 1.5rem;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.2s, border-color 0.2s;
    }
    .card:hover { box-shadow: 0 4px 18px rgba(44,24,16,0.11); border-color: #D4A853; }
    .card-date { color: #9A8060; font-size: 0.75rem; margin: 0 0 0.5rem; }
    .card-title { color: var(--text-heading); font-size: 0.95rem; font-weight: 600; line-height: 1.45; margin: 0 0 0.65rem; flex: 1; }
    .card-desc { color: #6B5040; font-size: 0.82rem; line-height: 1.6; margin: 0 0 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 0.75rem; border-top: 1px solid #f0ebe3; }
    .card-arrow { color: #D4A853; font-size: 1rem; }

    .pagination {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.45rem 0.65rem;
      margin: 0 0 2rem;
      font-size: 0.88rem;
    }
    .pagination a,
    .pagination span.current {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2.25rem;
      padding: 0.45rem 0.55rem;
      border-radius: 8px;
      text-decoration: none;
      border: 1px solid rgba(44,24,16,0.12);
      color: #4A2C1A;
      background: rgba(255,255,255,0.85);
    }
    .pagination a:hover { border-color: rgba(212,168,83,0.55); }
    .pagination span.current {
      font-weight: 700;
      border-color: rgba(212,168,83,0.55);
      background: rgba(212,168,83,0.12);
    }
    .blog-listing--searching .grid { display: none !important; }

    .cta-box {
      background: #1c2b3f;
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 14px 32px rgba(12, 22, 38, 0.35);
    }
    .cta-box h2 { color: #fac775; margin: 0 0 0.5rem; font-size: 1.1rem; }
    .cta-box p { color: #d4cfc3; margin: 0 0 1.25rem; font-size: 0.9rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-gold {
      background: #c9a168;
      color: #1c2b3f;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      transition: filter 0.15s ease;
    }
    .btn-gold:hover { filter: brightness(1.05); }
    .btn-outline {
      background: transparent;
      color: rgba(248, 250, 252, 0.95);
      border: 1px solid #c9a168;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .btn-outline:hover {
      background: rgba(201, 161, 104, 0.14);
      border-color: #d4b47e;
    }

    @media (max-width: 900px) {
      .grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .grid { grid-template-columns: 1fr; }
      .main-wrap { padding: 1.5rem 1rem 3rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main class="blog-listing-root" id="blog-listing-root">
    <div class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/">首页</a> › <a href="/blog/">博客文章</a> › 第 {currentPage} 页</p>
        <h1>法律知识 · 博客文章</h1>
        <p class="hero-stat">第 {currentPage} / {totalPages} 页 · 共 {totalPosts} 篇</p>
        <p class="hero-sub">何淼律师撰写 · 普通话全程服务 · 647-930-6688</p>
        <p class="page-last-updated page-last-updated--gradient">页面内容最后更新：{SITE_LAST_UPDATED_ZH}</p>
      </div>
    </div>

    <div class="main-wrap">
      <div
        class="blog-search"
        role="search"
        aria-label="博客文章搜索"
        data-search-json="/blog-search.json"
        data-list-home="/blog/"
      >
        <label class="sr-only" for="blog-search-input">搜索文章</label>
        <input
          id="blog-search-input"
          class="blog-search-input"
          type="search"
          placeholder="搜索关键词（例如：离婚、监护、婚前协议、抚养费）"
          autocomplete="off"
        />
        <button class="blog-search-clear" id="blog-search-clear" type="button" aria-label="清空搜索">清空</button>
      </div>
      <p class="blog-search-meta" id="blog-search-meta" aria-live="polite"></p>
      <div class="blog-search-results" id="blog-search-results" hidden></div>

      <nav class="pagination" aria-label="博客分页">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) =>
          num === currentPage ? (
            <span class="current" aria-current="page">{num}</span>
          ) : num === 1 ? (
            <a href="/blog/">{num}</a>
          ) : (
            <a href={`/blog/page/${num}/`}>{num}</a>
          )
        )}
      </nav>

      <div class="grid" id="post-grid">
        {pagePosts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="card"
            data-search={`${post.data.title} ${post.data.description} ${(post.data.tags ?? []).join(' ')}`.toLowerCase()}
          >
            <p class="card-date">{formatDate(post.data.pubDate)}</p>
            <p class="card-title">{post.data.title}</p>
            <p class="card-desc">{post.data.description}</p>
            <div class="card-footer">
              <span style="font-size:0.75rem;color:#9A8060;">何淼律师</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

      <div class="cta-box">
        <h2>预约初次法律咨询</h2>
        <p>何淼律师 · 30分钟初次咨询 $220+HST · 普通话 · Markham · 服务Ontario全省</p>
        <div class="cta-btns">
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="/contact" class="btn-outline">在线预约</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <script src="/js/blog-listing.js" defer></script>
</body>
</html>
