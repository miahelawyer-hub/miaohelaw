    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Brampton 宾顿的家庭法案件在哪个法院处理？",
          "acceptedAnswer": { "@type": "Answer", "text": "Brampton 案件在 Peel Region 的 Ontario Court of Justice 或 Superior Court of Justice（Brampton 法院大楼）处理。何淼律师熟悉 Peel 地区法院流程，可全程代理。" }
        },
        {
          "@type": "Question",
          "name": "Brampton 有很多南亚裔家庭，何淼律师也可以代理非华人客户吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "可以。何淼律师以英文为非华裔客户提供完整代理服务，并不限于华人社区。" }
        },
        {
          "@type": "Question",
          "name": "初次咨询需要准备什么材料？",
          "acceptedAnswer": { "@type": "Answer", "text": "建议准备：结婚证（如有）、资产清单（房产、账户、车辆）、收入证明、子女出生证明。无需全部齐备，何淼律师可根据现有信息提供初步法律意见。" }
