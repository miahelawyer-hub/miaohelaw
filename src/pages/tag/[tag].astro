---
/* ============================================
 * TAG INTRO MECHANISM（中文 blog /tag/[tag]）
 * ============================================
 * Intro 文件存放在：src/data/tag-intros/{slug}.md（slug 与 blog frontmatter tags 一致，英文 kebab-case）。
 *
 * 每个 intro 文件的 frontmatter 必须包含以下五个核心字段（中英通用模板）：
 *   title            吸引点击的页面标题（<title> / OG 等）
 *   h2               页面顶部专业导语（hero 副标题）
 *   description      搜索结果用的 meta 摘要
 *   schemaName       CollectionPage 等结构化数据的标题（更正式）
 *   schemaDescription 结构化数据的详细描述（更偏教义/底层信息）
 *
 * Tag 聚合页一律 noindex,follow（仍可被爬虫顺着链接抓取并传递权重；不向 SERP 收录）。
 * Intro + ≥5 篇时仍可渲染导语段落并附带 ItemList 结构化数据（便于站内语义）；rescued 仅保留这些内容层面的区分。
 *
 * 如果某 tag 没有对应 md 文件，tag 页会正常显示
 * （只是 H1 下方不出现 intro 段落）——不会报错。
 *
 * 写新文章后的 TAG CHECK 流程：
 *   1. 列出文章 tags
 *   2. 对比 src/data/tag-intros/ 现有文件
 *   3. 报告缺口；若某 tag 已达 5+ 篇，应补齐 intro 及五字段
 * ============================================ */

import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { isBlogPostRoutable } from '../../lib/blogPublished';
import { getTagDisplayNameZh } from '../../data/tagDisplayNames';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(isBlogPostRoutable);
  const tagMap = new Map();
  for (const post of posts) {
    const tags = post.data.tags || [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag).push(post);
    }
  }
  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { posts, tag },
  }));
}

// 动态加载 tag intro 文件（如果存在）
const tagIntroModules = import.meta.glob('../../data/tag-intros/*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

// 极简 frontmatter 解析器（不依赖外部包）
function parseTagIntro(raw) {
  if (!raw) return null;
  const match = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!match) return { frontmatter: {}, body: raw.trim() };
  const frontmatterText = match[1];
  const body = match[2].trim();
  const frontmatter = {};
  frontmatterText.split('\n').forEach((line) => {
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) return;
    const key = line.slice(0, colonIdx).trim();
    let value = line.slice(colonIdx + 1).trim();
    if (
      (value.startsWith('"') && value.endsWith('"')) ||
      (value.startsWith("'") && value.endsWith("'"))
    ) {
      value = value.slice(1, -1);
    }
    frontmatter[key] = value;
  });
  return { frontmatter, body };
}

// 将 intro body 中的 Markdown 链接和换行转成 HTML
function renderIntroBody(body) {
  if (!body) return '';
  return body
    // Markdown 链接 [text](url) -> <a href="url">text</a>
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    // 双换行 -> 段落分隔
    .split(/\n\n+/)
    .map((para) => `<p>${para.replace(/\n/g, '<br>')}</p>`)
    .join('');
}

const { tag, posts } = Astro.props;

// 查找当前 tag 是否有 intro 文件
let tagIntro = null;
const introKey = `../../data/tag-intros/${tag}.md`;
const rawContent = tagIntroModules[introKey];
if (rawContent) {
  tagIntro = parseTagIntro(rawContent);
}

// “rescued”：有 intro 且 ≥5 篇 — 用于导语区块与 ItemList；SEO 上与非 rescued 一致均为 noindex,follow。
const isRescuedTag = Boolean(tagIntro) && posts.length >= 5;

const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const canonical = `https://www.miaohelaw.ca/tag/${tag}/`;

const introFm = tagIntro?.frontmatter ?? {};
const displayLabel = introFm.displayName ?? getTagDisplayNameZh(tag);
const pageTitle =
  introFm.title ?? `${displayLabel} 专题 | 何淼律师 — Ontario家庭法律师`;
const pageH2 = introFm.h2 ?? null;
const pageDescription =
  introFm.description ??
  `何淼律师关于${displayLabel}的专业文章与法律资讯。Ontario家庭法，普通话全程服务，647-930-6688。`;
const schemaDescription =
  introFm.schemaDescription ??
  `何淼律师关于${displayLabel}的专业文章与法律资讯，涵盖Ontario家庭法实务。`;
const collectionPageName = displayLabel;

function formatDate(date) {
  return new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

const itemList =
  isRescuedTag
    ? {
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        itemListElement: sorted.map((post, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          url: new URL(`/blog/${post.id}/`, Astro.site).href,
          name: post.data.title,
        })),
      }
    : null;

const schema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: collectionPageName,
    description: schemaDescription,
    url: canonical,
    inLanguage: 'zh-Hans',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: 'https://www.miaohelaw.ca/' },
      { '@type': 'ListItem', position: 2, name: '标签', item: 'https://www.miaohelaw.ca/tag/' },
      { '@type': 'ListItem', position: 3, name: displayLabel, item: canonical },
    ],
  },
  ...(itemList ? [itemList] : []),
]);
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title={pageTitle}
    description={pageDescription}
  />
  <meta name="robots" content="noindex, follow" />
  <meta name="keywords" content={displayLabel + ",何淼律师,Miao He,Ontario家庭法,华人离婚律师,LSO 83315K"} />
  <meta property="og:title" content={displayLabel + " | 何淼律师"} />
  <meta property="og:type" content="website" />
  <script type="application/ld+json" set:html={schema}></script>
  <style>
    body{background:var(--bg);margin:0}
    .hero{background:var(--hero-legal-top-background);border-bottom:1px solid rgba(0,0,0,0.35);padding:2.5rem 1.5rem 2rem;text-align:center}
    .hero h1{color:#fff;font-size:clamp(1.3rem,3vw,1.8rem);margin:0 0 0.5rem}
    .hero h2{color:rgba(255,250,235,0.98);font-size:clamp(0.95rem,2.2vw,1.12rem);font-weight:500;margin:0 auto 0.85rem;line-height:1.55;max-width:52rem;padding:0 1rem;box-sizing:border-box;text-shadow:0 1px 3px rgba(0,0,0,0.45)}
    .hero p{color:#D4A853;margin:0;font-size:0.9rem}
    .container{max-width:800px;margin:0 auto;padding:2rem 1.5rem}
    .post-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1px;background:#e8e0d5;border:1px solid #e8e0d5;border-radius:12px;overflow:hidden}
    .post-item{background:white}
    .post-link{display:flex;align-items:center;gap:1.25rem;padding:1.25rem 1.5rem;text-decoration:none;transition:background 0.15s}
    .post-link:hover{background:var(--bg)}
    .post-num{font-size:0.75rem;color:#D4A853;font-weight:700;min-width:1.5rem;text-align:right;flex-shrink:0}
    .post-body{flex:1;min-width:0}
    .post-title{color: var(--text-heading);font-size:0.98rem;font-weight:600;line-height:1.45;margin:0 0 0.25rem}
    .post-date{color:#9A8060;font-size:0.78rem;margin:0}
    .post-arrow{color:#D4A853;font-size:0.9rem;flex-shrink:0}
    .cta-box{background:#1c2b3f;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:1.75rem;text-align:center;margin-top:2rem;box-shadow:0 14px 32px rgba(12,22,38,0.35)}
    .cta-box h2{color:#fac775;margin:0 0 0.5rem;font-size:1.1rem}
    .cta-box p{color:#d4cfc3;margin:0 0 1rem;font-size:0.9rem}
    .cta-btns{display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap}
    .btn-gold{background:#c9a168;color:#1c2b3f;padding:0.65rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:700;font-size:0.9rem;transition:filter 0.15s ease}
    .btn-gold:hover{filter:brightness(1.05)}
    .btn-outline{background:transparent;color:rgba(248,250,252,0.95);border:1px solid #c9a168;padding:0.65rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:700;font-size:0.9rem;transition:background 0.15s ease,border-color 0.15s ease}
    .btn-outline:hover{background:rgba(201,161,104,0.14);border-color:#d4b47e}
    .back-link{display:inline-block;color:#9A8060;font-size:0.82rem;text-decoration:none;margin-bottom:1.5rem}
    @media(max-width:600px){.post-link{padding:1rem 1.1rem;gap:0.9rem}.post-num{display:none}}
    /* hero 上须用浅色字以保证可读；链接保持金色 */
    .tag-intro {
      max-width: 760px;
      margin: 1.2em auto 1.5em;
      padding: 0 1em;
      text-align: left;
      line-height: 1.75;
      color: rgba(255, 250, 235, 0.94);
      font-size: 1rem;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
    }
    .tag-intro :global(p) {
      margin: 0 0 0.8em;
      color: inherit;
    }
    .tag-intro :global(p:last-child) {
      margin-bottom: 0;
    }
    .tag-intro :global(a) {
      color: #d4a853;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .tag-intro :global(a:hover) {
      color: #f0d592;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="hero">
      <h1>{displayLabel}</h1>
      {pageH2 && <h2>{pageH2}</h2>}
      {tagIntro && (
        <div class="tag-intro">
          <div set:html={renderIntroBody(tagIntro.body)}></div>
        </div>
      )}
      <p>何淼律师 · 普通话全程服务 · 647-930-6688</p>
    </div>
    <div class="container">
      <a href="/blog/" class="back-link">← 返回博客文章</a>
      <ul class="post-list">
        {sorted.map((post, i) => (
          <li class="post-item">
            <a href={`/blog/${post.id}/`} class="post-link">
              <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="post-body">
                <p class="post-title">{post.data.title}</p>
                <p class="post-date">{formatDate(post.data.pubDate)}</p>
              </div>
              <span class="post-arrow">›</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="cta-box">
        <h2>预约初次咨询</h2>
        <p>30分钟 · $220+HST · 普通话 · Markham · 服务Ontario全省</p>
        <div class="cta-btns">
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="/contact" class="btn-outline">在线预约</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
