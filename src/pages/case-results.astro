---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="案例结果 | Case Results — 何淼律师 | Miao He Family Law"
    description="何淼律师真实案件成果展示，包括跨境资产追回、离婚诉讼、子女监护、婚前协议等家庭法案件。Yang v. Li 2024 ONSC 4801，Li v. Jiang 2026 ONSC 561。"
  />
</head>
<body>
  <Header />
  <main class="page-main">

    <section class="page-hero">
      <div class="page-hero-inner">
        <div class="page-label">VERIFIED OUTCOMES · 真实案件成果</div>
        <h1>案例结果 · Case Results</h1>
        <p>以下案件成果均来自真实代理，CanLII 公开判决可供核实，匿名案件已获客户同意展示。</p>
      </div>
    </section>

    <section class="results-numbers">
      <div class="results-numbers-inner">
        <div class="result-stat">
          <div class="result-stat-number">$300,000+</div>
          <div class="result-stat-label">跨境资产追回<br/>Cross-Border Asset Recovery</div>
        </div>
        <div class="result-stat">
          <div class="result-stat-number">$500,000+</div>
          <div class="result-stat-label">协议效力维护<br/>Agreement Value Protected</div>
        </div>
        <div class="result-stat">
          <div class="result-stat-number">$400,000</div>
          <div class="result-stat-label">财务错误纠正节省<br/>Saved via Error Discovery</div>
        </div>
        <div class="result-stat">
          <div class="result-stat-number">$1M+</div>
          <div class="result-stat-label">调解达成和解<br/>Mediation Settlement</div>
        </div>
      </div>
    </section>

    <section class="cases-section">
      <div class="cases-inner">
        <h2>公开判决 · Verified Court Records</h2>

        <div class="case-card verified">
          <div class="case-tag">【离婚诉讼 · 动议】CanLII 已核实</div>
          <h3>Yang v. Li, 2024 ONSC 4801</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>对方同时提出八项主张，包含 CBV 业务估值争议</div>
            <div class="case-row"><span class="case-key">策略：</span>动议阶段全面防御，就对方缺乏坦诚申请费用</div>
            <div class="case-row"><span class="case-key">结果：</span>八项主张全部驳回，获重大费用裁定；上诉被三位法官一致驳回</div>
          </div>
          <a href="https://www.canlii.org/en/on/onscdc/doc/2024/2024onsc4801/2024onsc4801.html" target="_blank" class="case-verify">在 CanLII 核实 →</a>
        </div>

        <div class="case-card verified">
          <div class="case-tag">【子女探视 · 动议】CanLII 已核实</div>
          <h3>Li v. Jiang, 2026 ONSC 561</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>对方拖延探视安排长达19个月</div>
            <div class="case-row"><span class="case-key">策略：</span>申请无限制探视令，同时追讨诉讼费</div>
            <div class="case-row"><span class="case-key">结果：</span>取得 Unrestricted Access Order + $4,000 诉讼费裁定</div>
          </div>
          <a href="https://www.canlii.org/en/on/onsc/doc/2026/2026onsc561/2026onsc561.html" target="_blank" class="case-verify">在 CanLII 核实 →</a>
        </div>

        <h2 style="margin-top: 3rem;">匿名案件 · Anonymous Cases</h2>
        <p class="anonymous-note">以下案件已获客户同意展示，敏感信息已作匿名处理。</p>

        <div class="case-card">
          <div class="case-tag">【跨境资产】</div>
          <h3>中国房产及股权追回</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>对方将婚姻期间资产转移至中国境内，包括多处房产及公司股权</div>
            <div class="case-row"><span class="case-key">策略：</span>通过微信记录、税务申报及 CBV 配合完成跨境资产追查</div>
            <div class="case-row"><span class="case-key">结果：</span>成功追回 $300,000+ 资产</div>
          </div>
        </div>

        <div class="case-card">
          <div class="case-tag">【财产分割】</div>
          <h3>财务计算错误纠正</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>接手案件后发现对方 NFP 计算存在重大错误</div>
            <div class="case-row"><span class="case-key">策略：</span>逐项审查财务披露，识别错误并提出异议</div>
            <div class="case-row"><span class="case-key">结果：</span>为客户节省约 $400,000</div>
          </div>
        </div>

        <div class="case-card">
          <div class="case-tag">【协议效力】</div>
          <h3>婚前协议效力维护</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>对方起诉推翻婚前协议，涉及资产逾 $500,000</div>
            <div class="case-row"><span class="case-key">策略：</span>证明协议签署程序合规，双方均获独立法律建议</div>
            <div class="case-row"><span class="case-key">结果：</span>成功维护协议效力，守住 $500,000+ 资产</div>
          </div>
        </div>

        <div class="case-card">
          <div class="case-tag">【调解和解】</div>
          <h3>三年僵局庭外和解</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>接手已僵持三年的离婚案件，双方争议婚姻住房归属</div>
            <div class="case-row"><span class="case-key">策略：</span>转换策略，通过调解推动和解</div>
            <div class="case-row"><span class="case-key">结果：</span>数月内达成庭外和解，客户保住婚姻住房，和解金额逾 $1M</div>
          </div>
        </div>

        <div class="case-card">
          <div class="case-tag">【子女监护】</div>
          <h3>CAS 介入危机处理</h3>
          <div class="case-detail">
            <div class="case-row"><span class="case-key">案情：</span>CAS 介入，家长面临失去子女监护权风险</div>
            <div class="case-row"><span class="case-key">策略：</span>迅速介入，配合 CAS 要求同时保护家长权益</div>
            <div class="case-row"><span class="case-key">结果：</span>孩子成功留在父母身边</div>
          </div>
        </div>

      </div>
    </section>

    <section class="page-cta">
      <h2>有类似情况？欢迎咨询</h2>
      <p>每个案件都有其独特性。何淼律师提供初步咨询，帮助您了解自己的法律权利和案件走向。</p>
      <div class="cta-actions">
        <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
        <a href="mailto:miao@miaohelaw.ca" class="btn-secondary">miao@miaohelaw.ca</a>
      </div>
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
  .page-main { max-width: 100%; padding: 0; margin: 0; }
  .page-hero { background: #2C2418; padding: 4rem 2rem; text-align: center; }
  .page-hero-inner { max-width: 760px; margin: 0 auto; }
  .page-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 1rem; }
  .page-hero h1 { font-family: 'Georgia', serif; font-size: 2.5rem; font-weight: 400; color: #FAC775; margin-bottom: 1rem; }
  .page-hero p { color: #C4AA80; font-size: 0.95rem; line-height: 1.7; }
  .results-numbers { background: #F5EFE0; padding: 3rem 2rem; border-bottom: 1px solid #EDE8DF; }
  .results-numbers-inner { max-width: 960px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; text-align: center; }
  .result-stat-number { font-family: 'Georgia', serif; font-size: 2rem; color: #7A5A1A; margin-bottom: 0.5rem; }
  .result-stat-label { font-size: 0.8rem; color: #6B5A3A; line-height: 1.5; }
  .cases-section { padding: 4rem 2rem; }
  .cases-inner { max-width: 800px; margin: 0 auto; }
  .cases-inner h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 1.5rem; }
  .anonymous-note { font-size: 0.85rem; color: #9A8060; margin-bottom: 2rem; }
  .case-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 1.75rem; margin-bottom: 1.25rem; border-left: 4px solid #7A5A1A; }
  .case-card.verified { border-left-color: #FAC775; }
  .case-tag { font-size: 0.75rem; color: #7A5A1A; font-weight: 600; background: #F5EFE0; display: inline-block; padding: 3px 10px; border-radius: 4px; margin-bottom: 0.75rem; }
  .case-card.verified .case-tag { background: #2C2418; color: #FAC775; }
  .case-card h3 { font-family: 'Georgia', serif; font-size: 1.2rem; font-weight: 400; color: #1A1208; margin-bottom: 1rem; }
  .case-detail { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
  .case-row { font-size: 0.88rem; color: #4A3A2A; line-height: 1.6; }
  .case-key { font-weight: 600; color: #1A1208; }
  .case-verify { font-size: 0.8rem; color: #7A5A1A; text-decoration: none; font-weight: 500; }
  .case-verify:hover { text-decoration: underline; }
  .page-cta { background: #F5EFE0; border-top: 1px solid #EDE8DF; padding: 4rem 2rem; text-align: center; }
  .page-cta h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .page-cta p { color: #6B5A3A; font-size: 0.9rem; max-width: 540px; margin: 0 auto 1.5rem; line-height: 1.7; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: #7A5A1A; color: #FDFBF7; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  .btn-primary:hover { background: #4A3A0A; color: #FDFBF7; }
  .btn-secondary { background: transparent; color: #7A5A1A; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; border: 1px solid #7A5A1A; }
  .btn-secondary:hover { background: #F5EFE0; }
  @media (max-width: 720px) {
    .results-numbers-inner { grid-template-columns: repeat(2, 1fr); }
    .page-hero h1 { font-size: 1.75rem; }
  }
</style>