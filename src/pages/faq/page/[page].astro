---
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_LAST_UPDATED_ZH, SITE_URL } from '../../../consts';
import { getFaqItemsForListing } from '../../../data/faq';
import { getFaqItemsEnForListing } from '../../../data/faq-en';
import { stripHtml } from '../../../utils/stripHtml';

export const getStaticPaths = (async () => {
	const all = getFaqItemsForListing();
	const enAll = getFaqItemsEnForListing();
	const n = all.length;
	const totalPages = Math.max(1, Math.ceil(n / 10));
	const enTotalPages = Math.max(1, Math.ceil(enAll.length / 10));
	const paths: {
		params: { page: string };
		props: {
			currentPage: number;
			pageItems: ReturnType<typeof getFaqItemsForListing>;
			totalPages: number;
			totalFaq: number;
			enTotalPages: number;
		};
	}[] = [];
	for (let p = 2; p <= totalPages; p++) {
		paths.push({
			params: { page: String(p) },
			props: {
				currentPage: p,
				pageItems: all.slice((p - 1) * 10, p * 10),
				totalPages,
				totalFaq: n,
				enTotalPages,
			},
		});
	}
	return paths;
}) satisfies GetStaticPaths;

const { currentPage, pageItems, totalPages, totalFaq, enTotalPages } = Astro.props;

const canonicalUrl = `${SITE_URL}/faq/page/${currentPage}/`;
const prevUrl = currentPage === 2 ? `${SITE_URL}/faq/` : `${SITE_URL}/faq/page/${currentPage - 1}/`;
const nextUrl = currentPage < totalPages ? `${SITE_URL}/faq/page/${currentPage + 1}/` : null;

const emitHreflang = currentPage <= enTotalPages;

const itemListJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: pageItems.map((item, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: `${SITE_URL}/faq/${item.slug}/`,
		name: stripHtml(item.question),
	})),
};

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '首页', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: '常见问题', item: `${SITE_URL}/faq/` },
		{ '@type': 'ListItem', position: 3, name: `第${currentPage}页`, item: canonicalUrl },
	],
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title={`离婚常见问题解答 · 第${currentPage}页 | 多伦多华人离婚律师 何淼律师`}
    description={`何淼律师解答多伦多华人离婚常见法律问题（第${currentPage}页，共 ${totalFaq} 题）：离婚条件、财产分割、子女监护、抚养费、婚前协议等。647-930-6688。`}
  />
  <meta name="keywords" content="多伦多离婚费用,多伦多离婚常见问题,华人离婚FAQ,安省离婚条件,何淼律师" />
  <meta property="og:title" content={`离婚常见问题解答 · 第${currentPage}页 | 何淼律师`} />
  <meta property="og:description" content={`华人离婚常见问题解答第${currentPage}页，共 ${totalFaq} 题。`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content="https://www.miaohelaw.ca/og-image.jpg" />
  <link rel="prev" href={prevUrl} />
  {nextUrl && <link rel="next" href={nextUrl} />}
  {emitHreflang && (
    <>
      <link rel="alternate" hreflang="zh" href={canonicalUrl} />
      <link rel="alternate" hreflang="en" href={`${SITE_URL}/en/faq/page/${currentPage}/`} />
      <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/en/faq/page/${currentPage}/`} />
    </>
  )}
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
</head>
<body>
  <Header />
  <main class="faq-listing-root" id="faq-listing-root">
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">首页</a> › <a href="/faq/">常见问题</a> › 第 {currentPage} 页</div>
        <h1>常见问题</h1>
        <p class="hero-stat">共 {totalFaq} 个常见问题解答 · 第 {currentPage} / {totalPages} 页</p>
        <p class="hero-sub">点击下方问题了解详情 · 普通话全程服务 · 647-930-6688</p>
        <p class="page-last-updated page-last-updated--gradient">页面内容最后更新：{SITE_LAST_UPDATED_ZH}</p>
      </div>
    </section>
    <section class="faq-section">
      <div class="container">
        <div
          class="faq-search"
          role="search"
          aria-label="常见问题搜索"
          data-search-json="/faq-search.json"
          data-list-home="/faq/"
        >
          <label class="sr-only" for="faq-search-input">搜索问题</label>
          <input
            id="faq-search-input"
            class="faq-search-input"
            type="search"
            placeholder="搜索关键词（例如：抚养费、婚房、首付、家暴）"
            autocomplete="off"
          />
          <button class="faq-search-clear" id="faq-search-clear" type="button" aria-label="清空搜索">清空</button>
        </div>
        <p class="faq-search-meta" id="faq-search-meta" aria-live="polite"></p>
        <div class="faq-search-results" id="faq-search-results" hidden></div>

        <nav class="faq-pagination" aria-label="常见问题分页">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) =>
            num === currentPage ? (
              <span class="current" aria-current="page">{num}</span>
            ) : num === 1 ? (
              <a href="/faq/">{num}</a>
            ) : (
              <a href={`/faq/page/${num}/`}>{num}</a>
            )
          )}
        </nav>

        {pageItems.map((item) => (
          <div
            class="faq-item"
            data-search={`${stripHtml(item.question)} ${stripHtml(item.capsule)} ${stripHtml(item.summary)} ${item.answers.map(stripHtml).join(' ')} ${item.keywords}`.toLowerCase()}
          >
            <a href={`/faq/${item.slug}/`} class="faq-link">
              <span set:html={item.question} />
              <span class="faq-arrow">→</span>
            </a>
          </div>
        ))}
        <div class="contact-card">
          <div class="contact-info">
            <h2>还有其他问题？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: var(--bg);
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  a { color: inherit; text-decoration: none; }

  .page-hero{
    position: relative;
    background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0, 0, 0, 0.35);
    color:white;
    padding: 3.25rem 0 2.25rem;
    overflow: hidden;
  }
  .page-hero h1{
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    margin: 0.55rem 0 0.35rem;
    color:#ffffff;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .hero-stat{
    color:#F5E6C8;
    margin:0 0 0.45rem;
    font-size:0.96rem;
    font-weight:600;
    letter-spacing:0.02em;
  }
  .hero-sub{
    color:#E8C47A;
    margin:0;
    opacity: 0.95;
  }
  .breadcrumb{
    font-size:0.85rem;
    opacity:0.75;
    margin-bottom:0.5rem;
  }
  .breadcrumb a{color:white;text-decoration:none}
  .breadcrumb a:hover{opacity:0.95;text-decoration:underline}
  .container{max-width:860px;margin:0 auto;padding:0 1.5rem}

  .faq-section { padding: 3rem 0 4rem; }
  .sr-only{
    position:absolute;
    width:1px;
    height:1px;
    padding:0;
    margin:-1px;
    overflow:hidden;
    clip:rect(0,0,0,0);
    white-space:nowrap;
    border:0;
  }
  .faq-search{
    display:flex;
    gap:0.75rem;
    align-items:center;
    margin: 0 0 1.25rem;
    padding: 0.75rem;
    border-radius: 14px;
    background: rgba(255,255,255,0.75);
    border: 1px solid rgba(237,232,223,0.95);
    box-shadow: 0 1px 0 rgba(44,24,16,0.02);
  }
  .faq-search-input{
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(212,168,83,0.28);
    background: #fff;
    color: var(--text-heading);
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    font-size: 1rem;
    line-height: 1.2;
    outline: none;
  }
  .faq-search-input:focus{
    border-color: rgba(212,168,83,0.6);
    box-shadow: 0 0 0 4px rgba(212,168,83,0.18);
  }
  .faq-search-clear{
    flex: none;
    border: 1px solid rgba(154,128,96,0.35);
    background: transparent;
    color: #6B5A3A;
    padding: 0.75rem 0.9rem;
    border-radius: 12px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .faq-search-clear:hover{
    background: rgba(212,168,83,0.14);
    border-color: rgba(212,168,83,0.45);
    color: var(--text-heading);
  }
  .faq-search-meta{
    margin: -0.35rem 0 1.25rem;
    color: rgba(44,24,16,0.72);
    font-size: 0.92rem;
  }
  .faq-search-results { margin: 0 0 1.25rem; }
  .faq-search-results ul { list-style: none; margin: 0; padding: 0; }
  .faq-search-results li { margin: 0 0 0.5rem; }
  .faq-search-results a {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.05rem 1.1rem; gap: 1rem; font-size: 1.02rem; line-height: 1.65;
    border-radius: 12px; background: rgba(255,255,255,0.65);
    border: 1px solid rgba(237,232,223,0.9); color: var(--text-primary); text-decoration: none;
  }
  .faq-search-results a:hover { border-color: rgba(212,168,83,0.35); color: #6B4A12; }
  .faq-pagination {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem 0.65rem;
    margin: 0 0 1.25rem; font-size: 0.88rem;
  }
  .faq-pagination a, .faq-pagination span.current {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 2.25rem; padding: 0.45rem 0.55rem; border-radius: 8px;
    text-decoration: none; border: 1px solid rgba(44,24,16,0.12);
    color: #4A2C1A; background: rgba(255,255,255,0.85);
  }
  .faq-pagination a:hover { border-color: rgba(212,168,83,0.55); }
  .faq-pagination span.current { font-weight: 700; border-color: rgba(212,168,83,0.55); background: rgba(212,168,83,0.12); }
  .faq-listing--searching .faq-item { display: none !important; }
  .faq-item { padding: 0.55rem 0; }
  .faq-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.05rem 1.1rem;
    gap: 1rem;
    font-size: 1.02rem;
    color: var(--text-primary);
    line-height: 1.65;
    border-radius: 12px;
    background: rgba(255,255,255,0.65);
    border: 1px solid rgba(237,232,223,0.9);
    box-shadow: 0 1px 0 rgba(44,24,16,0.02);
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
  }
  .faq-link:hover {
    background: #fff;
    border-color: rgba(212,168,83,0.35);
    color: #6B4A12;
    transform: translateY(-1px);
  }
  .faq-link:active { transform: translateY(0px); }
  .faq-link:hover .faq-arrow { color: #D4A853; }
  .faq-link span em { font-style: italic; }
  .faq-arrow { font-size: 1.05rem; color: #9A8060; flex-shrink: 0; }

  .faq-filter-hidden { display: none; }

  .contact-card{background:linear-gradient(135deg,#2C1810,#4A2C1A);border-radius:12px;padding:2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-top:3rem}
  .contact-info h2{color:#D4A853;margin:0 0 0.5rem;font-size:1.2rem;font-weight:400}
  .contact-info p{color:#ffffff;margin:0;font-size:0.95rem;opacity:0.88}
  .contact-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
  .btn-primary{display:inline-block;background:#D4A853;color: var(--text-heading);padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}
  .btn-secondary{display:inline-block;background:transparent;color:white;border:2px solid white;padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}

  @media(max-width:768px){
    .page-hero h1{font-size:1.5rem}
    .contact-card{flex-direction:column}
  }
  @media (max-width: 520px) {
    .faq-section { padding: 2.25rem 0 3.5rem; }
    .faq-item { padding: 0.45rem 0; }
    .faq-link { padding: 0.95rem 0.9rem; font-size: 1rem; }
    .faq-search{ padding: 0.65rem; gap: 0.6rem; }
    .faq-search-input{ padding: 0.8rem 0.85rem; }
    .faq-search-clear{ padding: 0.72rem 0.82rem; }
  }
</style>

<script src="/js/faq-listing.js" defer></script>
