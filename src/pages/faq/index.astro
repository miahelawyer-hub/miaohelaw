---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { faqItems } from '../../data/faq';
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="离婚常见问题解答 | 多伦多华人离婚律师 何淼律师"
    description="何淼律师解答53个多伦多华人离婚最常见法律问题：离婚条件、财产分割、子女监护、抚养费、婚前协议、跨境资产等。普通话全程服务，647-930-6688。"
  />
  <meta name="keywords" content="多伦多离婚常见问题,华人离婚FAQ,安省离婚条件,子女监护权加拿大,婚前协议安省,跨境资产离婚,离婚律师费用,何淼律师,多伦多华人律师" />
  <meta property="og:title" content="离婚常见问题解答 | 多伦多华人离婚律师 何淼律师" />
  <meta property="og:description" content="何淼律师解答53个多伦多华人离婚最常见法律问题。普通话全程服务，647-930-6688。" />
  <meta property="og:url" content="https://www.miaohelaw.ca/faq" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://www.miaohelaw.ca/og-image.jpg" />
  <link rel="canonical" href="https://www.miaohelaw.ca/faq" />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"在加拿大安省离婚需要什么条件？","acceptedAnswer":{"@type":"Answer","text":"离婚有三种情形：双方分居超过一年、任何一方有婚外情、或存在家暴。绝大多数案件走的是分居满一年这条路。分居满一年是法院发出离婚证的条件，不是递交申请的条件，分居后任何时间都可以递交申请。"}},
      {"@type":"Question","name":"新移民在加拿大安省可以离婚吗？","acceptedAnswer":{"@type":"Answer","text":"可以。安省处理离婚不看移民身份，只要有任何一方在安省居住满一年以上，安省法庭都会审理离婚案件。无论是PR、工签还是其他身份，只要满足居住时间要求，都可以在安省提起离婚。"}},
      {"@type":"Question","name":"对方不配合离婚怎么办？","acceptedAnswer":{"@type":"Answer","text":"对方不配合，可以直接提起诉讼，法院不需要对方同意就可以推进案件。分居满一年后，即便对方拒绝配合，法院可以在对方缺席的情况下作出判决（Default Judgment）。"}},
      {"@type":"Question","name":"离婚时房子一定要平分吗？","acceptedAnswer":{"@type":"Answer","text":"不一定。安省实行家庭净资产均等分割原则（Equalization of Net Family Property），房子是净资产计算的一部分，不是单独平分。婚房的全部价值计入计算，但最终分配取决于双方净资产的差额。"}},
      {"@type":"Question","name":"子女抚养费和配偶赡养费怎么计算？","acceptedAnswer":{"@type":"Answer","text":"子女抚养费（Child Support）按联邦Child Support Guidelines强制计算，根据支付方收入和子女人数确定，双方不能约定低于标准。配偶赡养费（Spousal Support）有参考指引，但法院有更大裁量空间，不是每个案件都需要支付。"}},
      {"@type":"Question","name":"婚前协议在安省有法律效力吗？","acceptedAnswer":{"@type":"Answer","text":"有效，但必须满足严格条件：双方自愿签署、各自获得独立法律意见（ILA）、完整披露财产状况、协议内容公平合理。私下达成的婚前协议可能被法院认定无效。"}},
      {"@type":"Question","name":"离婚时有中国房产或跨境资产怎么处理？","acceptedAnswer":{"@type":"Answer","text":"在安省，婚姻财产均等分割原则适用于全球资产，包括中国房产、境外账户、海外投资。跨境资产追查和判决执行涉及两国法律，建议在启动离婚程序前咨询持中加双重执照的律师制定完整策略。"}},
      {"@type":"Question","name":"对方要带孩子回中国怎么办？","acceptedAnswer":{"@type":"Answer","text":"这是极度紧急的情况，请立即联系律师。中国不是海牙公约成员国，孩子一旦离境追回极难。安省法院可以发出Non-Removal Order禁止带孩子出境，必须在孩子离境前采取行动。"}},
      {"@type":"Question","name":"在安省离婚需要多久？","acceptedAnswer":{"@type":"Answer","text":"无争议离婚通常需要4至8个月；有争议的诉讼离婚视复杂程度，可能需要1至3年甚至更长。"}},
      {"@type":"Question","name":"在安省离婚律师费大概多少钱？","acceptedAnswer":{"@type":"Answer","text":"无争议离婚套餐价格通常在$2,000至$5,000之间。有争议的诉讼离婚按小时收费，案件复杂持续时间长的情况下，一年律师费可能在$5万至$8万加币。初次咨询30分钟$220+HST。"}},
      {"@type":"Question","name":"父母给我们买房出了首付，离婚时这笔钱能拿回来吗？","acceptedAnswer":{"@type":"Answer","text":"不一定。要看这套房子是婚房还是投资房，同时要看当时父母的钱打入谁的账户，以及父母与你们当时的沟通记录能否证明这笔钱是赠与还是借款。没有固定答案，每个案件情况不同，建议带上所有相关记录咨询律师。"}},
      {"@type":"Question","name":"对方名下有RRSP，离婚时我能分到吗？","acceptedAnswer":{"@type":"Answer","text":"婚姻期间增长的部分可以分。安省净资产计算是分居日资产减去结婚日资产，RRSP在婚姻期间的增长属于家庭净资产，通过Equalization Payment结算给另一方。如果双方同意用RRSP本身支付，可申请RRSP Direct Transfer，不计入当年应税收入。"}},
      {"@type":"Question","name":"离婚了孩子说想跟爸爸住，法官会听孩子的意见吗？","acceptedAnswer":{"@type":"Answer","text":"法院会听取但不由孩子做主。六七岁以下孩子的意见权重较低。法院优先看婚姻期间及分居后谁是主要照顾者，孩子意见只是众多考量因素之一，核心标准是子女最大利益。"}},
      {"@type":"Question","name":"离婚之后我想带孩子搬去温哥华，对方不同意，我能搬吗？","acceptedAnswer":{"@type":"Answer","text":"不能直接搬。需要走relocation程序，提前60天给对方正式通知，对方有30天回复。如果双方无法达成一致，须上庭由法院裁决，拿到法院命令才能带孩子搬离。"}},
      {"@type":"Question","name":"对方婚后欠了很多信用卡债，离婚之后这些债我也要还吗？","acceptedAnswer":{"@type":"Answer","text":"要看债务性质。用于家庭共同生活的债务有连带义务；对方个人名下、你完全没有受益的债务，债权人通常无法向你追索。法院会看这笔钱最终用在了哪里，有没有用于家庭生活。"}},
      {"@type":"Question","name":"结婚10年一直在家带孩子没有工作，离婚之后我能拿到赡养费吗？","acceptedAnswer":{"@type":"Answer","text":"很可能可以。配偶赡养费参考联邦指引，金额和时长取决于双方收入差距、婚姻年限、以及一方因照顾家庭牺牲职业发展的程度。结婚10年全职照顾孩子，这些因素基本都指向有权主张赡养费。"}},
      {"@type":"Question","name":"我有工签，对方是PR，现在要离婚，我的身份会不会有问题？","acceptedAnswer":{"@type":"Answer","text":"已有的工签通常不受影响。但如果正在依靠对方担保申请PR，分居后婚姻状态改变，对方很可能无法继续作为担保申请人，PR申请会受到影响，建议同时咨询移民律师。"}},
      {"@type":"Question","name":"分居协议签完之后，对方反悔了不执行怎么办？","acceptedAnswer":{"@type":"Answer","text":"分居协议是有法律约束力的合同，可以向法院申请执行令强制对方执行。对方在法院命令下仍拒不执行，可能面临藐视法庭处罚，包括罚款甚至监禁。"}},
      {"@type":"Question","name":"对方在中国有养老金和社保，分居的时候在加拿大能不能分？","acceptedAnswer":{"@type":"Answer","text":"可以纳入计算。安省净资产计算覆盖全球资产，对方须披露中国养老金和社保的现金价值，婚姻期间增长的部分计入家庭净资产参与分配。"}},
      {"@type":"Question","name":"离婚证书拿到之后，我什么时候可以再婚？","acceptedAnswer":{"@type":"Answer","text":"拿到离婚证书（Certificate of Divorce）后任何时候都可以再婚。注意区分：法院先颁发离婚令，31天后才能申请离婚证书，拿到证书才是法律上婚姻正式解除，之后可以立即安排再婚。"}}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"首页","item":"https://www.miaohelaw.ca/"},
      {"@type":"ListItem","position":2,"name":"常见问题","item":"https://www.miaohelaw.ca/faq"}
    ]
  }</script>
</head>
<body>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">首页</a> › 常见问题</div>
        <h1>常见问题</h1>
        <p class="hero-sub">点击下方问题了解详情 · 普通话全程服务 · 647-930-6688</p>
      </div>
    </section>
    <section class="faq-index-section">
      <div class="container">
        <div class="capsules" id="capsulesBox">
          {faqItems.map((item, i) => (
            <a href={"/faq/" + item.slug} class={`capsule${i >= 15 ? ' hidden-cap' : ''}`}>
              {item.capsule}
            </a>
          ))}
        </div>
        <div class="show-more-wrap" id="showMoreWrap">
          <button class="show-more-btn" id="showMoreBtn">展开全部 53 个问题 ↓</button>
        </div>
        <div class="contact-card">
          <div class="contact-info">
            <h2>还有其他问题？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  .page-hero{background:linear-gradient(135deg,#2C1810 0%,#4A2C1A 100%);color:white;padding:3rem 0 2rem}
  .page-hero h1{font-size:2rem;margin:0.5rem 0;color:#ffffff}
  .hero-sub{color:#D4A853;margin:0}
  .breadcrumb{font-size:0.85rem;opacity:0.7;margin-bottom:0.5rem}
  .breadcrumb a{color:white;text-decoration:none}
  .container{max-width:1000px;margin:0 auto;padding:0 1.5rem}
  .faq-index-section{padding:3rem 0}
  .capsules{display:flex;flex-wrap:wrap;gap:1rem 1.25rem;margin-bottom:3rem}
  .capsule{background:#f5f0eb;border:1.5px solid #e0d5c8;color:#4A2C1A;padding:0.65rem 1.4rem;border-radius:999px;font-size:0.95rem;text-decoration:none;transition:all 0.2s;line-height:1.5}
  .capsule:hover{background:#2C1810;border-color:#2C1810;color:#ffffff}
  @media(max-width:768px){.capsules{flex-direction:column;gap:0.6rem}.capsule{width:100%;text-align:center;padding:0.8rem 1.2rem;font-size:1rem}}
  .contact-card{background:linear-gradient(135deg,#2C1810,#4A2C1A);border-radius:12px;padding:2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
  .contact-info h2{color:#D4A853;margin:0 0 0.5rem;font-size:1.2rem}
  .contact-info p{color:#ffffff;margin:0;font-size:0.95rem}
  .contact-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
  .btn-primary{display:inline-block;background:#D4A853;color:#2C1810;padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}
  .btn-secondary{display:inline-block;background:transparent;color:white;border:2px solid white;padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}
  .hidden-cap{display:none}
  .show-more-wrap{text-align:center;margin:0.5rem 0 2rem}
  .show-more-btn{background:transparent;border:1.5px solid #9A8060;color:#9A8060;padding:0.6rem 1.8rem;border-radius:999px;font-size:0.9rem;cursor:pointer;transition:all 0.2s;font-family:inherit}
  .show-more-btn:hover{background:#9A8060;color:white}
  @media(max-width:768px){.page-hero h1{font-size:1.5rem}.contact-card{flex-direction:column}.capsules{flex-direction:column;gap:0.5rem}.capsule{width:100%;text-align:center;box-sizing:border-box}}
</style>

<script>
  const btn = document.getElementById('showMoreBtn');
  const wrap = document.getElementById('showMoreWrap');
  btn?.addEventListener('click', () => {
    document.querySelectorAll('.hidden-cap').forEach(el => el.classList.remove('hidden-cap'));
    wrap.style.display = 'none';
  });
</script>
