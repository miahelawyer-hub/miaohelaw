---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getFaqItemsForListing } from '../../data/faq';

const faqListing = getFaqItemsForListing();
const totalFaq = faqListing.length;
const faqPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqListing.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.summary,
    },
  })),
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="离婚常见问题解答 | 多伦多华人离婚律师 何淼律师"
    description={`何淼律师解答${totalFaq}个多伦多华人离婚最常见法律问题：离婚条件、财产分割、子女监护、抚养费、婚前协议、跨境资产等。普通话全程服务，647-930-6688。`}
  />
  <meta name="keywords" content="多伦多离婚常见问题,华人离婚FAQ,安省离婚条件,子女监护权加拿大,婚前协议安省,跨境资产离婚,离婚律师费用,何淼律师,多伦多华人律师" />
  <meta property="og:title" content="离婚常见问题解答 | 多伦多华人离婚律师 何淼律师" />
  <meta property="og:description" content={`何淼律师解答${totalFaq}个多伦多华人离婚最常见法律问题。普通话全程服务，647-930-6688。`} />
  <meta property="og:url" content="https://www.miaohelaw.ca/faq" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://www.miaohelaw.ca/og-image.jpg" />
  <link rel="canonical" href="https://www.miaohelaw.ca/faq" />
  <script type="application/ld+json" set:html={JSON.stringify(faqPageJsonLd)} />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"首页","item":"https://www.miaohelaw.ca/"},
      {"@type":"ListItem","position":2,"name":"常见问题","item":"https://www.miaohelaw.ca/faq"}
    ]
  }</script>
</head>
<body>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">首页</a> › 常见问题</div>
        <h1>常见问题</h1>
        <p class="hero-sub">点击下方问题了解详情 · 普通话全程服务 · 647-930-6688</p>
      </div>
    </section>
    <section class="faq-section">
      <div class="container">
        <div class="faq-search" role="search" aria-label="常见问题搜索">
          <label class="sr-only" for="faq-search-input">搜索问题</label>
          <input
            id="faq-search-input"
            class="faq-search-input"
            type="search"
            placeholder="搜索关键词（例如：抚养费、婚房、首付、家暴）"
            autocomplete="off"
          />
          <button class="faq-search-clear" id="faq-search-clear" type="button" aria-label="清空搜索">清空</button>
        </div>
        <p class="faq-search-meta" id="faq-search-meta" aria-live="polite"></p>

        {faqListing.map((item, i) => (
          <div
            class={`faq-item${i >= 10 ? ' faq-hidden' : ''}`}
            data-search={`${item.question} ${item.capsule} ${item.summary} ${item.keywords}`.toLowerCase()}
          >
            <a href={`/faq/${item.slug}`} class="faq-link">
              <span>{item.question}</span>
              <span class="faq-arrow">→</span>
            </a>
          </div>
        ))}
        {totalFaq > 10 && (
          <div class="load-more-wrap">
            <button class="load-more-btn" id="faq-load-more">加载更多问题 ↓</button>
          </div>
        )}
        <div class="contact-card">
          <div class="contact-info">
            <h2>还有其他问题？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: #faf8f5;
    color: #2C1810;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  a { color: inherit; text-decoration: none; }

  .page-hero{
    position: relative;
    background: linear-gradient(135deg,#2C1810 0%,#4A2C1A 100%);
    color:white;
    padding: 3.25rem 0 2.25rem;
    overflow: hidden;
  }
  .page-hero::after{
    content:"";
    position:absolute;
    inset:-40% -20% auto auto;
    width:520px;
    height:520px;
    background: radial-gradient(circle at 30% 30%, rgba(212,168,83,0.28), rgba(212,168,83,0) 60%);
    transform: rotate(18deg);
    pointer-events:none;
  }
  .page-hero h1{
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    margin: 0.55rem 0 0.35rem;
    color:#ffffff;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .hero-sub{
    color:#E8C47A;
    margin:0;
    opacity: 0.95;
  }
  .breadcrumb{
    font-size:0.85rem;
    opacity:0.75;
    margin-bottom:0.5rem;
  }
  .breadcrumb a{color:white;text-decoration:none}
  .breadcrumb a:hover{opacity:0.95;text-decoration:underline}
  .container{max-width:860px;margin:0 auto;padding:0 1.5rem}

  .faq-section { padding: 3rem 0 4rem; }
  .sr-only{
    position:absolute;
    width:1px;
    height:1px;
    padding:0;
    margin:-1px;
    overflow:hidden;
    clip:rect(0,0,0,0);
    white-space:nowrap;
    border:0;
  }
  .faq-search{
    display:flex;
    gap:0.75rem;
    align-items:center;
    margin: 0 0 1.25rem;
    padding: 0.75rem;
    border-radius: 14px;
    background: rgba(255,255,255,0.75);
    border: 1px solid rgba(237,232,223,0.95);
    box-shadow: 0 1px 0 rgba(44,24,16,0.02);
  }
  .faq-search-input{
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(212,168,83,0.28);
    background: #fff;
    color: #2C1810;
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    font-size: 1rem;
    line-height: 1.2;
    outline: none;
  }
  .faq-search-input:focus{
    border-color: rgba(212,168,83,0.6);
    box-shadow: 0 0 0 4px rgba(212,168,83,0.18);
  }
  .faq-search-clear{
    flex: none;
    border: 1px solid rgba(154,128,96,0.35);
    background: transparent;
    color: #6B5A3A;
    padding: 0.75rem 0.9rem;
    border-radius: 12px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .faq-search-clear:hover{
    background: rgba(212,168,83,0.14);
    border-color: rgba(212,168,83,0.45);
    color: #2C1810;
  }
  .faq-search-meta{
    margin: -0.35rem 0 1.25rem;
    color: rgba(44,24,16,0.72);
    font-size: 0.92rem;
  }
  .faq-item { padding: 0.55rem 0; }
  .faq-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.05rem 1.1rem;
    gap: 1rem;
    font-size: 1.02rem;
    color: #1A1208;
    line-height: 1.65;
    border-radius: 12px;
    background: rgba(255,255,255,0.65);
    border: 1px solid rgba(237,232,223,0.9);
    box-shadow: 0 1px 0 rgba(44,24,16,0.02);
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
  }
  .faq-link:hover {
    background: #fff;
    border-color: rgba(212,168,83,0.35);
    color: #6B4A12;
    transform: translateY(-1px);
  }
  .faq-link:active { transform: translateY(0px); }
  .faq-link:hover .faq-arrow { color: #D4A853; }
  .faq-arrow { font-size: 1.05rem; color: #9A8060; flex-shrink: 0; }

  .faq-hidden { display: none; }
  .faq-filter-hidden { display: none; }
  .load-more-wrap { text-align: center; margin: 1.5rem 0 0; }
  .load-more-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: white; border: 2px solid #D4A853; color: #2C1810;
    padding: 0.7rem 1.8rem; border-radius: 8px; font-size: 0.92rem;
    font-weight: 600; cursor: pointer; font-family: Georgia, serif;
    transition: background 0.15s, color 0.15s;
  }
  .load-more-btn:hover { background: #D4A853; color: white; }

  .contact-card{background:linear-gradient(135deg,#2C1810,#4A2C1A);border-radius:12px;padding:2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-top:3rem}
  .contact-info h2{color:#D4A853;margin:0 0 0.5rem;font-size:1.2rem;font-weight:400}
  .contact-info p{color:#ffffff;margin:0;font-size:0.95rem;opacity:0.88}
  .contact-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
  .btn-primary{display:inline-block;background:#D4A853;color:#2C1810;padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}
  .btn-secondary{display:inline-block;background:transparent;color:white;border:2px solid white;padding:0.7rem 1.4rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem}

  @media(max-width:768px){
    .page-hero h1{font-size:1.5rem}
    .contact-card{flex-direction:column}
  }
  @media (max-width: 520px) {
    .faq-section { padding: 2.25rem 0 3.5rem; }
    .faq-item { padding: 0.45rem 0; }
    .faq-link { padding: 0.95rem 0.9rem; font-size: 1rem; }
    .faq-search{ padding: 0.65rem; gap: 0.6rem; }
    .faq-search-input{ padding: 0.8rem 0.85rem; }
    .faq-search-clear{ padding: 0.72rem 0.82rem; }
  }
</style>

<script>
  const loadMoreBtn = document.getElementById('faq-load-more');
  const searchInput = document.getElementById('faq-search-input');
  const clearBtn = document.getElementById('faq-search-clear');
  const meta = document.getElementById('faq-search-meta');

  const items = Array.from(document.querySelectorAll('.faq-item'));
  const pageSize = 10;

  const getLoadMoreWrap = () => loadMoreBtn?.closest('.load-more-wrap');
  const setLoadMoreVisible = (visible) => {
    const wrap = getLoadMoreWrap();
    if (wrap) wrap.style.display = visible ? '' : 'none';
    if (loadMoreBtn) loadMoreBtn.style.display = visible ? '' : 'none';
  };

  const applyPagination = () => {
    items.forEach((el, idx) => {
      if (idx < pageSize) el.classList.remove('faq-hidden');
      else el.classList.add('faq-hidden');
    });
    const remaining = items.filter(el => el.classList.contains('faq-hidden') && !el.classList.contains('faq-filter-hidden')).length;
    setLoadMoreVisible(remaining > 0);
  };

  const filterItems = (rawQuery) => {
    const q = (rawQuery || '').trim().toLowerCase();
    if (!q) {
      items.forEach(el => el.classList.remove('faq-filter-hidden'));
      if (meta) meta.textContent = '';
      applyPagination();
      return;
    }

    let matches = 0;
    items.forEach(el => {
      const hay = el.getAttribute('data-search') || '';
      const ok = hay.includes(q);
      el.classList.toggle('faq-filter-hidden', !ok);
      el.classList.remove('faq-hidden');
      if (ok) matches += 1;
    });
    setLoadMoreVisible(false);
    if (meta) meta.textContent = `已找到 ${matches} 个相关问题`;
  };

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', () => {
      const hidden = items.filter(el => el.classList.contains('faq-hidden') && !el.classList.contains('faq-filter-hidden'));
      hidden.slice(0, pageSize).forEach(el => el.classList.remove('faq-hidden'));
      const remaining = items.filter(el => el.classList.contains('faq-hidden') && !el.classList.contains('faq-filter-hidden')).length;
      if (remaining === 0) setLoadMoreVisible(false);
    });
  }

  if (searchInput) {
    searchInput.addEventListener('input', (e) => filterItems(e.target.value));
  }
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      filterItems('');
      searchInput?.focus();
    });
  }

  // Initialize state
  applyPagination();
</script>
