    .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e8e0d5; border: 1px solid #e8e0d5; border-radius: 10px; overflow: hidden; margin: 1.5rem 0 2.5rem; }
