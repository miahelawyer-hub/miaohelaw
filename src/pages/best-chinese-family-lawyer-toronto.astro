    .btn-outline { background: transparent; color: white; border: 2px solid white; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.95rem; }

    .container { max-width: 960px; margin: 0 auto; padding: 2.5rem 1.5rem; }

    .prose { color: #4A2C1A; font-size: 0.95rem; line-height: 1.8; margin-bottom: 1.25rem; }
    .prose strong { color: var(--text-heading); }
    .insight-box { background: #FDF6EC; border-left: 4px solid #D4A853; border-radius: 0 8px 8px 0; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
    .insight-box p { color: #4A2C1A; font-size: 0.92rem; line-height: 1.75; margin: 0; }
    .check-list { list-style: none; padding: 0; margin: 1rem 0 1.5rem; }
    .check-list li { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.5rem 0; font-size: 0.92rem; color: #4A2C1A; line-height: 1.6; border-bottom: 1px solid #f0ebe3; }
    .check-list li:last-child { border-bottom: none; }
    .check-list .icon { color: #D4A853; font-weight: 700; flex-shrink: 0; }

    /* 核心指标 */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: #e8e0d5;
      border: 1px solid #e8e0d5;
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 3rem;
    }
    .stat {
      background: white;
      padding: 1.25rem 1rem;
      text-align: center;
    }
    .stat-num { font-size: 1.6rem; font-weight: 700; color: var(--text-heading); display: block; }
    .stat-label { font-size: 0.78rem; color: #9A8060; margin-top: 0.2rem; }

    /* 为什么选择 */
    .section-title { color: var(--text-heading); font-size: 1.3rem; margin: 0 0 1.5rem; padding-bottom: 0.4rem; border-bottom: 2px solid #D4A853; }

    .reason-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-bottom: 3rem; }
    .reason-card { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.5rem; }
    .reason-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .reason-card h3 { color: var(--text-heading); font-size: 0.98rem; margin: 0 0 0.5rem; }
    .reason-card p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* 真实案件 */
    .case-block { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.5rem; margin-bottom: 1rem; border-left: 4px solid #D4A853; }
    .case-ref { font-size: 0.78rem; color: #D4A853; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 0.4rem; }
    .case-block h3 { color: var(--text-heading); font-size: 0.95rem; margin: 0 0 0.5rem; }
    .case-block p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* FAQ */
