  <style>
    * { box-sizing: border-box; }
    body { background: var(--bg); margin: 0; }
    .page-hero { background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0,0,0,0.35);
      padding: 3rem 1.5rem 2.5rem;
      text-align: center;
    }
    .page-hero .badge {
      display: inline-block;
      background: rgba(212,168,83,0.15);
      border: 1px solid #D4A853;
      color: #D4A853;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      padding: 0.3rem 1rem;
      border-radius: 20px;
      margin-bottom: 1rem;
      text-transform: uppercase;
    }
    .page-hero h1 {
      color: #ffffff;
      font-size: clamp(1.5rem, 3.5vw, 2.1rem);
      line-height: 1.35;
      margin: 0 auto 1rem;
      max-width: 800px;
    }
