  <style>
    * { box-sizing: border-box; }
    body { background: #faf8f5; margin: 0; }
    .page-hero {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      padding: 3rem 1.5rem 2.5rem;
      text-align: center;
    }
    .page-hero .badge {
      display: inline-block;
      background: rgba(212,168,83,0.15);
      border: 1px solid #D4A853;
      color: #D4A853;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      padding: 0.3rem 1rem;
      border-radius: 20px;
      margin-bottom: 1rem;
      text-transform: uppercase;
    }
    .page-hero h1 {
      color: #ffffff;
      font-size: clamp(1.5rem, 3.5vw, 2.1rem);
      line-height: 1.35;
      margin: 0 auto 1rem;
      max-width: 800px;
    }
    .page-hero .sub {
      color: rgba(255,255,255,0.8);
      font-size: 1rem;
      max-width: 600px;
      margin: 0 auto 1.5rem;
      line-height: 1.7;
    }
    .hero-cta { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-gold { background: #D4A853; color: #2C1810; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.95rem; }
    .btn-outline { background: transparent; color: white; border: 2px solid white; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.95rem; }

    .container { max-width: 960px; margin: 0 auto; padding: 2.5rem 1.5rem; }

    /* 核心指标 */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: #e8e0d5;
      border: 1px solid #e8e0d5;
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 3rem;
    }
    .stat {
      background: white;
      padding: 1.25rem 1rem;
      text-align: center;
    }
    .stat-num { font-size: 1.6rem; font-weight: 700; color: #2C1810; display: block; }
    .stat-label { font-size: 0.78rem; color: #9A8060; margin-top: 0.2rem; }

    /* 为什么选择 */
    .section-title { color: #2C1810; font-size: 1.3rem; margin: 0 0 1.5rem; padding-bottom: 0.4rem; border-bottom: 2px solid #D4A853; }

    .reason-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-bottom: 3rem; }
    .reason-card { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.5rem; }
    .reason-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .reason-card h3 { color: #2C1810; font-size: 0.98rem; margin: 0 0 0.5rem; }
    .reason-card p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* 真实案件 */
    .case-block { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.5rem; margin-bottom: 1rem; border-left: 4px solid #D4A853; }
    .case-ref { font-size: 0.78rem; color: #D4A853; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 0.4rem; }
    .case-block h3 { color: #2C1810; font-size: 0.95rem; margin: 0 0 0.5rem; }
    .case-block p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* FAQ */
    .faq-item { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 0.75rem; }
    .faq-item h3 { color: #2C1810; font-size: 0.95rem; margin: 0 0 0.5rem; }
    .faq-item p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* 资质 */
    .credential-list { list-style: none; padding: 0; margin: 0 0 3rem; }
    .credential-list li { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.75rem 0; border-bottom: 1px solid #e8e0d5; font-size: 0.9rem; color: #4A2C1A; }
    .credential-list li:last-child { border-bottom: none; }
    .credential-list .icon { color: #D4A853; font-size: 1.1rem; flex-shrink: 0; margin-top: 0.1rem; }

    /* 最终CTA */
    .final-cta { background: linear-gradient(135deg, #2C1810, #4A2C1A); border-radius: 12px; padding: 2.5rem; text-align: center; }
    .final-cta h2 { color: #D4A853; margin: 0 0 0.75rem; font-size: 1.3rem; }
    .final-cta p { color: rgba(255,255,255,0.88); margin: 0 0 1.5rem; font-size: 0.95rem; line-height: 1.7; }

    @media (max-width: 768px) {
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .reason-grid { grid-template-columns: 1fr; }
      .page-hero h1 { font-size: 1.4rem; }
    }
    @media (max-width: 480px) {
      .stats-bar { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
