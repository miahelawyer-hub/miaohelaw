---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import Footer from '../../components/Footer.astro';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Contact | Miao He — Ontario Family Law Lawyer | Book a Consultation"
    description="Book a consultation with Miao He, Ontario & China dual-licensed family lawyer in Markham. 30 min · $220+HST · Mandarin & English. 647-930-6688 · miao@miaohelaw.ca"
  />
  <meta name="keywords" content="contact Miao He lawyer,book family law consultation Toronto,Chinese family lawyer Markham contact,Miao He 647-930-6688" />
  <meta property="og:title" content="Contact | Miao He — Ontario Family Law Lawyer" />
  <meta property="og:url" content="https://www.miaohelaw.ca/en/contact" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/contact" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/contact" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/contact" />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "LegalService",
    "name": "H. LAW FIRM — Miao He Family Law",
    "url": "https://www.miaohelaw.ca/en/",
    "telephone": "+1-647-930-6688",
    "email": "miao@miaohelaw.ca",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "208-7050 Woodbine Ave",
      "addressLocality": "Markham",
      "addressRegion": "Ontario",
      "postalCode": "L3R 4G8",
      "addressCountry": "CA"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    "areaServed": "Greater Toronto Area, Ontario"
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://www.miaohelaw.ca/en/"},
      {"@type":"ListItem","position":2,"name":"Contact","item":"https://www.miaohelaw.ca/en/contact"}
    ]
  }</script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Georgia, serif; background: #FDFBF7; color: #2C1810; }
    a { color: inherit; text-decoration: none; }
    .page-hero { background: linear-gradient(135deg, #2C1810, #4A2C1A); padding: 3rem 1.5rem 2.5rem; text-align: center; }
    .page-hero .inner { max-width: 700px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; font-weight: 400; }
    .page-hero p { color: #D4A853; font-size: 0.9rem; margin: 0; }
    .contact-section { padding: 3rem 1.5rem 4rem; }
    .contact-inner { max-width: 760px; margin: 0 auto; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
    .contact-card { background: #fff; border: 1px solid #E8E0D5; border-radius: 10px; padding: 2rem; }
    .contact-card h2 { font-size: 1rem; font-weight: 600; color: #7A5A1A; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.08em; }
    .contact-row { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1rem; }
    .contact-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
    .contact-label { font-size: 0.75rem; color: #9A8060; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.2rem; }
    .contact-value { font-size: 0.9rem; color: #2C1810; line-height: 1.5; }
    .contact-value a { color: #7A5A1A; }
    .contact-value a:hover { text-decoration: underline; }
    .consult-card { background: linear-gradient(135deg, #2C1810, #4A2C1A); border-radius: 10px; padding: 2rem; margin-bottom: 2rem; }
    .consult-card h2 { color: #D4A853; font-size: 1.1rem; font-weight: 400; margin-bottom: 0.5rem; }
    .consult-card p { color: rgba(255,255,255,0.85); font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.5rem; }
    .consult-price { font-size: 2rem; color: #D4A853; margin: 0.75rem 0 0.25rem; }
    .consult-price span { font-size: 1rem; color: rgba(255,255,255,0.6); }
    .consult-detail { font-size: 0.8rem; color: rgba(255,255,255,0.55); margin-bottom: 1.5rem; }
    .btn-gold { display: inline-flex; align-items: center; justify-content: center; background: #D4A853; color: #2C1810; padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; margin-right: 0.75rem; margin-bottom: 0.5rem; }
    .btn-outline-white { display: inline-flex; align-items: center; justify-content: center; background: transparent; color: white; border: 2px solid rgba(255,255,255,0.5); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; margin-bottom: 0.5rem; }
    .process-card { background: #F5EFE0; border-radius: 10px; padding: 2rem; margin-bottom: 2rem; }
    .process-card h2 { font-size: 1rem; font-weight: 600; color: #7A5A1A; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.08em; }
    .process-steps { display: flex; flex-direction: column; gap: 1rem; }
    .process-step { display: flex; gap: 1rem; align-items: flex-start; }
    .step-num { background: #7A5A1A; color: #fff; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .step-text h3 { font-size: 0.9rem; color: #1A1208; font-weight: 600; margin-bottom: 0.2rem; }
    .step-text p { font-size: 0.82rem; color: #6B5A3A; line-height: 1.6; }
    .note-card { background: #fff; border: 1px solid #E8E0D5; border-radius: 10px; padding: 1.5rem 2rem; font-size: 0.85rem; color: #6B5A3A; line-height: 1.7; }
    .note-card strong { color: #2C1810; }
    @media (max-width: 640px) { .contact-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <HeaderEn />
  <main>
    <section class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/en/">Home</a> › Contact</p>
        <h1>Contact Miao He</h1>
        <p>Ontario & China Dual-Licensed Family Lawyer · Markham · 647-930-6688</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-inner">

        <div class="consult-card">
          <h2>Book an Initial Consultation</h2>
          <p>The first step to understanding your options and building a strategy for your situation.</p>
          <div class="consult-price">$220 <span>+ HST</span></div>
          <div class="consult-detail">30 minutes · Mandarin & English · In-person or video · No obligation to retain</div>
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="mailto:miao@miaohelaw.ca" class="btn-outline-white">miao@miaohelaw.ca</a>
        </div>

        <div class="contact-grid">
          <div class="contact-card">
            <h2>Contact Information</h2>
            <div class="contact-row">
              <span class="contact-icon">📞</span>
              <div>
                <div class="contact-label">Phone</div>
                <div class="contact-value"><a href="tel:6479306688">647-930-6688</a></div>
              </div>
            </div>
            <div class="contact-row">
              <span class="contact-icon">📧</span>
              <div>
                <div class="contact-label">Email</div>
                <div class="contact-value"><a href="mailto:miao@miaohelaw.ca">miao@miaohelaw.ca</a></div>
              </div>
            </div>
            <div class="contact-row">
              <span class="contact-icon">📍</span>
              <div>
                <div class="contact-label">Office</div>
                <div class="contact-value">208-7050 Woodbine Ave<br/>Markham, ON L3R 4G8</div>
              </div>
            </div>
            <div class="contact-row">
              <span class="contact-icon">🕐</span>
              <div>
                <div class="contact-label">Office Hours</div>
                <div class="contact-value">Mon – Fri: 9:00 AM – 6:00 PM</div>
              </div>
            </div>
          </div>

          <div class="contact-card">
            <h2>Languages & Service Area</h2>
            <div class="contact-row">
              <span class="contact-icon">🌐</span>
              <div>
                <div class="contact-label">Languages</div>
                <div class="contact-value">Mandarin (普通话) · English</div>
              </div>
            </div>
            <div class="contact-row">
              <span class="contact-icon">⚖️</span>
              <div>
                <div class="contact-label">Licensed In</div>
                <div class="contact-value">Ontario (LSO #83315K)<br/>China (PRC Bar)</div>
              </div>
            </div>
            <div class="contact-row">
              <span class="contact-icon">📌</span>
              <div>
                <div class="contact-label">Areas Served</div>
                <div class="contact-value">Markham · Toronto · Richmond Hill · Vaughan · Mississauga · Brampton · Scarborough · All of Ontario</div>
              </div>
            </div>
          </div>
        </div>

        <div class="process-card">
          <h2>What to Expect</h2>
          <div class="process-steps">
            <div class="process-step">
              <div class="step-num">1</div>
              <div class="step-text">
                <h3>Reach Out</h3>
                <p>Call 647-930-6688 or email miao@miaohelaw.ca. We typically respond within 1–3 business days.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-num">2</div>
              <div class="step-text">
                <h3>Initial Consultation (30 min · $220+HST)</h3>
                <p>We review your situation, clarify your legal rights, and give you a candid assessment of your options and the realistic fee range.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-num">3</div>
              <div class="step-text">
                <h3>Decide Your Path Forward</h3>
                <p>There is no obligation to retain after the consultation. If you decide to proceed, we discuss the retainer and begin building your strategy.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="note-card">
          <strong>Please note:</strong> Miao He primarily serves privately retained clients. Legal Aid services are not available through this firm. If budget is a concern, please mention this during the consultation — we will explore the most cost-effective approach for your situation, including limited retainer arrangements where appropriate.
        </div>

      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
