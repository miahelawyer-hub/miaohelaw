---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import Footer from '../../components/Footer.astro';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Contact | Miao He — Ontario Family Law Lawyer"
    description="Contact Miao He — Ontario & China dual-licensed family lawyer in Markham. Call 647-930-6688 or email miao@miaohelaw.ca. Mandarin and English."
  />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/contact" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/contact" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/contact" />
  <style>
    * { box-sizing: border-box; }
    body { background: #faf8f5; margin: 0; font-family: Georgia, serif; color: #2C1810; }
    .page-hero { background: linear-gradient(135deg, #2C1810, #4A2C1A); padding: 3rem 1.5rem 2.5rem; }
    .page-hero .inner { max-width: 900px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; }
    .page-hero p { color: #D4A853; margin: 0; font-size: 0.92rem; }
    .main-wrap { max-width: 860px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .card { background: #fff; border: 1px solid #E8E0D5; border-radius: 8px; padding: 2rem; }
    .card h2 { color: #7A5A1A; font-size: 1rem; margin: 0 0 1.2rem; letter-spacing: 0.03em; }
    .contact-item { display: flex; gap: 0.8rem; align-items: flex-start; margin-bottom: 1.2rem; }
    .contact-icon { font-size: 1.2rem; margin-top: 0.1rem; }
    .contact-label { font-size: 0.78rem; color: #9A8060; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.2rem; }
    .contact-value { font-size: 0.92rem; color: #2C1810; }
    .contact-value a { color: #7A5A1A; text-decoration: none; font-weight: 600; }
    .hours-card { grid-column: 1 / -1; }
    .hours-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; margin-top: 0.5rem; }
    .hours-item { font-size: 0.85rem; color: #5A4A3A; }
    .note { background: #F5EFE0; border-radius: 6px; padding: 0.8rem 1rem; font-size: 0.82rem; color: #5A4A3A; margin-top: 1rem; }
    @media (max-width: 600px) { .main-wrap { grid-template-columns: 1fr; } .hours-card { grid-column: 1; } }
  </style>
</head>
<body>
  <HeaderEn />
  <div class="page-hero">
    <div class="inner">
      <div class="breadcrumb"><a href="/en/">Home</a> › Contact</div>
      <h1>Contact Us</h1>
      <p>Book a consultation or ask a question — we respond within 3 business days</p>
    </div>
  </div>
  <div class="main-wrap">
    <div class="card">
      <h2>CONTACT INFORMATION</h2>
      <div class="contact-item">
        <div class="contact-icon">📞</div>
        <div>
          <div class="contact-label">Phone</div>
          <div class="contact-value"><a href="tel:6479306688">647-930-6688</a></div>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">📧</div>
        <div>
          <div class="contact-label">Email</div>
          <div class="contact-value"><a href="mailto:miao@miaohelaw.ca">miao@miaohelaw.ca</a></div>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">💬</div>
        <div>
          <div class="contact-label">WeChat</div>
          <div class="contact-value">372656035</div>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">🏢</div>
        <div>
          <div class="contact-label">Office</div>
          <div class="contact-value">208-7050 Woodbine Ave<br/>Markham, Ontario L3R 4G8</div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>INITIAL CONSULTATION</h2>
      <p style="color:#5A4A3A; font-size:0.9rem; line-height:1.7;">30 minutes · $220 + HST<br/>Billed in 6-minute increments<br/>Services in Mandarin and English</p>
      <div class="note">We typically respond within 3 business days. For urgent matters, please call directly.</div>
    </div>

    <div class="card hours-card">
      <h2>OFFICE HOURS</h2>
      <div class="hours-grid">
        <div class="hours-item"><strong>Monday – Friday</strong><br/>9:00 AM – 5:30 PM</div>
        <div class="hours-item"><strong>Saturday</strong><br/>By appointment</div>
        <div class="hours-item"><strong>Sunday</strong><br/>Closed</div>
      </div>
    </div>
  </div>
  <Footer />
</body>
</html>
