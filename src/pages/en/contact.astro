---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import Footer from '../../components/Footer.astro';
import { SITE_LAST_UPDATED_EN } from '../../consts';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Contact Miao He — Chinese Family Lawyer Toronto | Mandarin Divorce Lawyer GTA"
    description="Book a consultation with Miao He, Ontario & China dual-licensed family lawyer in Markham. Serving Chinese-Canadian clients across GTA in Mandarin & English. 30 min · $220+HST · 647-930-6688."
  />
  <meta name="keywords" content="Chinese family lawyer Toronto,Mandarin divorce lawyer GTA,Chinese divorce lawyer Markham,Mandarin speaking family lawyer Ontario,Chinese lawyer Richmond Hill,Mandarin family lawyer Mississauga,Chinese divorce attorney Brampton,bilingual family lawyer Toronto,Miao He lawyer,647-930-6688" />
  <meta property="og:title" content="Contact Miao He — Chinese Family Lawyer Toronto | Mandarin Divorce Lawyer GTA" />
  <meta property="og:description" content="Book a consultation with Miao He, Ontario & China dual-licensed family lawyer. Serving GTA in Mandarin & English. 647-930-6688." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://www.miaohelaw.ca/og-image.jpg" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/contact/" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/contact/" />
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "@id": "https://www.miaohelaw.ca/en/contact/",
      "url": "https://www.miaohelaw.ca/en/contact/",
      "name": "Contact Miao He — Chinese Family Lawyer Toronto",
      "description": "Book a consultation with Miao He, Ontario and China dual-licensed family lawyer. Serving the Chinese-Canadian community across GTA in Mandarin and English.",
      "inLanguage": ["en", "zh-Hans"],
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.miaohelaw.ca/en/" },
          { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://www.miaohelaw.ca/en/contact/" }
        ]
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "LegalService",
      "@id": "https://www.miaohelaw.ca/en/#lawfirm",
      "name": "H. LAW FIRM — Miao He Family Law",
      "url": "https://www.hlawfirmontario.com",
      "telephone": "+1-647-930-6688",
      "email": "miao@miaohelaw.ca",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "208-7050 Woodbine Avenue",
        "addressLocality": "Markham",
        "addressRegion": "ON",
        "postalCode": "L3R 4G8",
        "addressCountry": "CA"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": "43.8149715", "longitude": "-79.3498119" },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "18:00"
      },
      "areaServed": ["Toronto","Markham","Richmond Hill","Mississauga","Scarborough","Brampton","Vaughan","Greater Toronto Area","Ontario"],
      "knowsLanguage": ["zh-Hans","en"],
      "serviceType": ["Divorce Litigation","Family Law","Child Custody","Property Division","Cross-Border Asset Division","Spousal Support","Child Support","Prenuptial Agreement","Separation Agreement","Mediation"],
      "employee": {
        "@type": "Person",
        "name": "Miao He",
        "jobTitle": "Family Law Lawyer",
        "telephone": "+1-647-930-6688",
        "email": "miao@miaohelaw.ca",
        "hasCredential": [
          { "@type": "EducationalOccupationalCredential", "credentialCategory": "Law Society of Ontario — Member #83315K" },
          { "@type": "EducationalOccupationalCredential", "credentialCategory": "China Bar Association — Licensed" },
          { "@type": "EducationalOccupationalCredential", "credentialCategory": "Expert Witness — Chinese Family Law & Marriage Law" },
          { "@type": "EducationalOccupationalCredential", "credentialCategory": "Notary Public — Ontario" }
        ]
      },
      "priceRange": "$$"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "I am considering divorce but don\'t know where to start. Can I contact Miao He?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Miao He offers a 30-minute initial consultation ($220+HST) to help you understand your rights, the process, and your options. Call 647-930-6688." }
        },
        {
          "@type": "Question",
          "name": "I am worried my spouse may be hiding or transferring assets. Can Miao He help?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Miao He has extensive experience with cross-border asset tracing, including emergency asset preservation orders and investigation of assets in China. She has successfully helped clients recover over $300,000 CAD in hidden assets." }
        },
        {
          "@type": "Question",
          "name": "Which areas does Miao He serve?",
          "acceptedAnswer": { "@type": "Answer", "text": "Miao He serves clients throughout Ontario, including Toronto, Markham, Richmond Hill, Mississauga, Scarborough, Brampton, Vaughan, and all GTA regions." }
        },
        {
          "@type": "Question",
          "name": "Does Miao He provide services in Mandarin?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Miao He provides full service in Mandarin (Putonghua) and English, ensuring Chinese-Canadian clients can clearly understand complex legal proceedings." }
        }
      ]
    }
  ]
  </script>
  <style>
    .page-main {
      max-width: 100%;
      padding: 0;
      margin: 0;
      --contact-gold: #b89456;
      --contact-gold-soft: #c4a386;
      --contact-panel: #ffffff;
      --contact-panel-border: rgba(44, 36, 24, 0.12);
      --contact-body: #4a3a2a;
      --contact-muted: rgba(74, 58, 42, 0.72);
    }

    .hf-hero {
      --hf-brand-primary: #3a4148;
      --hf-brand-accent: #b8956a;
      --hf-brand-accent-dark: #a78458;
      position: relative;
      overflow: hidden;
      padding: clamp(5rem, 12vw, 7rem) 1.5rem;
      text-align: center;
      color: #fff;
      border-bottom: 1px solid rgba(0, 0, 0, 0.35);
    }

    /* Contact hero: same backdrop scale + scrim as EN homepage (.hero-court-bg / .hero-court-scrim) */
    .hf-hero__layers {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }

    .hf-hero__court-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      transform: scale(1.03);
      pointer-events: none;
    }

    .hf-hero__court-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .hf-hero__court-scrim {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        radial-gradient(ellipse 88% 74% at 50% 40%, rgba(0, 0, 0, 0.49) 0%, transparent 62%),
        linear-gradient(180deg, rgba(252, 250, 247, 0.01) 0%, transparent 52%),
        linear-gradient(
          165deg,
          rgba(26, 24, 22, 0.64) 0%,
          rgba(32, 28, 26, 0.69) 45%,
          rgba(18, 17, 16, 0.73) 100%
        );
      pointer-events: none;
    }

    .hf-hero__inner {
      position: relative;
      z-index: 2;
      max-width: 56rem;
      margin: 0 auto;
      padding-left: max(0px, env(safe-area-inset-left));
      padding-right: max(0px, env(safe-area-inset-right));
    }

    .hf-hero__breadcrumb {
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.78);
      margin-bottom: 1rem;
    }

    .hf-hero__breadcrumb a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .hf-hero__badge-row {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }

    .hf-hero__badge {
      display: inline-block;
      padding: 0.375rem 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--hf-brand-accent);
      background: rgba(184, 149, 106, 0.15);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border-radius: 9999px;
      border: 1px solid rgba(184, 149, 106, 0.3);
    }

    .hf-hero__title {
      font-size: clamp(1.875rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 1rem;
      color: #fff;
    }

    .hf-hero__accent {
      color: var(--hf-brand-accent);
    }

    .hf-hero__subtitle {
      font-size: clamp(1rem, 2vw, 1.125rem);
      font-weight: 500;
      color: rgba(255, 255, 255, 0.9);
      margin: 0 auto 1.5rem;
      max-width: 42rem;
      line-height: 1.5;
    }

    .hf-hero__lead {
      font-size: clamp(1.05rem, 2vw, 1.25rem);
      line-height: 1.625;
      color: rgba(255, 255, 255, 0.9);
      margin: 0 auto 2.5rem;
      max-width: 48rem;
    }

    .hf-hero__accent-inline {
      color: var(--hf-brand-accent);
      font-weight: 600;
    }

    .hf-hero__cta-row {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      justify-content: center;
      align-items: stretch;
    }

    .hf-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.5rem;
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.25;
      border-radius: 0.375rem;
      text-decoration: none;
      border: 2px solid transparent;
      cursor: pointer;
      box-sizing: border-box;
      transition:
        background 0.2s ease,
        color 0.2s ease,
        border-color 0.2s ease,
        box-shadow 0.2s ease;
      font-family: inherit;
      width: 100%;
    }

    .hf-btn--primary {
      background: var(--hf-brand-accent);
      color: #fff !important;
      border-color: var(--hf-brand-accent);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.25);
    }

    .hf-btn--primary:hover {
      background: var(--hf-brand-accent-dark);
      border-color: var(--hf-brand-accent-dark);
    }

    .hf-btn--ghost {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border-color: #fff;
      color: #fff !important;
    }

    .hf-btn--ghost:hover {
      background: #fff;
      color: var(--hf-brand-primary) !important;
      border-color: #fff;
    }

    .hf-wechat-icon {
      width: 1.25rem;
      height: 1.25rem;
      flex-shrink: 0;
      color: #07c160;
    }

    .hf-btn--ghost:hover .hf-wechat-icon {
      color: #07c160;
    }

    .hf-hero__wechat {
      position: relative;
      display: inline-flex;
      width: 100%;
      justify-content: center;
    }

    .hf-wechat-popover {
      display: none;
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-bottom: 0.75rem;
      width: 16rem;
      background: #fff;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 0.5rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
      padding: 1rem;
      z-index: 50;
      text-align: left;
    }

    .hf-wechat-popover.is-open {
      display: block;
    }

    .hf-wechat-popover__label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #6b7280;
      margin: 0 0 0.75rem;
      text-align: center;
    }

    .hf-wechat-popover__qr {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 0.375rem;
    }

    .hf-wechat-popover__hours {
      font-size: 0.75rem;
      color: #374151;
      margin: 0.75rem 0 0;
      text-align: center;
      line-height: 1.5;
    }

    .hf-hero__updated {
      margin: 1.75rem 0 0;
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.72);
    }

    #direct-contact {
      scroll-margin-top: 5rem;
    }

    @media (min-width: 640px) {
      .hf-hero__cta-row {
        flex-direction: row;
        align-items: stretch;
      }

      .hf-btn {
        width: auto;
      }

      .hf-hero__wechat {
        width: auto;
      }
    }

    .contact-section {
      padding: 3rem 1.5rem 4rem;
      background: var(--bg);
      color: var(--contact-body);
    }
    .contact-inner { max-width: 960px; margin: 0 auto; }
    .contact-grid { display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; }

    .contact-card,
    .services-card,
    .faq-card,
    .sidebar-card {
      background: var(--contact-panel);
      border: 1px solid var(--contact-panel-border);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--box-shadow);
    }

    .contact-card.highlight {
      border-left: 4px solid var(--contact-gold);
      padding-left: calc(2rem - 3px);
    }

    .contact-card.highlight h2,
    .services-card h2,
    .faq-card h2 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--contact-gold);
      margin: 0 0 1.2rem;
    }

    .contact-methods { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
    .contact-method {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 1rem;
      text-decoration: none;
      color: inherit;
      background: rgba(122, 90, 26, 0.06);
      border-radius: 8px;
      border: 1px solid rgba(44, 36, 24, 0.08);
      transition: background 0.15s, border-color 0.15s;
    }
    .contact-method:hover {
      background: rgba(122, 90, 26, 0.1);
      border-color: rgba(212, 168, 83, 0.45);
    }
    .method-icon { font-size: 1.4rem; }
    .method-label { font-size: 0.78rem; color: var(--contact-muted); margin-bottom: 0.2rem; }
    .method-value { font-size: 1rem; font-weight: 600; color: #2c1810; }

    .cta-actions { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .btn-primary {
      background: var(--contact-gold-soft);
      color: #1a1208;
      padding: 0.72rem 1.45rem;
      border-radius: 999px;
      font-size: 0.92rem;
      font-weight: 700;
      border: none;
      box-shadow: 0 4px 14px rgba(44, 36, 24, 0.18);
      transition: background 0.15s, transform 0.15s;
    }
    .btn-primary:hover { background: #d4b699; transform: translateY(-1px); }
    .btn-secondary {
      background: transparent;
      color: #4a3a2a;
      padding: 0.68rem 1.35rem;
      border-radius: 999px;
      font-size: 0.92rem;
      font-weight: 600;
      border: 2px solid rgba(74, 58, 42, 0.35);
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .btn-secondary:hover {
      background: rgba(122, 90, 26, 0.08);
      border-color: var(--contact-gold);
      color: #2c1810;
    }

    .response-note { font-size: 0.8rem; color: var(--contact-muted); }

    .services-card p,
    .faq-card p {
      font-size: 0.92rem;
      color: var(--contact-body);
      line-height: 1.65;
      margin-bottom: 0.75rem;
    }

    .services-list,
    .faq-list {
      padding-left: 1.2rem;
      margin: 0.75rem 0;
    }
    .services-list li,
    .faq-list li {
      margin-bottom: 0.5rem;
      font-size: 0.92rem;
      line-height: 1.55;
      color: var(--contact-body);
    }

    .complex-cases {
      font-size: 0.88rem;
      color: #4a3a2a;
      margin-top: 1rem;
      line-height: 1.6;
      background: rgba(184, 149, 106, 0.14);
      padding: 0.85rem 1rem;
      border-radius: 6px;
      border-left: 3px solid var(--contact-gold);
    }

    .contact-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

    .sidebar-card { padding: 1.5rem; }
    .sidebar-card h3 {
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--contact-gold);
      margin: 0 0 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .sidebar-card address {
      font-style: normal;
      font-size: 0.88rem;
      line-height: 1.75;
      color: var(--contact-body);
    }
    .sidebar-card address a {
      color: #2c1810;
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid rgba(212, 168, 83, 0.45);
    }
    .sidebar-card address a:hover {
      color: var(--contact-gold);
      border-bottom-color: var(--contact-gold);
    }

    .sidebar-card p { font-size: 0.875rem; color: var(--contact-body); line-height: 1.7; margin-bottom: 0.5rem; }

    .map-wrapper {
      margin-top: 0.75rem;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--contact-panel-border);
    }

    .area-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .area-list li { font-size: 0.85rem; }
    .area-list a {
      color: #5c4a36;
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    .area-list a:hover {
      color: var(--contact-gold);
      border-bottom-color: rgba(212, 168, 83, 0.5);
    }

    .credential-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .credential-list li {
      font-size: 0.85rem;
      color: var(--contact-body);
      padding-left: 1rem;
      position: relative;
    }
    .credential-list li::before {
      content: "·";
      position: absolute;
      left: 0;
      color: var(--contact-gold);
    }

    .sidebar-area-lede { font-size: 0.8rem; color: var(--contact-muted); margin-bottom: 0.5rem; }

    @media (max-width: 760px) {
      .contact-grid { grid-template-columns: 1fr; }
      .contact-sidebar { order: -1; }
    }
  </style>
</head>
<body>
  <HeaderEn />
  <main class="page-main">

    <section class="hf-hero" aria-label="Contact">
      <div class="hf-hero__layers" aria-hidden="true">
        <div class="hf-hero__court-bg">
          <img
            src="/images/hero-legal-backdrop.png"
            alt=""
            width="1920"
            height="1080"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hf-hero__court-scrim"></div>
      </div>
      <div class="hf-hero__inner">
        <div class="hf-hero__breadcrumb"><a href="/en/">Home</a> › Contact</div>
        <div class="hf-hero__badge-row">
          <span class="hf-hero__badge">Contact</span>
        </div>
        <h1 class="hf-hero__title">
          Contact Miao He | <span class="hf-hero__accent">Book a Consultation</span>
        </h1>
        <p class="hf-hero__subtitle">
          Ontario LSO #83315K · Mandarin &amp; English · Greater Toronto
        </p>
        <p class="hf-hero__lead">
          Looking for a Mandarin-speaking divorce lawyer in Toronto or GTA? Contact <span class="hf-hero__accent-inline">Miao He</span>. Initial consultation <span class="hf-hero__accent-inline">30 min · $220 + HST</span>.
        </p>
        <div class="hf-hero__cta-row">
          <a href="tel:6479306688" class="hf-btn hf-btn--primary">📞 647-930-6688</a>
          <div class="hf-hero__wechat" id="cta-wechat-wrapper-contact-en-hero">
            <button
              type="button"
              class="hf-btn hf-btn--ghost hf-btn--wechat"
              id="cta-wechat-toggle-contact-en-hero"
              aria-expanded="false"
              aria-controls="cta-wechat-popover-contact-en-hero"
            >
              <svg class="hf-wechat-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8.691 2C4.768 2 1.5 4.74 1.5 8.07c0 1.928 1.105 3.652 2.832 4.776L3.5 14.5l2.227-1.118c.704.182 1.443.282 2.205.282.158 0 .315-.005.47-.014a4.99 4.99 0 01-.182-1.293c0-2.946 2.804-5.339 6.275-5.339.158 0 .314.006.469.018C14.495 4.066 11.953 2 8.691 2zm-2.5 4a.75.75 0 110 1.5.75.75 0 010-1.5zm5 0a.75.75 0 110 1.5.75.75 0 010-1.5zM15.5 7.95c-3.245 0-5.875 2.166-5.875 4.838s2.63 4.838 5.875 4.838c.683 0 1.341-.097 1.953-.275L19.5 18.5l-.658-1.395C20.357 16.18 21.25 14.74 21.25 13.05c0-2.672-2.63-5.1-5.75-5.1zm-2 3a.625.625 0 110 1.25.625.625 0 010-1.25zm4 0a.625.625 0 110 1.25.625.625 0 010-1.25z"></path>
              </svg>
              WeChat
            </button>
            <div class="hf-wechat-popover" id="cta-wechat-popover-contact-en-hero" role="dialog" aria-hidden="true">
              <p class="hf-wechat-popover__label">Scan QR to add WeChat</p>
              <img src="/wechat-qr.jpg" alt="H. Law Firm WeChat QR code" class="hf-wechat-popover__qr" width="256" height="256" loading="lazy" decoding="async" />
              <p class="hf-wechat-popover__hours">
                Hours: Monday–Friday<br />
                9:00 a.m. – 5:00 p.m.
              </p>
            </div>
          </div>
          <a href="mailto:miao@miaohelaw.ca" class="hf-btn hf-btn--ghost">Email us →</a>
        </div>
        <p class="hf-hero__updated">Page last updated: {SITE_LAST_UPDATED_EN}</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-inner">
        <div class="contact-grid">

          <div class="contact-main">

            <div class="contact-card highlight" id="direct-contact">
              <h2>Contact Directly</h2>
              <div class="contact-methods">
                <a href="tel:6479306688" class="contact-method">
                  <span class="method-icon">📞</span>
                  <div>
                    <div class="method-label">Phone / WeChat Voice</div>
                    <div class="method-value">647-930-6688</div>
