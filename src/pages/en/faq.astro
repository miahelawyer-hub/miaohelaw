          ["How do I book a consultation with Miao He?", "Call 647-930-6688 or email miao@miaohelaw.ca. Initial consultations are 30 minutes at $220 + HST, conducted in Mandarin or English, in person or by video. There is no obligation to retain after the consultation."]
        ].map(([q, a], i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" onclick={`toggleFaq(${i})`}>
              <span>{q}</span>
