---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import Footer from '../../components/Footer.astro';

const faqs = [
  { q: "What are the grounds for divorce in Ontario?", a: "There are three grounds: separation for one year, adultery, or physical/mental cruelty. The vast majority of cases use the one-year separation ground. You can file the application at any time after separation — you do not need to wait a full year before filing." },
  { q: "Can a new immigrant get divorced in Ontario?", a: "Yes. Ontario courts handle divorce regardless of immigration status. As long as either spouse has lived in Ontario for at least one year, Ontario has jurisdiction to grant the divorce." },
  { q: "What if my spouse refuses to cooperate with the divorce?", a: "You can proceed with litigation regardless. The court does not require your spouse's consent. After one year of separation, the court can grant a divorce by default judgment even if your spouse refuses to participate." },
  { q: "Does the matrimonial home have to be split 50/50?", a: "Not necessarily. Ontario uses the equalization of net family property. The home is factored into the net family property calculation — the final division depends on the difference in each spouse's net family property, not a straight split of the house." },
  { q: "How is child support calculated in Ontario?", a: "Child support is calculated using the Federal Child Support Guidelines based on the paying parent's income and the number of children. The parties cannot agree to pay less than the guideline amount." },
  { q: "How is spousal support calculated?", a: "Spousal support is guided by the Spousal Support Advisory Guidelines (SSAG), which produce a range based on both parties' incomes and the length of the relationship. Courts have more discretion than with child support — not every case results in spousal support." },
  { q: "Is a marriage contract (prenup) enforceable in Ontario?", a: "Yes, if properly executed. Both parties must sign voluntarily, each must receive independent legal advice (ILA), there must be full financial disclosure, and the terms must be fair. Agreements made without ILA are at greater risk of being set aside." },
  { q: "How are assets held in China handled in an Ontario divorce?", a: "Ontario's equalization principle applies to worldwide assets, including Chinese real estate, offshore accounts, and overseas investments. Tracing and dividing cross-border assets requires a lawyer licensed in both China and Ontario." },
  { q: "What if my spouse threatens to take the children to China?", a: "This is an emergency. Contact a lawyer immediately. China is not a Hague Convention member, making recovery of a child extremely difficult once they leave Canada. Ontario courts can issue a Non-Removal Order before the child departs." },
  { q: "How long does divorce take in Ontario?", a: "An uncontested divorce typically takes 4 to 8 months. Contested litigation can take 1 to 3 years or longer depending on complexity." },
  { q: "How much does a divorce lawyer cost in Ontario?", a: "Uncontested divorce packages typically range from $2,000 to $5,000. Contested litigation is billed hourly — a complex contested case can cost $50,000 to $80,000 CAD or more over a year. Initial consultation is 30 minutes at $220 + HST." },
  { q: "What is equalization of net family property?", a: "This is Ontario's default property division rule. Each spouse calculates their net family property (assets minus debts at separation, minus assets brought into the marriage). The spouse with the higher NFP pays half the difference to the other." },
  { q: "Does common-law separation follow the same rules as marriage?", a: "No. Common-law spouses in Ontario do not have automatic equalization rights. However, they may have claims based on unjust enrichment, resulting trust, or constructive trust. Spousal support may also apply after a long relationship." },
  { q: "What is a separation agreement?", a: "A separation agreement is a legally binding contract between spouses that resolves all issues on separation — property division, spousal support, child custody, and parenting time. Both parties should have independent legal advice before signing." },
  { q: "Can I get an emergency custody order?", a: "Yes. If a child is at immediate risk, a lawyer can bring an emergency motion to obtain a temporary custody or non-removal order, sometimes within 24 to 48 hours." },
];
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Family Law FAQ | Miao He — Ontario Family Law Lawyer"
    description="Answers to common Ontario family law questions: divorce, property division, child custody, support, marriage contracts, cross-border assets. 647-930-6688."
  />
  <meta name="keywords" content="Ontario divorce FAQ,family law questions Ontario,divorce lawyer Toronto FAQ,child custody FAQ Ontario,spousal support Ontario" />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/faq" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/faq" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/faq" />
  <style>
    * { box-sizing: border-box; }
    body { background: #faf8f5; margin: 0; font-family: Georgia, serif; color: #2C1810; }
    .page-hero { background: linear-gradient(135deg, #2C1810, #4A2C1A); padding: 3rem 1.5rem 2.5rem; }
    .page-hero .inner { max-width: 900px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; }
    .page-hero p { color: #D4A853; margin: 0; font-size: 0.92rem; }
