    .cta-box { background: #F5EFE0; border-radius: 8px; padding: 2rem; text-align: center; margin-top: 3rem; }
    .cta-box h2 { color: #2C1810; margin-bottom: 0.5rem; }
    .cta-box p { color: #5A4A3A; font-size: 0.9rem; margin-bottom: 1.2rem; }
    .btn { display: inline-block; background: #7A5A1A; color: #fff; padding: 0.7rem 1.8rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 600; margin: 0.3rem; }
    .btn-outline { background: transparent; border: 1px solid #7A5A1A; color: #7A5A1A; }
  </style>
</head>
<body>
  <HeaderEn />
