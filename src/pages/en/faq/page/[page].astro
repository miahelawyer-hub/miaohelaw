---
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../../../components/BaseHead.astro';
import HeaderEn from '../../../../components/HeaderEn.astro';
import Footer from '../../../../components/Footer.astro';
import { SITE_LAST_UPDATED_EN, SITE_URL } from '../../../../consts';
import { getFaqItemsEnForListing } from '../../../../data/faq-en';
import { getFaqItemsForListing } from '../../../../data/faq';
import { stripHtml } from '../../../../utils/stripHtml';

export const getStaticPaths = (async () => {
	const all = getFaqItemsEnForListing();
	const zhAll = getFaqItemsForListing();
	const n = all.length;
	const totalPages = Math.max(1, Math.ceil(n / 10));
	const zhTotalPages = Math.max(1, Math.ceil(zhAll.length / 10));
	const paths: {
		params: { page: string };
		props: {
			currentPage: number;
			pageItems: ReturnType<typeof getFaqItemsEnForListing>;
			totalPages: number;
			totalFaqEn: number;
			zhTotalPages: number;
		};
	}[] = [];
	for (let p = 2; p <= totalPages; p++) {
		paths.push({
			params: { page: String(p) },
			props: {
				currentPage: p,
				pageItems: all.slice((p - 1) * 10, p * 10),
				totalPages,
				totalFaqEn: n,
				zhTotalPages,
			},
		});
	}
	return paths;
}) satisfies GetStaticPaths;

const { currentPage, pageItems, totalPages, totalFaqEn, zhTotalPages } = Astro.props;

const canonicalUrl = `${SITE_URL}/en/faq/page/${currentPage}/`;
const prevUrl = currentPage === 2 ? `${SITE_URL}/en/faq/` : `${SITE_URL}/en/faq/page/${currentPage - 1}/`;
const nextUrl = currentPage < totalPages ? `${SITE_URL}/en/faq/page/${currentPage + 1}/` : null;

const emitHreflang = currentPage <= zhTotalPages;

const itemListJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: pageItems.map((item, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: `${SITE_URL}/en/faq/${item.slug}/`,
		name: stripHtml(item.question),
	})),
};

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/en/` },
		{ '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE_URL}/en/faq/` },
		{ '@type': 'ListItem', position: 3, name: `Page ${currentPage}`, item: canonicalUrl },
	],
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={`FAQ · Page ${currentPage} | Ontario Family Law | Miao He`}
    description={`Ontario family law FAQ by Miao He — page ${currentPage} of ${totalPages} (${totalFaqEn} questions). Divorce, custody, property, support, and more. 647-930-6688.`}
  />
  <meta name="keywords" content="Toronto divorce cost,Ontario divorce FAQ,family law questions Ontario,Miao He" />
  <meta property="og:title" content={`FAQ · Page ${currentPage} | Miao He`} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="prev" href={prevUrl} />
  {nextUrl && <link rel="next" href={nextUrl} />}
  {emitHreflang && (
    <>
      <link rel="alternate" hreflang="zh" href={`${SITE_URL}/faq/page/${currentPage}/`} />
      <link rel="alternate" hreflang="en" href={canonicalUrl} />
      <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    </>
  )}
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: ui-serif, Georgia, serif;
      background: var(--bg);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { color: inherit; text-decoration: none; }

    .page-hero {
      position: relative;
      background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0, 0, 0, 0.35);
      color: white;
      padding: 3rem 1.5rem 2.5rem;
      overflow: hidden;
    }
    .page-hero .inner { max-width: 860px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); }
    .breadcrumb a:hover { opacity: 0.95; text-decoration: underline; }
    .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; color: #fff; font-weight: 500; letter-spacing: 0.02em; }
    .page-hero .hero-stat { color: #F5E6C8; margin: 0 0 0.45rem; font-size: 0.96rem; font-weight: 600; letter-spacing: 0.02em; }
    .page-hero .hero-sub { color: #E8C47A; margin: 0; font-size: 0.9rem; opacity: 0.95; }
    .faq-section { padding: 3rem 1.5rem 4rem; }
    .container { max-width: 860px; margin: 0 auto; }
    .faq-item { padding: 0.55rem 0; }
    .faq-link {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.05rem 1.1rem; gap: 1rem;
      font-size: 1.02rem; color: var(--text-primary); line-height: 1.65;
      border-radius: 12px;
      background: rgba(255,255,255,0.65);
      border: 1px solid rgba(237,232,223,0.9);
      box-shadow: 0 1px 0 rgba(44,24,16,0.02);
      transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
    }
    .faq-link:hover { background: #fff; border-color: rgba(212,168,83,0.35); color: #6B4A12; transform: translateY(-1px); }
    .faq-link:active { transform: translateY(0px); }
    .faq-link:hover .faq-arrow { color: #D4A853; }
    .faq-link span em { font-style: italic; }
    .faq-arrow { font-size: 1.05rem; color: #9A8060; flex-shrink: 0; }
    .contact-card {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px; padding: 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap; margin-top: 3rem;
    }
    .contact-info h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.2rem; font-weight: 400; }
    .contact-info p { color: #fff; margin: 0; font-size: 0.9rem; opacity: 0.88; }
    .contact-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: #D4A853; color: var(--text-heading); padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    .btn-secondary { display: inline-block; background: transparent; color: white; border: 2px solid white; padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    .faq-filter-hidden { display: none; }

    .sr-only{
      position:absolute;
      width:1px;
      height:1px;
      padding:0;
      margin:-1px;
      overflow:hidden;
      clip:rect(0,0,0,0);
      white-space:nowrap;
      border:0;
    }
    .faq-search{
      display:flex;
      gap:0.75rem;
      align-items:center;
      margin: 0 0 1.25rem;
      padding: 0.75rem;
      border-radius: 14px;
      background: rgba(255,255,255,0.75);
      border: 1px solid rgba(237,232,223,0.95);
      box-shadow: 0 1px 0 rgba(44,24,16,0.02);
    }
    .faq-search-input{
      flex: 1;
      min-width: 0;
      border: 1px solid rgba(212,168,83,0.28);
      background: #fff;
      color: var(--text-heading);
      border-radius: 12px;
      padding: 0.85rem 0.95rem;
      font-size: 1rem;
      line-height: 1.2;
      outline: none;
    }
    .faq-search-input:focus{
      border-color: rgba(212,168,83,0.6);
      box-shadow: 0 0 0 4px rgba(212,168,83,0.18);
    }
    .faq-search-clear{
      flex: none;
      border: 1px solid rgba(154,128,96,0.35);
      background: transparent;
      color: #6B5A3A;
      padding: 0.75rem 0.9rem;
      border-radius: 12px;
      cursor: pointer;
      font-family: inherit;
      font-size: 0.95rem;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .faq-search-clear:hover{
      background: rgba(212,168,83,0.14);
      border-color: rgba(212,168,83,0.45);
      color: var(--text-heading);
    }
    .faq-search-meta{
      margin: -0.35rem 0 1.25rem;
      color: rgba(44,24,16,0.72);
      font-size: 0.92rem;
    }
    .faq-search-results { margin: 0 0 1.25rem; }
    .faq-search-results ul { list-style: none; margin: 0; padding: 0; }
    .faq-search-results li { margin: 0 0 0.5rem; }
    .faq-search-results a {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.05rem 1.1rem; gap: 1rem; font-size: 1.02rem; line-height: 1.65;
      border-radius: 12px; background: rgba(255,255,255,0.65);
      border: 1px solid rgba(237,232,223,0.9); color: var(--text-primary); text-decoration: none;
    }
    .faq-search-results a:hover { border-color: rgba(212,168,83,0.35); color: #6B4A12; }
    .faq-pagination {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem 0.65rem;
      margin: 0 0 1.25rem; font-size: 0.88rem;
    }
    .faq-pagination a, .faq-pagination span.current {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 2.25rem; padding: 0.45rem 0.55rem; border-radius: 8px;
      text-decoration: none; border: 1px solid rgba(44,24,16,0.12);
      color: #4A2C1A; background: rgba(255,255,255,0.85);
    }
    .faq-pagination a:hover { border-color: rgba(212,168,83,0.55); }
    .faq-pagination span.current { font-weight: 700; border-color: rgba(212,168,83,0.55); background: rgba(212,168,83,0.12); }
    .faq-listing--searching .faq-item { display: none !important; }

    @media (max-width: 720px) { .contact-card { flex-direction: column; } }
    @media (max-width: 520px) {
      .faq-section { padding: 2.25rem 1.5rem 3.5rem; }
      .faq-item { padding: 0.45rem 0; }
      .faq-link { padding: 0.95rem 0.9rem; font-size: 1rem; }
      .faq-search{ padding: 0.65rem; gap: 0.6rem; }
      .faq-search-input{ padding: 0.8rem 0.85rem; }
      .faq-search-clear{ padding: 0.72rem 0.82rem; }
    }
  </style>
</head>
<body>
  <HeaderEn />
  <main class="faq-listing-root" id="faq-listing-root">
    <section class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/en/">Home</a> › <a href="/en/faq/">FAQ</a> › Page {currentPage}</p>
        <h1>Frequently Asked Questions</h1>
        <p class="hero-stat">{totalFaqEn} questions · Page {currentPage} of {totalPages}</p>
        <p class="hero-sub">Ontario Family Law · Answered by Miao He · 647-930-6688</p>
        <p class="page-last-updated page-last-updated--gradient">Page last updated: {SITE_LAST_UPDATED_EN}</p>
      </div>
    </section>
    <section class="faq-section">
      <div class="container">
        <div
          class="faq-search"
          role="search"
          aria-label="FAQ search"
          data-search-json="/en/faq-search.json"
          data-list-home="/en/faq/"
        >
          <label class="sr-only" for="faq-search-input">Search questions</label>
          <input
            id="faq-search-input"
            class="faq-search-input"
            type="search"
            placeholder="Search (e.g., divorce, custody, down payment, support)"
            autocomplete="off"
          />
          <button class="faq-search-clear" id="faq-search-clear" type="button" aria-label="Clear search">Clear</button>
        </div>
        <p class="faq-search-meta" id="faq-search-meta" aria-live="polite"></p>
        <div class="faq-search-results" id="faq-search-results" hidden></div>

        <nav class="faq-pagination" aria-label="FAQ pagination">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) =>
            num === currentPage ? (
              <span class="current" aria-current="page">{num}</span>
            ) : num === 1 ? (
              <a href="/en/faq/">{num}</a>
            ) : (
              <a href={`/en/faq/page/${num}/`}>{num}</a>
            )
          )}
        </nav>

        {pageItems.map((item) => (
          <div class="faq-item" data-search={`${stripHtml(item.question)} ${stripHtml(item.summary)} ${item.answers.map(stripHtml).join(' ')} ${item.keywords}`.toLowerCase()}>
            <a href={`/en/faq/${item.slug}/`} class="faq-link">
              <span set:html={item.question} />
              <span class="faq-arrow">→</span>
            </a>
          </div>
        ))}
        <div class="contact-card">
          <div class="contact-info">
            <h2>Have More Questions?</h2>
            <p>Miao He provides consultations in Mandarin and English · 30 min · $220 + HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/en/contact" class="btn-secondary">Book a Consultation</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
  <script src="/js/faq-listing.js" defer></script>
</body>
</html>
