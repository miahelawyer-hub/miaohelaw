---
import BaseHead from '../../../components/BaseHead.astro';
import HeaderEn from '../../../components/HeaderEn.astro';
import Footer from '../../../components/Footer.astro';
import { faqItemsEn } from '../../../data/faq-en';

const FEATURED_FAQ_SLUG = 'parents-down-payment-divorce-ontario';
const items = [...faqItemsEn].sort((a, b) => {
  if (a.slug === FEATURED_FAQ_SLUG) return -1;
  if (b.slug === FEATURED_FAQ_SLUG) return 1;
  return 0;
});
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="FAQ | Ontario Family Law | Miao He — Divorce, Custody, Property"
    description="Answers to 20 common Ontario family law questions: divorce requirements, property division, child custody, support, prenuptial agreements, cross-border assets. 647-930-6688."
  />
  <meta name="keywords" content="Ontario divorce FAQ,family law questions Ontario,divorce requirements Ontario,child custody Ontario,spousal support Ontario,prenuptial agreement Ontario,Chinese family lawyer FAQ" />
  <meta property="og:title" content="FAQ | Ontario Family Law | Miao He" />
  <meta property="og:url" content="https://www.miaohelaw.ca/en/faq" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/faq" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/faq" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/faq" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": items.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.summary }
    }))
  })} />
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://www.miaohelaw.ca/en/"},
      {"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.miaohelaw.ca/en/faq"}
    ]
  })}</script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: ui-serif, Georgia, serif;
      background: #faf8f5;
      color: #2C1810;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { color: inherit; text-decoration: none; }

    .page-hero {
      position: relative;
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      color: white;
      padding: 3rem 1.5rem 2.5rem;
      overflow: hidden;
    }
    .page-hero::after {
      content: "";
      position: absolute;
      inset: -40% -20% auto auto;
      width: 520px;
      height: 520px;
      background: radial-gradient(circle at 30% 30%, rgba(212,168,83,0.28), rgba(212,168,83,0) 60%);
      transform: rotate(18deg);
      pointer-events: none;
    }
    .page-hero .inner { max-width: 860px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); }
    .breadcrumb a:hover { opacity: 0.95; text-decoration: underline; }
    .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; color: #fff; font-weight: 500; letter-spacing: 0.02em; }
    .page-hero p { color: #E8C47A; margin: 0; font-size: 0.9rem; opacity: 0.95; }
    .faq-section { padding: 3rem 1.5rem 4rem; }
    .container { max-width: 860px; margin: 0 auto; }
    .faq-item { padding: 0.55rem 0; }
    .faq-link {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.05rem 1.1rem; gap: 1rem;
      font-size: 1.02rem; color: #1A1208; line-height: 1.65;
      border-radius: 12px;
      background: rgba(255,255,255,0.65);
      border: 1px solid rgba(237,232,223,0.9);
      box-shadow: 0 1px 0 rgba(44,24,16,0.02);
      transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
    }
    .faq-link:hover { background: #fff; border-color: rgba(212,168,83,0.35); color: #6B4A12; transform: translateY(-1px); }
    .faq-link:active { transform: translateY(0px); }
    .faq-link:hover .faq-arrow { color: #D4A853; }
    .faq-arrow { font-size: 1.05rem; color: #9A8060; flex-shrink: 0; }
    .contact-card {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px; padding: 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap; margin-top: 3rem;
    }
    .contact-info h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.2rem; font-weight: 400; }
    .contact-info p { color: #fff; margin: 0; font-size: 0.9rem; opacity: 0.88; }
    .contact-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: #D4A853; color: #2C1810; padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    .btn-secondary { display: inline-block; background: transparent; color: white; border: 2px solid white; padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    .faq-hidden { display: none; }
    .load-more-wrap { text-align: center; margin: 1.5rem 0 0; }
    .load-more-btn { display: inline-flex; align-items: center; gap: 0.5rem; background: white; border: 2px solid #D4A853; color: #2C1810; padding: 0.7rem 1.8rem; border-radius: 8px; font-size: 0.92rem; font-weight: 600; cursor: pointer; font-family: Georgia, serif; transition: background 0.15s, color 0.15s; }
    .load-more-btn:hover { background: #D4A853; color: white; }
    @media (max-width: 720px) { .contact-card { flex-direction: column; } }
    @media (max-width: 520px) {
      .faq-section { padding: 2.25rem 1.5rem 3.5rem; }
      .faq-item { padding: 0.45rem 0; }
      .faq-link { padding: 0.95rem 0.9rem; font-size: 1rem; }
    }
  </style>
</head>
<body>
  <HeaderEn />
  <main>
    <section class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/en/">Home</a> › FAQ</p>
        <h1>Frequently Asked Questions</h1>
        <p>Ontario Family Law · Answered by Miao He · 647-930-6688</p>
      </div>
    </section>
    <section class="faq-section">
      <div class="container">
        {items.map((item, i) => (
          <div class={`faq-item${i >= 10 ? ' faq-hidden' : ''}`}>
            <a href={`/en/faq/${item.slug}`} class="faq-link">
              <span>{item.question}</span>
              <span class="faq-arrow">→</span>
            </a>
          </div>
        ))}
        {items.length > 10 && (
          <div class="load-more-wrap">
            <button class="load-more-btn" id="faq-load-more">Load More Questions ↓</button>
          </div>
        )}
        <div class="contact-card">
          <div class="contact-info">
            <h2>Have More Questions?</h2>
            <p>Miao He provides consultations in Mandarin and English · 30 min · $220 + HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/en/contact" class="btn-secondary">Book a Consultation</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
  <script>
    const btn = document.getElementById('faq-load-more');
    if (btn) {
      const getHidden = () => Array.from(document.querySelectorAll('.faq-hidden'));
      btn.addEventListener('click', () => {
        getHidden().slice(0, 10).forEach(el => el.classList.remove('faq-hidden'));
        if (getHidden().length === 0) btn.style.display = 'none';
      });
    }
  </script>
</body>
</html>
