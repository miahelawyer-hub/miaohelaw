---
import BaseHead from '../../../components/BaseHead.astro';
import HeaderEn from '../../../components/HeaderEn.astro';
import Footer from '../../../components/Footer.astro';
import { faqItemsEn } from '../../../data/faq-en';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="FAQ | Ontario Family Law | Miao He — Divorce, Custody, Property"
    description="Answers to 20 common Ontario family law questions: divorce requirements, property division, child custody, support, prenuptial agreements, cross-border assets. 647-930-6688."
  />
  <meta name="keywords" content="Ontario divorce FAQ,family law questions Ontario,divorce requirements Ontario,child custody Ontario,spousal support Ontario,prenuptial agreement Ontario,Chinese family lawyer FAQ" />
  <meta property="og:title" content="FAQ | Ontario Family Law | Miao He" />
  <meta property="og:url" content="https://www.miaohelaw.ca/en/faq" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/faq" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/faq" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/faq" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItemsEn.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.summary }
    }))
  })} />
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://www.miaohelaw.ca/en/"},
      {"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.miaohelaw.ca/en/faq"}
    ]
  })}</script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Georgia, serif; background: #faf8f5; color: #2C1810; }
    a { color: inherit; text-decoration: none; }
    .page-hero { background: linear-gradient(135deg, #2C1810, #4A2C1A); color: white; padding: 3rem 1.5rem 2.5rem; }
    .page-hero .inner { max-width: 860px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); }
    .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; color: #fff; font-weight: 400; }
    .page-hero p { color: #D4A853; margin: 0; font-size: 0.9rem; }
    .faq-section { padding: 3rem 1.5rem 4rem; }
    .container { max-width: 860px; margin: 0 auto; }
    .faq-item { border-bottom: 1px solid #EDE8DF; }
    .faq-link {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.25rem 0; gap: 1rem;
      font-size: 1rem; color: #1A1208; line-height: 1.5;
      transition: color 0.15s;
    }
    .faq-link:hover { color: #7A5A1A; }
    .faq-link:hover .faq-arrow { color: #D4A853; }
    .faq-arrow { font-size: 1rem; color: #9A8060; flex-shrink: 0; }
    .contact-card {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px; padding: 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap; margin-top: 3rem;
    }
    .contact-info h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.2rem; font-weight: 400; }
    .contact-info p { color: #fff; margin: 0; font-size: 0.9rem; opacity: 0.88; }
    .contact-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: #D4A853; color: #2C1810; padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    .btn-secondary { display: inline-block; background: transparent; color: white; border: 2px solid white; padding: 0.7rem 1.4rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; }
    @media (max-width: 720px) { .contact-card { flex-direction: column; } }
  </style>
</head>
<body>
  <HeaderEn />
  <main>
    <section class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/en/">Home</a> › FAQ</p>
        <h1>Frequently Asked Questions</h1>
        <p>Ontario Family Law · Answered by Miao He · 647-930-6688</p>
      </div>
    </section>
    <section class="faq-section">
      <div class="container">
        {faqItemsEn.map(item => (
          <div class="faq-item">
            <a href={`/en/faq/${item.slug}`} class="faq-link">
              <span>{item.question}</span>
              <span class="faq-arrow">→</span>
            </a>
          </div>
        ))}
        <div class="contact-card">
          <div class="contact-info">
            <h2>Have More Questions?</h2>
            <p>Miao He provides consultations in Mandarin and English · 30 min · $220 + HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/en/contact" class="btn-secondary">Book a Consultation</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
