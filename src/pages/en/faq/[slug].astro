---
import BaseHead from '../../../components/BaseHead.astro';
import HeaderEn from '../../../components/HeaderEn.astro';
import Footer from '../../../components/Footer.astro';
import { faqItemsEn } from '../../../data/faq-en';

export function getStaticPaths() {
  return faqItemsEn.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const others = faqItemsEn.filter(f => f.slug !== item.slug).slice(0, 6);
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={`${item.question} | Miao He — Ontario Family Law`}
    description={item.summary}
  />
  <meta name="keywords" content={item.keywords} />
  <meta property="og:title" content={`${item.question} | Miao He`} />
  <meta property="og:description" content={item.summary} />
  <meta property="og:url" content={`https://www.miaohelaw.ca/en/faq/${item.slug}`} />
  <meta property="og:type" content="article" />
  <link rel="canonical" href={`https://www.miaohelaw.ca/en/faq/${item.slug}`} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.summary }
    }]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://www.miaohelaw.ca/en/"},
      {"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.miaohelaw.ca/en/faq"},
      {"@type":"ListItem","position":3,"name":item.question,"item":`https://www.miaohelaw.ca/en/faq/${item.slug}`}
    ]
  })} />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Georgia, serif; background: #faf8f5; color: #2C1810; }
    a { color: inherit; text-decoration: none; }

    .page-hero { background: linear-gradient(135deg, #2C1810, #4A2C1A); padding: 3rem 1.5rem 2.5rem; }
    .page-hero .inner { max-width: 860px; margin: 0 auto; }
    .breadcrumb { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-bottom: 1rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); }
    .breadcrumb span { color: rgba(255,255,255,0.3); margin: 0 0.4rem; }
    .page-hero h1 { color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.4; font-weight: 400; }

    .answer-section { padding: 2.5rem 1.5rem 4rem; }
    .container { max-width: 860px; margin: 0 auto; }

    .summary-card {
      background: #fff7ec; border-left: 4px solid #D4A853;
      border-radius: 0 8px 8px 0; padding: 1.25rem 1.5rem; margin-bottom: 2rem;
    }
    .summary-label {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
      color: #9A8060; text-transform: uppercase; margin-bottom: 0.5rem;
    }
    .summary-card p { color: #2C1810; font-size: 0.95rem; line-height: 1.8; margin: 0; }

    .answer-card {
      background: white; border-radius: 12px;
      box-shadow: 0 2px 12px rgba(44,24,16,0.07);
      padding: 2rem 2.5rem; margin-bottom: 2rem;
    }
    .answer-card h2 {
      font-size: 1rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: #9A8060; margin-bottom: 1.25rem; padding-bottom: 0.75rem;
      border-bottom: 2px solid #D4A853;
    }
    .answer-card p { color: #2C1810; font-size: 0.95rem; line-height: 1.9; margin-bottom: 1.25rem; }
    .answer-card p:last-of-type { margin-bottom: 0; }

    .answer-cta {
      margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid #e8e0d5;
    }
    .answer-cta a {
      display: inline-block; background: #D4A853; color: #2C1810;
      padding: 0.7rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem;
    }

    .related-section { margin-bottom: 2rem; }
    .related-section h2 {
      font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: #9A8060; margin-bottom: 1rem;
    }
    .related-list { list-style: none; background: white; border-radius: 10px;
      border: 1px solid #e8e0d5; overflow: hidden; margin-bottom: 1rem; }
    .related-list li { border-bottom: 1px solid #f0ebe3; }
    .related-list li:last-child { border-bottom: none; }
    .related-list a {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.9rem 1.25rem; font-size: 0.9rem; color: #2C1810;
      transition: background 0.15s;
    }
    .related-list a:hover { background: #fdf6ec; color: #7A5A1A; }
    .related-list .arr { color: #9A8060; font-size: 0.85rem; }
    .view-all { font-size: 0.85rem; color: #9A8060; }
    .view-all:hover { color: #2C1810; }

    .contact-card {
      background: linear-gradient(135deg, #2C1810, #4A2C1A);
      border-radius: 12px; padding: 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap;
    }
    .contact-info h2 { color: #D4A853; margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 400; }
    .contact-info p { color: rgba(255,255,255,0.88); margin: 0; font-size: 0.88rem; }
    .contact-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: #D4A853; color: #2C1810; padding: 0.65rem 1.3rem; border-radius: 6px; font-weight: 700; font-size: 0.88rem; }
    .btn-secondary { display: inline-block; background: transparent; color: white; border: 2px solid white; padding: 0.65rem 1.3rem; border-radius: 6px; font-weight: 700; font-size: 0.88rem; }

    @media (max-width: 720px) {
      .answer-card { padding: 1.5rem 1.25rem; }
      .contact-card { flex-direction: column; }
    }
  </style>
</head>
<body>
  <HeaderEn />
  <main>
    <section class="page-hero">
      <div class="inner">
        <p class="breadcrumb">
          <a href="/en/">Home</a><span>›</span>
          <a href="/en/faq">FAQ</a><span>›</span>
          {item.question}
        </p>
        <h1>{item.question}</h1>
      </div>
    </section>

    <section class="answer-section">
      <div class="container">

        <div class="summary-card">
          <div class="summary-label">Short Answer</div>
          <p>{item.summary}</p>
        </div>

        <div class="answer-card">
          <h2>Detailed Answer</h2>
          {item.details.map(para => (
            <p>{para}</p>
          ))}
          <div class="answer-cta">
            <a href="tel:6479306688">📞 647-930-6688 · Book a Consultation with Miao He</a>
          </div>
        </div>

        <div class="related-section">
          <h2>Other Common Questions</h2>
          <ul class="related-list">
            {others.map(other => (
              <li>
                <a href={`/en/faq/${other.slug}`}>
                  <span>{other.question}</span>
                  <span class="arr">→</span>
                </a>
              </li>
            ))}
          </ul>
          <a href="/en/faq" class="view-all">← View all questions</a>
        </div>

        <div class="contact-card">
          <div class="contact-info">
            <h2>Still have questions?</h2>
            <p>Miao He · Mandarin & English · 30 min consultation $220 + HST · Markham · All of Ontario</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/en/contact" class="btn-secondary">Book Online</a>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
