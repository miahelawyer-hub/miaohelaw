      ],
      "skills": "Family law litigation, cross-border asset disputes, high-conflict divorce, child custody, enforcement motions"
    },
    "worksFor": {"@type": "LegalService", "name": "H. LAW FIRM", "url": "https://www.hlawfirmontario.com"}
