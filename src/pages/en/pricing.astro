    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.55), 0 1px 3px rgba(0, 0, 0, 0.45);
  }
  .page-hero--pricing p {
    font-size: 0.9rem;
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
  }
  .page-hero--pricing .page-last-updated { color: rgba(255, 255, 255, 0.72) !important; }
  .page-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 1rem; }
  .pricing-section { padding: 5.5rem 2rem 6rem; }
  .pricing-inner { max-width: 920px; margin: 0 auto; }
  .pricing-inner--consult { max-width: 1080px; margin-top: 3.5rem; }
