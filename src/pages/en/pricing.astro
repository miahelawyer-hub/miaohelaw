    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(237, 232, 223, 0.35);
    box-shadow: 0 16px 48px rgba(44, 36, 24, 0.18);
    min-height: 240px;
    height: 100%;
    max-height: 420px;
  }
  .consult-intro-visual-frame img {
    width: 100%;
    height: 100%;
    min-height: 240px;
    object-fit: cover;
    display: block;
  }
  .consult-intro-slide {
    opacity: 0;
    transition: transform 0.7s ease-out, opacity 0.7s ease-out;
