    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 0 auto;
  }
  .page-hero--pricing .page-label {
    color: rgba(232, 201, 164, 0.95);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
  }
