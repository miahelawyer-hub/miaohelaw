  <style>
    * { box-sizing: border-box; }
    body { background: var(--bg); margin: 0; }
    .page-hero { background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0,0,0,0.35); padding: 3rem 1.5rem 2.5rem; text-align: center; }
