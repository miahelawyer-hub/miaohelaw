    .btn-outline { background: transparent; color: white; border: 2px solid white; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.95rem; }
    .container { max-width: 900px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .section-title { color: var(--text-heading); font-size: 1.25rem; margin: 2.5rem 0 1.25rem; padding-bottom: 0.4rem; border-bottom: 2px solid #D4A853; }
    .prose { color: #4A2C1A; font-size: 0.95rem; line-height: 1.8; margin-bottom: 1.25rem; }
    .prose strong { color: var(--text-heading); }
    .insight-box { background: #FDF6EC; border-left: 4px solid #D4A853; border-radius: 0 8px 8px 0; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
    .insight-box p { color: #4A2C1A; font-size: 0.92rem; line-height: 1.75; margin: 0; }
