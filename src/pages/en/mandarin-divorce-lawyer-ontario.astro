    .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e8e0d5; border: 1px solid #e8e0d5; border-radius: 10px; overflow: hidden; margin: 1.5rem 0 2.5rem; }
    .stat { background: white; padding: 1.1rem 1rem; text-align: center; }
    .stat-num { font-size: 1.5rem; font-weight: 700; color: var(--text-heading); display: block; }
    .stat-label { font-size: 0.75rem; color: #9A8060; margin-top: 0.2rem; }
    .faq-item { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 0.75rem; }
    .faq-item h3 { color: var(--text-heading); font-size: 0.95rem; margin: 0 0 0.5rem; }
    .faq-item p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }
    .final-cta { background: linear-gradient(135deg, #2C1810, #4A2C1A); border-radius: 12px; padding: 2.5rem; text-align: center; margin-top: 3rem; }
