<style>
  main { max-width: 100%; padding: 0; margin: 0; }

  /* Home hero: same court treatment as Chinese / (portrait on /en/about/) */
  .hero--court {
    --court-tan: #b89678;
    --court-tan-hover: #c4a386;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: min(72vh, 620px);
    padding: clamp(3.5rem, 8vw, 5.5rem) 1.5rem;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 0, 0, 0.35);
  }
  .hero-court-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: url('/images/hero-legal-backdrop.png') center 40% / cover no-repeat;
    transform: scale(1.03);
    pointer-events: none;
  }
  .hero-court-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 85% 72% at 50% 42%, rgba(0, 0, 0, 0.42) 0%, transparent 58%),
      linear-gradient(
        165deg,
        rgba(14, 12, 18, 0.76) 0%,
        rgba(22, 18, 16, 0.84) 45%,
        rgba(12, 10, 10, 0.9) 100%
      );
    pointer-events: none;
  }
  .hero-inner--court {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    padding: 0 0.5rem;
  }
  .hero-court-eyebrow {
    margin: 0 0 1rem;
