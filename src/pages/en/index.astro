---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import Footer from '../../components/Footer.astro';
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Miao He — Chinese Family Lawyer Toronto | Ontario & China Dual-Licensed | H. LAW FIRM"
    description="Miao He (何淼) is a dual-licensed family lawyer in Ontario and China, serving the Chinese-Canadian community in the GTA. Divorce litigation, cross-border assets, child custody. Mandarin & English. 647-930-6688."
  />
  <meta name="keywords" content="Chinese family lawyer Toronto,Mandarin divorce lawyer Ontario,dual licensed China Canada lawyer,Markham family lawyer,GTA Chinese divorce lawyer,cross-border asset divorce,family lawyer Markham,Ontario family law Chinese" />
  <meta property="og:title" content="Miao He — Chinese Family Lawyer Toronto | Ontario & China Dual-Licensed" />
  <meta property="og:description" content="Dual-licensed in Ontario and China. Divorce litigation, cross-border assets, child custody. Serving Toronto, Markham, Richmond Hill and all of Ontario. 647-930-6688." />
  <meta property="og:url" content="https://www.miaohelaw.ca/en/" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://www.miaohelaw.ca/en/" />
  <link rel="alternate" hreflang="zh" href="https://www.miaohelaw.ca/" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LegalService",
    "@id": "https://www.miaohelaw.ca/en/#service",
    "name": "Miao He — Chinese Family Lawyer Toronto",
    "url": "https://www.miaohelaw.ca/en/",
    "telephone": "+1-647-930-6688",
    "email": "miao@miaohelaw.ca",
    "provider": {
      "@type": "Person",
      "name": "Miao He",
      "alternateName": ["何淼", "Mia He"],
      "jobTitle": "Family Law Lawyer",
      "knowsLanguage": ["zh-Hans", "en"],
      "hasCredential": [
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Law Society of Ontario — Member #83315K"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "China Bar Association — Licensed"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Mediation Certificate"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Expert Witness — Chinese Family Law & Marriage Law"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Notary Public — Ontario"}
      ]
    },
    "serviceType": ["Divorce Litigation", "Cross-Border Asset Division", "Child Custody", "Spousal Support", "Domestic Contracts", "Mediation"],
    "areaServed": {"@type": "Province", "name": "Ontario"},
    "inLanguage": ["zh-Hans", "en"]
  }
  </script>
</head>
<body>
  <HeaderEn />
  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badge">Ontario & China Bar Licensed · Dual-Licensed Family Lawyer</div>
          <h1>Miao He <span class="chinese">何淼</span></h1>
          <p class="hero-title">Barrister & Solicitor · Ontario Family Law</p>
          <p class="hero-subtitle">GTA Chinese Community · Dual-Licensed · Negotiation · Mediation · Litigation</p>
          <p class="hero-desc">Bilingual family law services in Mandarin and English. Serving Toronto, Markham, Richmond Hill, Mississauga and all of Ontario.</p>
          <div class="hero-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688 · Book a Consultation</a>
            <a href="mailto:miao@miaohelaw.ca" class="btn-secondary">Email Us</a>
          </div>
          <p class="hero-note">Now accepting new cases · Response within 3 business days</p>
          <p class="hero-fee">Initial consultation 30 min · $220 + HST</p>
        </div>
        <div class="hero-photo">
          <img src="/miao-he-lawyer.jpeg" alt="Miao He — Ontario Family Law Lawyer" />
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats">
      <div class="stat-item">
        <div class="stat-number">15+</div>
        <div class="stat-label">Years of Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">20+</div>
        <div class="stat-label">Court Hours / Month</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">200+</div>
        <div class="stat-label">Consultations / Year</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">2</div>
        <div class="stat-label">Bar Licences — Ontario & China</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">🎓</div>
        <div class="stat-label">Expert Witness — Chinese Family Law</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">📋</div>
        <div class="stat-label">Notary Public · Ontario</div>
      </div>
    </section>

    <!-- Practice Areas -->
    <section class="areas">
      <h2>Family Law Services</h2>
      <div class="areas-grid">
        <div class="area-card area-family">
          <div class="area-num">01</div>
          <h3>Divorce Litigation</h3>
          <p>High-conflict divorce litigation at the Ontario Superior Court. 15+ years of experience, 20+ court hours per month.</p>
          <a href="/en/family-law/divorce-litigation" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-re">
          <div class="area-num">02</div>
          <h3>Cross-Border Asset Division</h3>
          <p>Tracing assets held in China — real estate, company shares, family trusts. Hidden asset investigation. CBV valuation disputes.</p>
          <a href="/en/family-law/cross-border-assets" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-civil">
          <div class="area-num">03</div>
          <h3>Child Custody & Access</h3>
          <p>Custody disputes, CAS intervention response, emergency motions, international relocation and Hague Convention matters.</p>
          <a href="/en/family-law/child-custody" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-sc">
          <div class="area-num">04</div>
          <h3>Spousal & Child Support</h3>
          <p>Hidden income investigation, self-employment income attribution, overseas income tracing, FRO enforcement and variation.</p>
          <a href="/en/family-law/support" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-family">
          <div class="area-num">05</div>
          <h3>Domestic Contracts</h3>
          <p>Marriage contracts, separation agreements, cohabitation agreements and ILA certificates — drafted from a litigator's perspective.</p>
          <a href="/en/family-law/domestic-contracts" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-civil">
          <div class="area-num">07</div>
          <h3>Common-Law Rights</h3>
          <p>Cohabitation agreement drafting, property disputes on separation, Unjust Enrichment claims, Spousal Support applications. Cohabitation is not marriage.</p>
          <a href="/en/family-law/domestic-contracts" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-re">
          <div class="area-num">06</div>
          <h3>Mediation & ADR</h3>
          <p>Certified mediator. Strategic out-of-court settlement, mediation-arbitration, JRP representation. $1M+ settlement achieved.</p>
          <a href="/en/family-law/mediation" class="area-link">Learn More →</a>
        </div>
        <div class="area-card area-family">
          <div class="area-num">08</div>
          <h3>Smart Advocacy</h3>
          <p>Every case evaluated through a litigator's lens. Maximum leverage at the negotiation table — full courtroom representation when it counts.</p>
          <a href="/en/smart-advocacy" class="area-link">Learn More →</a>
        </div>
      </div>
    </section>

    <!-- Case Results -->
    <section class="results-section">
      <div class="results-inner">
        <div class="results-label">VERIFIED OUTCOMES</div>
        <h2>Case Results</h2>
        <div class="results-grid">
          <div class="result-card">
            <div class="result-number">$300,000+</div>
            <div class="result-desc">Cross-Border Asset Recovery</div>
          </div>
          <div class="result-card">
            <div class="result-number">$500,000+</div>
            <div class="result-desc">Agreement Value Protected</div>
          </div>
          <div class="result-card">
            <div class="result-number">$400,000</div>
            <div class="result-desc">Saved via Financial Error Discovery</div>
          </div>
          <div class="result-card">
            <div class="result-number">$1M+</div>
            <div class="result-desc">Mediation Settlement Achieved</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Case -->
    <section class="case-section">
      <div class="case-label">VERIFIED COURT RECORD · CANLII</div>
      <h2>Yang v. Li, 2024 ONSC 4801</h2>
      <p>Eight simultaneous claims — including a Chartered Business Valuator (CBV) business valuation dispute — defeated at motion. Significant costs award granted for lack of candour. Appeal dismissed unanimously by three Divisional Court judges.</p>
      <blockquote>
        <p>"The motion for leave to appeal the interlocutory decision of Boucher J. dated July 22, 2024 is dismissed. There shall be no order of costs."</p>
        <cite>— Backhouse J., D.L. Corbett J., O'Brien J. · Ontario Divisional Court · September 4, 2024</cite>
      </blockquote>
      <a href="https://www.canlii.org/en/on/onscdc/doc/2024/2024onsc4801/2024onsc4801.html" target="_blank" class="case-link">Verify on CanLII →</a>
    </section>

    <!-- Testimonials -->
    <section class="testimonials-section">
      <div class="testimonials-inner">
        <h2>Client Reviews</h2>
        <p class="testimonials-sub">Real client feedback · Google reviews and direct testimonials</p>
        <div class="testimonials-grid">
          <div class="testimonial-card">
            <div class="testimonial-quote">"</div>
            <p>Miao He handled a very complex cross-border asset case for me. My ex-spouse held multiple properties and company shares in China. She successfully traced and recovered the assets. Professional, patient, and fully bilingual.</p>
            <div class="testimonial-meta">
              <span class="testimonial-tag">[Cross-Border Assets]</span>
              <span class="testimonial-author">— Ms. Zhang, Toronto · 2024</span>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-quote">"</div>
            <p>When CAS got involved, I had no idea what to do. Miao He stepped in immediately and helped keep my child at home. She knows Ontario family law inside out and is a very effective advocate in court.</p>
            <div class="testimonial-meta">
              <span class="testimonial-tag">[Child Custody]</span>
              <span class="testimonial-author">— Mr. Li, Markham · 2024</span>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-quote">"</div>
            <p>The marriage contract drafting was incredibly thorough — she anticipated issues from a litigator's perspective that we never would have thought of. Bilingual service meant my parents could fully understand the agreement too.</p>
            <div class="testimonial-meta">
              <span class="testimonial-tag">[Marriage Contract]</span>
              <span class="testimonial-author">— Mr. Wang, Richmond Hill · 2025</span>
            </div>
          </div>
        </div>
        <div style="text-align:center; margin-top: 2rem;">
          <a href="/en/testimonials" class="btn-secondary">View All Reviews →</a>
        </div>
      </div>
    </section>

    <!-- Videos -->
    <section class="video-section">
      <h2>Legal Insights · Videos</h2>
      <p class="video-sub">Watch Miao He explain Ontario family law in Mandarin and English.</p>
      <div class="video-grid">
        <div class="video-item">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/YhOVZxqwD_k" title="Ontario Family Law Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
        <div class="video-item">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/86ULSZ6-KF8" title="Ontario Family Law Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
        <div class="video-item">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/ijZ7E901pXU" title="Ontario Family Law Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top: 2rem;">
        <a href="https://youtube.com/channel/UCLtXNA90GpKWbt6k-nOgL7w" target="_blank" class="btn-secondary">View All Videos on YouTube →</a>
      </div>
    </section>

    <!-- Blog -->
    <section class="blog-section">
      <h2>Latest Articles</h2>
      <p class="blog-sub">Practical legal insights on Ontario family law — in English and Mandarin.</p>
      <a href="/en/blog" class="btn-secondary">View All Articles →</a>
    </section>

    <!-- CTA -->
    <section class="contact-cta">
      <h2>Ready to speak with Miao He?</h2>
      <p>Bilingual service in Mandarin and English · Serving Toronto, Markham, Richmond Hill, Mississauga and all of Ontario</p>
      <div class="fee-notice">Initial consultation 30 min · $220 + HST</div>
      <div class="cta-actions">
        <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
        <a href="mailto:miao@miaohelaw.ca" class="btn-secondary">miao@miaohelaw.ca</a>
      </div>
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
  main { max-width: 100%; padding: 0; margin: 0; }

  .hero { background: #FDFBF7; padding: 5rem 2rem 4rem; border-bottom: 1px solid #EDE8DF; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; gap: 3rem; }
  .hero-content { flex: 1; }
  .hero-photo { flex: 0 0 320px; display: flex; align-items: flex-end; }
  .hero-photo img { width: 100%; height: 480px; object-fit: cover; object-position: top center; border-radius: 12px; display: block; }
  .hero-badge { display: inline-block; background: #F5EFE0; color: #7A5A1A; font-size: 0.75rem; letter-spacing: 0.05em; padding: 5px 16px; border-radius: 20px; margin-bottom: 1.5rem; border: 1px solid #E8D9B8; }
  .hero h1 { font-family: 'Georgia', serif; font-size: 3.5rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; line-height: 1.1; }
  .chinese { color: #7A5A1A; }
  .hero-title { font-size: 1rem; color: #6B5A3A; margin-bottom: 0.4rem; font-weight: 400; }
  .hero-subtitle { font-size: 0.9rem; color: #7A5A1A; margin-bottom: 0.75rem; font-weight: 500; letter-spacing: 0.02em; }
  .hero-desc { font-size: 0.95rem; color: #8A7A5A; max-width: 540px; margin: 0 0 2rem; line-height: 1.7; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-note { margin-top: 1rem; font-size: 0.85rem; color: #7A5A1A; font-weight: 600; background: #F5EFE0; display: inline-block; padding: 0.4rem 1rem; border-radius: 20px; border: 1px solid #E8D9B8; }
  .hero-fee { margin-top: 0.5rem; font-size: 0.85rem; color: #185FA5; font-weight: 600; background: #EEF4FF; display: inline-block; padding: 0.4rem 1rem; border-radius: 20px; border: 1px solid #C5D8F5; }

  .btn-primary { background: #7A5A1A; color: #FDFBF7; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  .btn-primary:hover { background: #4A3A0A; }
  .btn-secondary { background: transparent; color: #7A5A1A; padding: 0.75rem 1.75rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; border: 1px solid #7A5A1A; }
  .btn-secondary:hover { background: #F5EFE0; }

  .stats { display: grid; grid-template-columns: repeat(6, 1fr); background: #2C2418; }
  .stat-item { padding: 2rem 1rem; text-align: center; border-right: 1px solid #3A3020; }
  .stat-item:last-child { border-right: none; }
  .stat-number { font-size: 2.25rem; font-weight: 500; color: #FAC775; margin-bottom: 0.4rem; }
  .stat-label { font-size: 0.75rem; color: #9A8060; line-height: 1.4; }

  .areas { padding: 4rem 2rem; max-width: 960px; margin: 0 auto; }
  .areas h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 2rem; }
  .areas-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .area-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 1.5rem; border-left: 4px solid; }
  .area-family { border-left-color: #7A5A1A; }
  .area-re { border-left-color: #185FA5; }
  .area-civil { border-left-color: #854F0B; }
  .area-sc { border-left-color: #993C1D; }
  .area-num { font-size: 0.7rem; color: #9A8060; letter-spacing: 0.1em; margin-bottom: 0.5rem; }
  .area-card h3 { font-size: 1rem; font-weight: 500; color: #1A1208; margin-bottom: 0.5rem; }
  .area-card p { font-size: 0.85rem; color: #6B5A3A; line-height: 1.6; margin-bottom: 1rem; }
  .area-link { font-size: 0.8rem; color: #7A5A1A; text-decoration: none; font-weight: 500; }
  .area-link:hover { text-decoration: underline; }

  .results-section { background: #F5EFE0; border-top: 1px solid #EDE8DF; border-bottom: 1px solid #EDE8DF; padding: 4rem 2rem; }
  .results-inner { max-width: 960px; margin: 0 auto; text-align: center; }
  .results-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 0.75rem; }
  .results-inner h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 2rem; }
  .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .result-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 1.5rem 1rem; border-top: 4px solid #7A5A1A; }
  .result-number { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #7A5A1A; margin-bottom: 0.5rem; }
  .result-desc { font-size: 0.8rem; color: #6B5A3A; line-height: 1.5; }

  .case-section { background: #2C2418; padding: 4rem 2rem; text-align: center; }
  .case-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 1rem; }
  .case-section h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #FAC775; margin-bottom: 1rem; }
  .case-section p { color: #C4AA80; max-width: 640px; margin: 0 auto 1.5rem; font-size: 0.9rem; line-height: 1.7; }
  .case-section blockquote { background: rgba(255,255,255,0.05); border: 1px solid rgba(250,199,117,0.2); border-left: 4px solid #FAC775; border-radius: 6px; padding: 1.25rem 1.5rem; max-width: 640px; margin: 0 auto 1.5rem; text-align: left; }
  .case-section blockquote p { font-style: italic; color: #E8D4A8; margin-bottom: 0.5rem; font-size: 0.9rem; }
  .case-section blockquote cite { font-size: 0.75rem; color: #9A8060; font-style: normal; }
  .case-link { color: #FAC775; text-decoration: none; font-size: 0.85rem; font-weight: 500; }
  .case-link:hover { text-decoration: underline; }

  .testimonials-section { padding: 4rem 2rem; border-top: 1px solid #EDE8DF; }
  .testimonials-inner { max-width: 960px; margin: 0 auto; text-align: center; }
  .testimonials-inner h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.5rem; }
  .testimonials-sub { color: #9A8060; font-size: 0.85rem; margin-bottom: 2rem; }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; text-align: left; }
  .testimonial-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 1.5rem; }
  .testimonial-quote { font-family: 'Georgia', serif; font-size: 3rem; color: #E8D9B8; line-height: 1; margin-bottom: 0.5rem; }
  .testimonial-card p { font-size: 0.85rem; color: #4A3A2A; line-height: 1.7; margin-bottom: 1rem; }
  .testimonial-meta { display: flex; flex-direction: column; gap: 0.25rem; }
  .testimonial-tag { font-size: 0.75rem; color: #7A5A1A; font-weight: 600; background: #F5EFE0; display: inline-block; padding: 2px 8px; border-radius: 4px; width: fit-content; }
  .testimonial-author { font-size: 0.75rem; color: #9A8060; }

  .video-section { padding: 4rem 2rem; max-width: 960px; margin: 0 auto; border-top: 1px solid #EDE8DF; }
  .video-section h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .video-sub { color: #6B5A3A; font-size: 0.9rem; margin-bottom: 2rem; }
  .video-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px; border: 1px solid #EDE8DF; }
  .video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }

  .blog-section { padding: 4rem 2rem; max-width: 960px; margin: 0 auto; text-align: center; border-top: 1px solid #EDE8DF; }
  .blog-section h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .blog-sub { color: #6B5A3A; font-size: 0.9rem; margin-bottom: 1.5rem; }

  .contact-cta { background: #F5EFE0; border-top: 1px solid #EDE8DF; padding: 4rem 2rem; text-align: center; }
  .contact-cta h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .contact-cta p { color: #6B5A3A; font-size: 0.9rem; max-width: 540px; margin: 0 auto 1rem; line-height: 1.7; }
  .fee-notice { display: inline-block; background: rgba(122,90,26,0.12); color: #7A5A1A; font-size: 0.85rem; font-weight: 500; padding: 0.5rem 1.25rem; border-radius: 20px; margin-bottom: 1.5rem; border: 1px solid rgba(122,90,26,0.25); }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hero-inner { flex-direction: column-reverse; gap: 1.5rem; }
    .hero-photo { flex: none; width: 100%; }
    .hero-photo img { height: 320px; }
    .hero h1 { font-size: 2.5rem; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .areas-grid { grid-template-columns: 1fr; }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr; }
    .video-grid { grid-template-columns: 1fr; }
  }
</style>
