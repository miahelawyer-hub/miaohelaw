    background: linear-gradient(135deg, rgba(250,199,117,0.92), rgba(212,168,83,0.92));
    color: #2C2418;
    box-shadow: 0 18px 30px rgba(44,24,16,0.22), inset 0 1px 0 rgba(255,255,255,0.65);
