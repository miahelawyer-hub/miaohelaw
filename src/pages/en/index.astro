    border-bottom: 1px solid rgba(0,0,0,0.42);
    box-shadow:
      0 14px 34px rgba(0,0,0,0.18),
      inset 0 1px 0 rgba(255,255,255,0.08),
      inset 0 -8px 16px rgba(0,0,0,0.28);
    overflow: hidden;
  }
  .stats::before{
    content:"";
    position:absolute;
    inset:0;
    background:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0 1px, rgba(255,255,255,0) 1px 14px),
      repeating-linear-gradient(0deg, rgba(0,0,0,0.06) 0 1px, rgba(0,0,0,0) 1px 10px);
    opacity: 0.20;
    pointer-events:none;
    mix-blend-mode: overlay;
  }
  .stats::after{
    content:"";
    position:absolute;
    left:0; right:0; top:0;
    height: 2px;
    background: linear-gradient(90deg, rgba(250,199,117,0), rgba(250,199,117,0.55), rgba(250,199,117,0));
