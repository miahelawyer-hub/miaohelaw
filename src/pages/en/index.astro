    border-radius: 14px 0 0 14px;
    background: linear-gradient(180deg, rgba(250,199,117,0.95), rgba(212,168,83,0.55));
  }
  .case-section blockquote p{
    font-style: italic;
    color: rgba(255,240,206,0.92);
    margin-bottom: 0.85rem;
    font-size: 0.95rem;
    line-height: 1.85;
  }
  .case-section blockquote cite{
    display: block;
    font-size: 0.78rem;
    color: rgba(232,217,184,0.70);
    font-style: normal;
    letter-spacing: 0.02em;
  }
  .case-link{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    color: #2C2418;
    background: linear-gradient(135deg, #FAC775, #D4A853);
    box-shadow: 0 16px 26px rgba(0,0,0,0.25);
    transition: transform 0.15s ease, filter 0.15s ease, box-shadow 0.15s ease;
  }
  .case-link:hover{
    transform: translateY(-1px);
    filter: brightness(1.02);
    box-shadow: 0 20px 34px rgba(0,0,0,0.28);
  }

