  .stats{
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    position: relative;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.02) 28%, transparent 62%),
      radial-gradient(760px 96px at 50% -8%, rgba(250,199,117,0.11), rgba(250,199,117,0) 58%),
      linear-gradient(180deg, #2a241b 0%, #221c15 48%, #1b1610 100%);
