      linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    border: 1px solid rgba(250,199,117,0.22);
    border-radius: 14px;
    padding: 1.6rem 1.65rem;
    max-width: 760px;
    margin: 0 auto 1.75rem;
