  .results-section { background: #F5EFE0; border-top: 1px solid #EDE8DF; border-bottom: 1px solid #EDE8DF; padding: 4rem 2rem; }
  .results-inner { max-width: 960px; margin: 0 auto; text-align: center; }
  .results-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 0.75rem; }
  .results-inner h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: var(--text-heading); margin-bottom: 2rem; }
  .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  /* Remove the "background board" card; keep only text + platform */
  .result-card{
    position: relative;
    background: transparent;
    border: 0;
    border-radius: 0;
    padding: 1.65rem 0.25rem 1.1rem;
    box-shadow: none;
  }
  .result-number{
    position: relative;
    display: inline-block;
    font-family: 'Georgia', serif;
    font-size: 1.75rem;
    font-weight: 600;
    font-style: italic;
    margin-bottom: 0.9rem;
    letter-spacing: 0.01em;
    --baseY: -2px;
    transform: translateY(var(--baseY)) translateZ(0);
    padding-bottom: 3.1rem; /* reserve room for larger platform + text */
    --dx: 8px;
    --dy: 8px;
    transform-origin: 50% 100%;
  }
  @keyframes result-pop{
    0%   { transform: translateY(var(--baseY)) scale(1) translateZ(0); }
    35%  { transform: translateY(calc(var(--baseY) - 10px)) scale(1.02) translateZ(0); }
    70%  { transform: translateY(calc(var(--baseY) + 2px)) scale(0.995) translateZ(0); }
    100% { transform: translateY(var(--baseY)) scale(1) translateZ(0); }
  }
  .result-number.is-pop{
    animation: result-pop 520ms cubic-bezier(.2,.8,.2,1);
  }
  @keyframes digit-pop{
    0%   { transform: translateY(0) scale(1); filter: brightness(1); }
    35%  { transform: translateY(-10px) scale(1.03); filter: brightness(1.04); }
    70%  { transform: translateY(2px) scale(0.995); filter: brightness(1.01); }
    100% { transform: translateY(0) scale(1); filter: brightness(1); }
  }
  .result-front .d{
    display: inline-block;
    will-change: transform;
  }
  .result-front.digits-pop .d{
    animation: digit-pop 520ms cubic-bezier(.2,.8,.2,1) both;
  }
  .result-front.digits-pop .d{ animation-delay: calc(var(--i, 0) * 70ms); }
  /* Extruded depth: subtle, premium */
  .result-number::before{
    content: attr(data-text);
    position:absolute;
    left: 0;
    top: 0;
    transform: translate(var(--dx), var(--dy));
    color: rgba(74,58,10,0.18);
    text-shadow:
      0 1px 0 rgba(122,90,26,0.22),
      1px 2px 0 rgba(122,90,26,0.20),
      2px 3px 0 rgba(44,24,16,0.12),
      0 18px 22px rgba(44,24,16,0.16);
    filter: blur(0.1px);
    z-index: 0;
    pointer-events:none;
  }
  .result-front{
    position: relative;
    z-index: 2;
    display: inline-block;
    color: #7A5A1A;
    text-shadow:
      0 1px 0 rgba(255,255,255,0.70),
      0 12px 22px rgba(44,24,16,0.18);
  }
  /* Isometric platform under number */
  .result-number::after{
    content:"";
    position:absolute;
    left: 50%;
    top: 46%;
    transform: translateX(-50%) skewX(-12deg);
    width: clamp(220px, 130%, 340px);
    height: 86px;
    border-radius: 12px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(253,251,247,0.72)),
      radial-gradient(220px 42px at 50% 22%, rgba(250,199,117,0.28), rgba(250,199,117,0));
    border: 1px solid rgba(232,217,184,0.98);
    box-shadow:
      0 26px 36px rgba(44,24,16,0.16),
      inset 0 1px 0 rgba(255,255,255,0.85),
      inset 0 -14px 18px rgba(44,24,16,0.10);
    clip-path: polygon(7% 10%, 93% 10%, 100% 100%, 0% 100%);
    opacity: 0.98;
    z-index: 1;
    pointer-events:none;
  }
  .result-desc{
    position: relative;
    z-index: 2;
    display: block;
    margin-top: -2.25rem; /* pull onto the platform */
    padding: 0 0.75rem;
    font-size: 0.76rem;
    color: #5A4518;
    line-height: 1.5;
    font-style: italic;
    text-align: center;
    text-shadow: 0 1px 0 rgba(255,255,255,0.55);
    max-width: 22ch;
    margin-left: auto;
    margin-right: auto;
  }

  .case-section{
