---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import HeaderEn from '../../../components/HeaderEn.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_LAST_UPDATED_EN, SITE_URL } from '../../../consts';

const posts = (await getCollection('blog-en')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const totalPosts = posts.length;
const totalPages = Math.max(1, Math.ceil(totalPosts / 10));
const pageSmallCards = posts.slice(1, 10);
const schemaPosts = posts.length > 0 ? [posts[0], ...pageSmallCards] : [];

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: schemaPosts.map((post, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}/en/blog/${post.id}/`,
    name: post.data.title,
  })),
};

const canonicalUrl = `${SITE_URL}/en/blog/`;
const nextUrl = totalPages > 1 ? `${SITE_URL}/en/blog/page/2/` : null;

function formatDate(date) {
  return new Date(date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Blog | Miao He — Ontario Family Law Lawyer | Divorce · Custody · Property"
    description="Ontario family law articles by Miao He: divorce, child custody, property division, marriage contracts, cross-border assets. Bilingual Mandarin and English. 647-930-6688."
  />
  <meta name="keywords" content="Ontario family law blog,divorce lawyer Toronto articles,family law articles,Chinese family lawyer blog,Miao He lawyer,cross-border divorce Canada" />
  <meta property="og:title" content="Blog | Miao He — Ontario Family Law Lawyer" />
  <meta property="og:description" content="Ontario family law articles by Miao He: divorce, child custody, property division, marriage contracts, cross-border assets. Bilingual Mandarin and English. 647-930-6688." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:locale:alternate" content="zh_CN" />
  {nextUrl && <link rel="next" href={nextUrl} />}
  <link rel="alternate" hreflang="zh-CN" href="https://www.miaohelaw.ca/blog/" />
  <link rel="alternate" hreflang="en" href="https://www.miaohelaw.ca/en/blog/" />
  <link rel="alternate" hreflang="x-default" href="https://www.miaohelaw.ca/en/blog/" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://www.miaohelaw.ca/en/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://www.miaohelaw.ca/en/blog/"}
    ]
  }</script>
  <style is:global>
    * { box-sizing: border-box; }
    body { background: var(--bg); margin: 0; font-family: Georgia, serif; }
    .page-hero { background: var(--hero-legal-top-background); border-bottom: 1px solid rgba(0,0,0,0.35); padding: 3rem 1.5rem 2.5rem; }
    .page-hero .inner { max-width: 1100px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.6rem; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 0.4rem; }
    .page-hero .hero-stat { color: #F5E6C8; margin: 0 0 0.45rem; font-size: 0.96rem; font-weight: 600; letter-spacing: 0.02em; }
    .page-hero .hero-sub { color: #D4A853; margin: 0; font-size: 0.92rem; }
    .main-wrap { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
    .blog-search { display: flex; gap: 0.75rem; align-items: center; margin: 0 0 1.25rem; padding: 0.85rem; border-radius: 14px; background: rgba(255,255,255,0.75); border: 1px solid rgba(237,232,223,0.95); box-shadow: 0 1px 0 rgba(44,24,16,0.02); }
    .blog-search-input{ flex: 1; min-width: 0; border: 1px solid rgba(212,168,83,0.28); background: #fff; color: var(--text-heading); border-radius: 12px; padding: 0.85rem 0.95rem; font-size: 1rem; line-height: 1.2; outline: none; }
    .blog-search-input:focus{ border-color: rgba(212,168,83,0.6); box-shadow: 0 0 0 4px rgba(212,168,83,0.18); }
    .blog-search-clear{ flex: none; background: transparent; border: 1px solid rgba(44,24,16,0.22); color: #4A2C1A; border-radius: 12px; padding: 0.7rem 0.9rem; font-size: 0.92rem; cursor: pointer; white-space: nowrap; }
    .blog-search-clear:hover{ border-color: rgba(212,168,83,0.6); background: rgba(212,168,83,0.08); }
    .blog-search-meta{ margin: 0 0 1.25rem; color: #6b5a48; font-size: 0.88rem; line-height: 1.5; min-height: 1.35em; }
    .blog-search-results { margin: 0 0 1.25rem; }
    .blog-search-results ul { list-style: none; margin: 0; padding: 0; }
    .blog-search-results li { margin: 0 0 0.5rem; }
    .blog-search-results a { display: block; padding: 0.65rem 0.85rem; border-radius: 10px; background: rgba(255,255,255,0.9); border: 1px solid rgba(237,232,223,0.95); color: var(--text-heading); text-decoration: none; font-size: 0.92rem; }
    .blog-search-results a:hover { border-color: rgba(212,168,83,0.45); }
    .pagination { display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem 0.65rem; margin: 0 0 1.5rem; font-size: 0.88rem; }
    .pagination a, .pagination span.current { display: inline-flex; align-items: center; justify-content: center; min-width: 2.25rem; padding: 0.45rem 0.55rem; border-radius: 8px; text-decoration: none; border: 1px solid rgba(44,24,16,0.12); color: #4A2C1A; background: rgba(255,255,255,0.85); }
    .pagination a:hover { border-color: rgba(212,168,83,0.55); }
    .pagination span.current { font-weight: 700; border-color: rgba(212,168,83,0.55); background: rgba(212,168,83,0.12); }
    .blog-listing--searching .featured-card,
    .blog-listing--searching .grid { display: none !important; }
    .sr-only{ position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
    .featured-card { display: grid; grid-template-columns: 280px 1fr; background: white; border-radius: 12px; box-shadow: 0 2px 16px rgba(44,24,16,0.09); overflow: hidden; margin-bottom: 2rem; text-decoration: none; border: 1px solid #e8e0d5; transition: box-shadow 0.2s; }
    .featured-card:hover { box-shadow: 0 6px 28px rgba(44,24,16,0.14); }
    .featured-left { background: linear-gradient(160deg, #2C1810 0%, #4A2C1A 60%, #3a2015 100%); padding: 2rem 1.75rem; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
    .featured-left::before { content: 'LAW'; position: absolute; right: -0.5rem; bottom: -0.5rem; font-size: 5rem; color: rgba(212,168,83,0.07); font-weight: 900; line-height: 1; pointer-events: none; }
    .featured-tag { display: inline-block; background: rgba(212,168,83,0.15); border: 1px solid rgba(212,168,83,0.4); color: #D4A853; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; padding: 0.3rem 0.75rem; border-radius: 20px; width: fit-content; }
    .featured-quote { color: rgba(255,255,255,0.75); font-size: 0.85rem; line-height: 1.7; margin: 1.25rem 0 0; }
    .featured-quote strong { color: #D4A853; display: block; font-size: 1rem; margin-bottom: 0.4rem; }
    .featured-author { color: rgba(255,255,255,0.45); font-size: 0.72rem; margin-top: 1.5rem; letter-spacing: 0.04em; }
    .featured-right { padding: 2rem 2rem 2rem 1.75rem; display: flex; flex-direction: column; justify-content: center; }
    .featured-date { color: #9A8060; font-size: 0.78rem; margin: 0 0 0.6rem; }
    .featured-title { color: var(--text-heading); font-size: 1.2rem; font-weight: 700; line-height: 1.4; margin: 0 0 0.85rem; }
    .featured-desc { color: #4A2C1A; font-size: 0.9rem; line-height: 1.75; margin: 0 0 1.25rem; }
    .featured-more { display: inline-flex; align-items: center; gap: 0.4rem; color: white; background: linear-gradient(135deg, #2C1810, #4A2C1A); padding: 0.55rem 1.2rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600; width: fit-content; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 1.5rem; }
    .card { background: white; border-radius: 10px; border: 1px solid #e8e0d5; box-shadow: 0 2px 8px rgba(44,24,16,0.05); padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; transition: box-shadow 0.2s, border-color 0.2s; }
    .card:hover { box-shadow: 0 4px 18px rgba(44,24,16,0.11); border-color: #D4A853; }
    .card-date { color: #9A8060; font-size: 0.75rem; margin: 0 0 0.5rem; }
    .card-title { color: var(--text-heading); font-size: 0.95rem; font-weight: 600; line-height: 1.45; margin: 0 0 0.65rem; flex: 1; }
    .card-desc { color: #6B5040; font-size: 0.82rem; line-height: 1.6; margin: 0 0 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 0.75rem; border-top: 1px solid #f0ebe3; }
    .card-arrow { color: #D4A853; font-size: 1rem; }
    .cta-box {
      background: #1c2b3f;
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 14px 32px rgba(12, 22, 38, 0.35);
    }
    .cta-box h2 { color: #fac775; margin: 0 0 0.5rem; font-size: 1.1rem; }
    .cta-box p { color: #d4cfc3; margin: 0 0 1.25rem; font-size: 0.9rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-gold {
      background: #c9a168;
      color: #1c2b3f;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      transition: filter 0.15s ease;
    }
    .btn-gold:hover { filter: brightness(1.05); }
    .btn-outline {
      background: transparent;
      color: rgba(248, 250, 252, 0.95);
      border: 1px solid #c9a168;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .btn-outline:hover {
      background: rgba(201, 161, 104, 0.14);
      border-color: #d4b47e;
    }
    @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } .featured-card { grid-template-columns: 1fr; } .featured-left { padding: 1.5rem; } }
    @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } .main-wrap { padding: 1.5rem 1rem 3rem; } .featured-right { padding: 1.5rem; } }
  </style>
</head>
<body>
  <HeaderEn />
  <main class="blog-listing-root" id="blog-listing-root">
    <div class="page-hero">
      <div class="inner">
        <p class="breadcrumb"><a href="/en/">Home</a> › Blog</p>
        <h1>Family Law Articles</h1>
        <p class="hero-stat">{totalPosts} {totalPosts === 1 ? 'blog article' : 'blog articles'} · Page 1 of {totalPages}</p>
        <p class="hero-sub">Written by Miao He · Bilingual Mandarin & English · 647-930-6688</p>
        <p class="page-last-updated page-last-updated--gradient">Page last updated: {SITE_LAST_UPDATED_EN}</p>
      </div>
    </div>
    <div class="main-wrap">
      <div
        class="blog-search"
        role="search"
        aria-label="Blog search"
        data-search-json="/en/blog-search.json"
        data-list-home="/en/blog/"
      >
        <label class="sr-only" for="blog-search-input">Search articles</label>
        <input
          id="blog-search-input"
          class="blog-search-input"
          type="search"
          placeholder="Search keywords (e.g., divorce, custody, support, prenup)"
          autocomplete="off"
        />
        <button class="blog-search-clear" id="blog-search-clear" type="button" aria-label="Clear search">Clear</button>
      </div>
      <p class="blog-search-meta" id="blog-search-meta" aria-live="polite"></p>
      <div class="blog-search-results" id="blog-search-results" hidden></div>

      <nav class="pagination" aria-label="Blog pagination">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) =>
          num === 1 ? (
            <span class="current" aria-current="page">{num}</span>
          ) : (
            <a href={`/en/blog/page/${num}/`}>{num}</a>
          )
        )}
      </nav>

      {posts.length > 0 && (
        <a
          href={`/en/blog/${posts[0].id}/`}
          class="featured-card"
          data-search={`${posts[0].data.title} ${posts[0].data.description} ${(posts[0].data.tags ?? []).join(' ')}`.toLowerCase()}
        >
          <div class="featured-left">
            <div>
              <span class="featured-tag">LATEST ARTICLE</span>
              <p class="featured-quote">
                <strong>Miao He says</strong>
                Understanding the law is the first step to protecting your rights. Every decision deserves to be made with full and accurate information.
              </p>
            </div>
            <p class="featured-author">Miao He · LSO #83315K · Ontario & China Dual-Licensed</p>
          </div>
          <div class="featured-right">
            <p class="featured-date">{formatDate(posts[0].data.pubDate)}</p>
            <p class="featured-title">{posts[0].data.title}</p>
            <p class="featured-desc">{posts[0].data.description}</p>
            <span class="featured-more">Read Article →</span>
          </div>
        </a>
      )}
      <div class="grid" id="post-grid">
        {pageSmallCards.map((post) => (
          <a
            href={`/en/blog/${post.id}/`}
            class="card"
            data-search={`${post.data.title} ${post.data.description} ${(post.data.tags ?? []).join(' ')}`.toLowerCase()}
          >
            <p class="card-date">{formatDate(post.data.pubDate)}</p>
            <p class="card-title">{post.data.title}</p>
            <p class="card-desc">{post.data.description}</p>
            <div class="card-footer">
              <span style="font-size:0.75rem;color:#9A8060;">Miao He</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
      <div class="cta-box">
        <h2>Book an Initial Consultation</h2>
        <p>Miao He · 30-min consultation $220+HST · Mandarin & English · Markham · All of Ontario</p>
        <div class="cta-btns">
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="/en/contact" class="btn-outline">Book Online</a>
        </div>
      </div>
    </div>
  </main>
  <Footer lang="en" />
  <script src="/js/blog-listing.js" defer></script>
</body>
</html>
