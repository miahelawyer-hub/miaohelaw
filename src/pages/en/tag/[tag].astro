---
/* ============================================
 * TAG INTRO MECHANISM (English blog tags)
 * ============================================
 * Intro files live in: src/data/tag-intros-en/{exact tag string}.md
 *
 * Filename must match the tag string exactly (spaces, punctuation, etc.).
 *
 * If a tag has no matching .md file, the tag page still renders
 * (only the intro block below H1 is omitted) — no build error.
 *
 * After publishing posts with new tags:
 *   1. List tags used in blog-en
 *   2. Compare with files under src/data/tag-intros-en/
 *   3. Report gaps; create intro files when needed
 * ============================================ */

import { getCollection } from 'astro:content';
import { isPublishedBlogEnPost } from '../../../lib/blogPublished';
import BaseHead from '../../../components/BaseHead.astro';
import HeaderEn from '../../../components/HeaderEn.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog-en')).filter(isPublishedBlogEnPost);
  const tagMap = new Map();
  for (const post of posts) {
    const tags = post.data.tags || [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag).push(post);
    }
  }
  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { posts, tag },
  }));
}

// Load optional tag intro markdown (raw)
const tagIntroModules = import.meta.glob('../../../data/tag-intros-en/*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

function parseTagIntro(raw) {
  if (!raw) return null;
  const match = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!match) return { frontmatter: {}, body: raw.trim() };
  const frontmatterText = match[1];
  const body = match[2].trim();
  const frontmatter = {};
  frontmatterText.split('\n').forEach((line) => {
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) return;
    const key = line.slice(0, colonIdx).trim();
    let value = line.slice(colonIdx + 1).trim();
    if (
      (value.startsWith('"') && value.endsWith('"')) ||
      (value.startsWith("'") && value.endsWith("'"))
    ) {
      value = value.slice(1, -1);
    }
    frontmatter[key] = value;
  });
  return { frontmatter, body };
}

function renderIntroBody(body) {
  if (!body) return '';
  return body
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .split(/\n\n+/)
    .map((para) => `<p>${para.replace(/\n/g, '<br>')}</p>`)
    .join('');
}

const { tag, posts } = Astro.props;

let tagIntro = null;
const introKey = `../../../data/tag-intros-en/${tag}.md`;
const rawContent = tagIntroModules[introKey];
if (rawContent) {
  tagIntro = parseTagIntro(rawContent);
}

// Index only when this tag is “rescued”: has an intro AND has 2+ posts.
const isRescuedTag = Boolean(tagIntro) && posts.length >= 2;

const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const canonical = `https://www.miaohelaw.ca/en/tag/${tag}/`;

const introFm = tagIntro?.frontmatter ?? {};
const pageTitle = introFm.title ?? `${tag} Hub | Miao He — Ontario Family Lawyer`;
const pageH2 = introFm.h2 ?? null;
const pageDescription =
  introFm.description ??
  `Articles and legal insights on ${tag} by Miao He. Ontario family law, Mandarin & English, 647-930-6688.`;
const schemaName = introFm.schemaName ?? `${tag} | Miao He — Ontario Family Lawyer`;
const schemaDescription =
  introFm.schemaDescription ??
  `Articles and legal insights on ${tag} by Miao He — Ontario family law practice, Mandarin & English.`;

function formatDate(date) {
  return new Date(date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
}

const itemList =
  isRescuedTag
    ? {
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        itemListElement: sorted.map((post, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          url: new URL(`/en/blog/${post.id}/`, Astro.site).href,
          name: post.data.title,
        })),
      }
    : null;

const schema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: schemaName,
    description: schemaDescription,
    url: canonical,
    inLanguage: 'en-CA',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.miaohelaw.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Tags', item: 'https://www.miaohelaw.ca/en/tag/' },
      { '@type': 'ListItem', position: 3, name: tag, item: canonical },
    ],
  },
  ...(itemList ? [itemList] : []),
]);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={pageTitle}
    description={pageDescription}
  />
  {!isRescuedTag && <meta name="robots" content="noindex, follow" />}
  <meta
    name="keywords"
    content={tag + ',Miao He,Ontario family law,Chinese family lawyer,dual-licensed lawyer,LSO 83315K'}
  />
  <meta property="og:title" content={tag + ' | Miao He — Ontario Family Lawyer'} />
  <meta property="og:type" content="website" />
  <script type="application/ld+json" set:html={schema}></script>
  <style>
    body{background:var(--bg);margin:0}
    .hero{background:var(--hero-legal-top-background);border-bottom:1px solid rgba(0,0,0,0.35);padding:2.5rem 1.5rem 2rem;text-align:center}
    .hero h1{color:#fff;font-size:clamp(1.3rem,3vw,1.8rem);margin:0 0 0.5rem}
    .hero p{color:#D4A853;margin:0;font-size:0.9rem}
    .container{max-width:800px;margin:0 auto;padding:2rem 1.5rem}
    .post-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1px;background:#e8e0d5;border:1px solid #e8e0d5;border-radius:12px;overflow:hidden}
    .post-item{background:white}
    .post-link{display:flex;align-items:center;gap:1.25rem;padding:1.25rem 1.5rem;text-decoration:none;transition:background 0.15s}
    .post-link:hover{background:var(--bg)}
    .post-num{font-size:0.75rem;color:#D4A853;font-weight:700;min-width:1.5rem;text-align:right;flex-shrink:0}
    .post-body{flex:1;min-width:0}
    .post-title{color: var(--text-heading);font-size:0.98rem;font-weight:600;line-height:1.45;margin:0 0 0.25rem}
    .post-date{color:#9A8060;font-size:0.78rem;margin:0}
    .post-arrow{color:#D4A853;font-size:0.9rem;flex-shrink:0}
    .cta-box{background:#1c2b3f;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:1.75rem;text-align:center;margin-top:2rem;box-shadow:0 14px 32px rgba(12,22,38,0.35)}
    .cta-box h2{color:#fac775;margin:0 0 0.5rem;font-size:1.1rem}
    .cta-box p{color:#d4cfc3;margin:0 0 1rem;font-size:0.9rem}
    .cta-btns{display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap}
    .btn-gold{background:#c9a168;color:#1c2b3f;padding:0.65rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:700;font-size:0.9rem;transition:filter 0.15s ease}
    .btn-gold:hover{filter:brightness(1.05)}
    .btn-outline{background:transparent;color:rgba(248,250,252,0.95);border:1px solid #c9a168;padding:0.65rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:700;font-size:0.9rem;transition:background 0.15s ease,border-color 0.15s ease}
    .btn-outline:hover{background:rgba(201,161,104,0.14);border-color:#d4b47e}
    .back-link{display:inline-block;color:#9A8060;font-size:0.82rem;text-decoration:none;margin-bottom:1.5rem}
    @media(max-width:600px){.post-link{padding:1rem 1.1rem;gap:0.9rem}.post-num{display:none}}
    /* 正文色与 global.css 中 .hero .page-last-updated 一致；链接与 .hero 底行金色一致 */
    .tag-intro {
      max-width: 760px;
      margin: 1.2em auto 1.5em;
      padding: 0 1em;
      text-align: left;
      line-height: 1.75;
      color: rgba(200, 185, 154, 0.85);
      font-size: 1rem;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    }
    .tag-intro :global(p) {
      margin: 0 0 0.8em;
      color: inherit;
    }
    .tag-intro :global(p:last-child) {
      margin-bottom: 0;
    }
    .tag-intro :global(a) {
      color: #d4a853;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .tag-intro :global(a:hover) {
      color: #f0d592;
    }
  </style>
</head>
<body>
  <HeaderEn />
  <main>
    <div class="hero">
      <h1>{tag}</h1>
      {pageH2 && <h2>{pageH2}</h2>}
      {tagIntro && (
        <div class="tag-intro">
          <div set:html={renderIntroBody(tagIntro.body)}></div>
        </div>
      )}
      <p>Miao He · Mandarin & English · 647-930-6688</p>
    </div>
    <div class="container">
      <a href="/en/blog/" class="back-link">← Back to Blog</a>
      <ul class="post-list">
        {sorted.map((post, i) => (
          <li class="post-item">
            <a href={`/en/blog/${post.id}/`} class="post-link">
              <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="post-body">
                <p class="post-title">{post.data.title}</p>
                <p class="post-date">{formatDate(post.data.pubDate)}</p>
              </div>
              <span class="post-arrow">›</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="cta-box">
        <h2>Book Initial Consultation</h2>
        <p>30 min · $220+HST · Mandarin & English · Markham · Serving Ontario</p>
        <div class="cta-btns">
          <a href="tel:6479306688" class="btn-gold">📞 647-930-6688</a>
          <a href="/en/contact" class="btn-outline">Contact</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
