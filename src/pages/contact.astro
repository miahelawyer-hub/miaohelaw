<style>
  .page-main { max-width: 100%; padding: 0; margin: 0; }

  .page-hero { background: #2C2418; padding: 4rem 2rem; text-align: center; }
  .page-hero-inner { max-width: 760px; margin: 0 auto; }
  .page-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #9A8060; margin-bottom: 1rem; }
  .page-hero h1 { font-family: 'Georgia', serif; font-size: 2.5rem; font-weight: 400; color: #FAC775; margin-bottom: 1rem; }
  .page-hero p { color: #C4AA80; font-size: 0.95rem; line-height: 1.7; max-width: 640px; margin: 0 auto; }

  .contact-section { padding: 4rem 2rem; }
  .contact-inner { max-width: 1060px; margin: 0 auto; }
  .contact-grid { display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start; }

  .contact-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 2rem; margin-bottom: 1.5rem; }
  .contact-card.highlight { background: #2C2418; border-left: 4px solid #FAC775; }
  .contact-card.highlight h2 { font-family: 'Georgia', serif; font-size: 1.4rem; font-weight: 400; color: #FAC775; margin-bottom: 1.25rem; }

  .contact-methods { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .contact-method { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; padding: 0.75rem 1rem; background: rgba(255,255,255,0.06); border-radius: 6px; }
  .contact-method:hover { background: rgba(255,255,255,0.1); }
  .method-icon { font-size: 1.2rem; flex-shrink: 0; }
  .method-label { font-size: 0.75rem; color: #9A8060; margin-bottom: 2px; }
  .method-value { font-size: 1rem; color: #FAC775; font-weight: 500; }

  .cta-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; justify-content: center; background: #7A5A1A; color: #FDFBF7; padding: 0.75rem 1.5rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 600; border: 2px solid #7A5A1A; }
  .btn-primary:hover { background: #4A3A0A; }
  .btn-secondary { display: inline-flex; align-items: center; justify-content: center; background: transparent; color: #FAC775; padding: 0.75rem 1.5rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 600; border: 2px solid #FAC775; }
  .btn-secondary:hover { background: rgba(250,199,117,0.1); }
  .response-note { font-size: 0.8rem; color: #9A8060; margin-top: 1rem; margin-bottom: 0; }

  .services-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 2rem; margin-bottom: 1.5rem; border-left: 4px solid #7A5A1A; }
  .services-card h2 { font-family: 'Georgia', serif; font-size: 1.4rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .services-card p { font-size: 0.9rem; color: #4A3A2A; line-height: 1.7; margin-bottom: 0.75rem; }
  .services-list { padding-left: 1.25rem; margin: 0.75rem 0; }
  .services-list li { font-size: 0.9rem; color: #4A3A2A; line-height: 1.9; }
  .complex-cases { font-size: 0.85rem; color: #6B5A3A; background: #F5EFE0; padding: 0.75rem 1rem; border-radius: 6px; margin-top: 0.75rem; margin-bottom: 0; }

  .faq-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 2rem; border-left: 4px solid #EDE8DF; }
  .faq-card h2 { font-family: 'Georgia', serif; font-size: 1.4rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .faq-card p { font-size: 0.9rem; color: #4A3A2A; line-height: 1.7; margin-bottom: 0.5rem; }
  .faq-list { padding-left: 1.25rem; margin: 0; }
  .faq-list li { font-size: 0.9rem; color: #4A3A2A; line-height: 2; }

  .sidebar-card { background: #FDFBF7; border: 1px solid #EDE8DF; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .sidebar-card h3 { font-family: 'Georgia', serif; font-size: 1.05rem; font-weight: 400; color: #1A1208; margin-bottom: 0.75rem; }
  .sidebar-card address { font-style: normal; font-size: 0.875rem; color: #4A3A2A; line-height: 1.8; margin-bottom: 1rem; }
  .sidebar-card address a { color: #7A5A1A; text-decoration: none; font-weight: 600; }
  .sidebar-card address a:hover { text-decoration: underline; }
  .sidebar-card p { font-size: 0.875rem; color: #4A3A2A; line-height: 1.7; margin-bottom: 0.5rem; }
  .map-wrapper { border-radius: 6px; overflow: hidden; margin-top: 0.75rem; }
  .area-list { padding-left: 1.1rem; margin: 0.5rem 0 0; }
  .area-list li { font-size: 0.875rem; color: #4A3A2A; line-height: 1.9; }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 1.75rem; }
  }
</style>