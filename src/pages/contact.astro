<style>
  :global(body.page-contact-dark) {
    background-color: #1a1a1a;
    color: rgba(255, 255, 255, 0.92);
  }

  .page-main {
    max-width: 100%;
    padding: 0;
    margin: 0;
    --contact-gold: #d4a853;
    --contact-gold-soft: #c4a386;
    --contact-panel: #222224;
    --contact-panel-border: rgba(255, 255, 255, 0.1);
    --contact-body: rgba(255, 255, 255, 0.9);
    --contact-muted: rgba(232, 226, 217, 0.72);
  }

  /* H.lawfirmontario-style hero (家庭法-华人律师): layered photo + brand scrim + gradient */
  .hf-hero {
    --hf-brand-primary: #3a4148;
    --hf-brand-accent: #b8956a;
    --hf-brand-accent-dark: #a78458;
    position: relative;
    overflow: hidden;
    padding: clamp(5rem, 12vw, 7rem) 1.5rem;
    text-align: center;
    color: #fff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.35);
  }

  .hf-hero__layers {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hf-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hf-hero__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hf-hero__overlay--brand {
    background: rgba(58, 65, 72, 0.85);
  }

  .hf-hero__overlay--gradient {
    background: linear-gradient(to top, rgba(58, 65, 72, 0.4), transparent, transparent);
  }

  .hf-hero__inner {
    position: relative;
    z-index: 10;
    max-width: 56rem;
    margin: 0 auto;
    padding-left: max(0px, env(safe-area-inset-left));
    padding-right: max(0px, env(safe-area-inset-right));
  }

  .hf-hero__badge-row {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .hf-hero__badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--hf-brand-accent);
    background: rgba(184, 149, 106, 0.15);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: 9999px;
    border: 1px solid rgba(184, 149, 106, 0.3);
  }

  .hf-hero__title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: #fff;
  }

  .hf-hero__accent {
    color: var(--hf-brand-accent);
  }

  .hf-hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 auto 1.5rem;
    max-width: 42rem;
    line-height: 1.5;
  }

  .hf-hero__lead {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.625;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 auto 2.5rem;
    max-width: 48rem;
  }

  .hf-hero__accent-inline {
    color: var(--hf-brand-accent);
    font-weight: 600;
  }

  .hf-hero__cta-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
    align-items: stretch;
  }

  .hf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.25;
    border-radius: 0.375rem;
    text-decoration: none;
    border: 2px solid transparent;
    cursor: pointer;
    box-sizing: border-box;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    font-family: inherit;
    width: 100%;
  }

  .hf-btn--primary {
    background: var(--hf-brand-accent);
    color: #fff !important;
    border-color: var(--hf-brand-accent);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.25);
  }

