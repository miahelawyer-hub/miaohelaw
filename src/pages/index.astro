	.hero::before{
		content:"";
		position:absolute;
		inset:0;
		background:
			/* soft paper fiber direction */
			repeating-linear-gradient(
				135deg,
				rgba(44,24,16,0.018) 0px,
				rgba(44,24,16,0.018) 1px,
				rgba(44,24,16,0) 1px,
				rgba(44,24,16,0) 12px
			),
			/* secondary, even subtler fiber */
			repeating-linear-gradient(
				35deg,
				rgba(44,24,16,0.012) 0px,
				rgba(44,24,16,0.012) 1px,
				rgba(44,24,16,0) 1px,
				rgba(44,24,16,0) 18px
			),
			/* gentle speckle via tiny radial dots */
			radial-gradient(circle at 20% 30%, rgba(44,24,16,0.022) 0 0.8px, rgba(44,24,16,0) 1.2px),
			radial-gradient(circle at 70% 60%, rgba(44,24,16,0.018) 0 0.7px, rgba(44,24,16,0) 1.15px),
			radial-gradient(circle at 40% 80%, rgba(44,24,16,0.016) 0 0.75px, rgba(44,24,16,0) 1.1px),
			linear-gradient(0deg, rgba(255,255,255,0.16), rgba(255,255,255,0.16));
		background-size:
			auto,
			auto,
			220px 220px,
			260px 260px,
			240px 240px,
			auto;
		opacity: 0.28;
		mix-blend-mode: multiply;
		pointer-events:none;
	}
	.hero::after{
		content:"";
		position:absolute;
		inset:-35% -25% auto auto;
		width:640px;
		height:640px;
		background: radial-gradient(circle at 35% 35%, rgba(212,168,83,0.22), rgba(212,168,83,0) 62%);
		transform: rotate(18deg);
		pointer-events:none;
	}
