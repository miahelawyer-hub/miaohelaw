	/* Subtle, premium-tinted backgrounds per category */
	.area-family { --accent: #7A5A1A; --card-bg: linear-gradient(180deg, #FFFFFF 0%, #FFFBF3 100%); }
	.area-re { --accent: #185FA5; --card-bg: linear-gradient(180deg, #FFFFFF 0%, #F2F7FF 100%); }
