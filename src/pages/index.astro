.hero-fee { margin-top: 0.5rem; font-size: 0.85rem; color: #185FA5; font-weight: 600; letter-spacing: 0.03em; background: #EEF4FF; display: inline-block; padding: 0.4rem 1rem; border-radius: 20px; border: 1px solid #C5D8F5; }
