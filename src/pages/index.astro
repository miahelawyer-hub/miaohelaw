	.stats{
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		position: relative;
		background:
			linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.02) 18%, rgba(0,0,0,0.0) 55%),
			radial-gradient(900px 120px at 35% 0%, rgba(250,199,117,0.22), rgba(250,199,117,0) 62%),
			linear-gradient(180deg, #312A1E 0%, #241D14 50%, #1D170F 100%);
		border-top: 1px solid rgba(255,255,255,0.10);
		border-bottom: 1px solid rgba(0,0,0,0.55);
		box-shadow:
			0 18px 40px rgba(0,0,0,0.22),
			inset 0 1px 0 rgba(255,255,255,0.10),
			inset 0 -10px 18px rgba(0,0,0,0.35);
		overflow: hidden;
	}
	.stats::before{
		content:"";
		position:absolute;
		inset:0;
		background:
			repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0 1px, rgba(255,255,255,0) 1px 14px),
			repeating-linear-gradient(0deg, rgba(0,0,0,0.06) 0 1px, rgba(0,0,0,0) 1px 10px);
		opacity: 0.20;
		pointer-events:none;
		mix-blend-mode: overlay;
	}
	.stats::after{
		content:"";
		position:absolute;
		left:0; right:0; top:0;
		height: 2px;
		background: linear-gradient(90deg, rgba(250,199,117,0), rgba(250,199,117,0.55), rgba(250,199,117,0));
		opacity: 0.65;
		pointer-events:none;
	}

	.stat-item{
		position: relative;
		padding: 2rem 1rem;
		text-align: center;
		border-right: 1px solid rgba(255,255,255,0.07);
		box-shadow: inset -1px 0 0 rgba(0,0,0,0.35);
	}
	.stat-item::before{
		content:"";
		position:absolute;
		inset:0;
		background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0));
		opacity: 0.6;
		pointer-events:none;
	}
	.stat-item:last-child { border-right: none; }
	.stat-empty { border-right: none; }
	.stat-number{
		font-family: ui-sans-serif, system-ui, -apple-system, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
		font-size: 2.25rem;
		font-weight: 600;
		color: #FAC775;
		margin-bottom: 0.4rem;
		letter-spacing: 0.01em;
		font-variant-numeric: tabular-nums lining-nums;
		text-shadow:
			0 1px 0 rgba(0,0,0,0.55),
			0 10px 22px rgba(0,0,0,0.35);
	}
	.stat-label{
		font-size: 0.75rem;
		color: rgba(230,206,160,0.72);
		line-height: 1.4;
		letter-spacing: 0.06em;
		/* keep uppercase styling for EN pages; zh stays normal */
		text-transform: none;
	}

	.areas { padding: 4.25rem 2rem; max-width: 960px; margin: 0 auto; }
	.areas h2 { font-family: 'Georgia', serif; font-size: 1.75rem; font-weight: 400; color: #1A1208; margin-bottom: 0.65rem; }
	.areas-sub { color: #6B5A3A; font-size: 0.95rem; line-height: 1.75; margin-bottom: 2rem; max-width: 70ch; }

	.areas-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

	.area-card {
		--accent: #7A5A1A;
