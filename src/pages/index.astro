---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { videoItems, type VideoItem } from '../data/videos';
import { isBlogPostRoutable } from '../lib/blogPublished';

const posts = (await getCollection('blog'))
	.filter(isBlogPostRoutable)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
function formatBlogDate(date: Date) {
	return new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

/** 首页「法律视频」三张卡片，链到本站 /videos/{slug}/ */
const homepageVideoSlugs = [
	'ontario-divorce-procedures-negotiation',
	'ontario-divorce-litigation-uncooperative-spouse',
	'divorce-financial-disclosure-preparation-ontario',
] as const;

const homepageVideos: VideoItem[] = homepageVideoSlugs
	.map((slug) => videoItems.find((v) => v.slug === slug))
	.filter((v): v is VideoItem => v != null);
