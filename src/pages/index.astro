		max-width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		padding: 4.5rem max(1.5rem, calc(50vw - 490px)) 4.75rem;
		box-sizing: border-box;
		background: var(--areas-bg);
	}
