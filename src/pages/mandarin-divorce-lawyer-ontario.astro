    .container { max-width: 900px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .section-title { color: var(--text-heading); font-size: 1.25rem; margin: 0 0 1.25rem; padding-bottom: 0.4rem; border-bottom: 2px solid #D4A853; }
    .faq-item { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 0.75rem; }
    .faq-item h3 { color: var(--text-heading); font-size: 0.95rem; margin: 0 0 0.5rem; }
    .faq-item p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0; }
    .service-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 2.5rem; }
    .service-item { background: white; border: 1px solid #e8e0d5; border-radius: 8px; padding: 0.85rem 1rem; font-size: 0.88rem; color: #4A2C1A; display: flex; align-items: center; gap: 0.5rem; }
