---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VideoCard from '../../components/VideoCard.astro';
import { videoItems, getTopicGroupsBySlug, VIDEOS_PREVIEW_PER_TOPIC } from '../../data/videos';
import { SITE_URL } from '../../consts';

const topicGroups = getTopicGroupsBySlug();
const totalVideos = videoItems.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: '法律视频 | 何淼律师',
  description: `何淼律师${totalVideos}条家庭法实用视频，涵盖婚房、分居、抚养费与离婚、婚姻协议等话题。`,
  url: `${SITE_URL}/videos/`,
  publisher: {
    '@id': `${SITE_URL}/#person`,
  },
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="法律视频 | 何淼律师 多伦多华人家庭法"
    description={`何淼律师${totalVideos}条家庭法实用视频，涵盖婚房、分居、抚养费与离婚、婚姻协议等话题。普通话讲解，通俗易懂。`}
  />
  <meta name="keywords" content="安省家庭法视频,多伦多离婚律师视频,华人家庭法普通话,婚房分居抚养费离婚视频,财产分割讲解,何淼律师视频" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json">{`{
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"首页","item":"${SITE_URL}/"},
      {"@type":"ListItem","position":2,"name":"法律视频","item":"${SITE_URL}/videos/"}
    ]
  }`}</script>
</head>
<body>
  <Header />
  <main class="video-listing-root" id="video-listing-root">
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">首页</a> › 法律视频</div>
        <h1>法律视频</h1>
        <p class="hero-sub">何淼律师以普通话讲解安省家庭法实务，通俗易懂 · 共 {totalVideos} 条视频</p>
      </div>
    </section>

    <section class="videos-section">
      <div class="container">
        <div
          class="video-search"
          role="search"
          aria-label="法律视频搜索"
          data-search-json="/video-search.json"
          data-list-home="/videos/"
        >
          <label class="sr-only" for="video-search-input">搜索视频</label>
          <input
            id="video-search-input"
            class="video-search-input"
            type="search"
            placeholder="搜索关键词（例如：婚房、抚养费、分居、Common Law、家暴）"
            autocomplete="off"
          />
          <button class="video-search-clear" id="video-search-clear" type="button" aria-label="清空搜索">清空</button>
        </div>
        <p class="video-search-meta" id="video-search-meta" aria-live="polite"></p>
        <div class="video-search-results" id="video-search-results" hidden></div>

        <div class="video-listing-topics">
          {topicGroups.map(({ topic, topicSlug, videos }) => (
            <div class="topic-group">
              <h2 class="topic-heading">{topic}</h2>
              <div class="video-grid">
                {videos.slice(0, VIDEOS_PREVIEW_PER_TOPIC).map((v) => (
                  <VideoCard video={v} />
                ))}
              </div>
              <a class="topic-learn-more" href={`/videos/topic/${topicSlug}/`}>
                Learn more →
              </a>
            </div>
          ))}
        </div>

        <div class="contact-card">
          <div class="contact-info">
            <h2>有具体问题想咨询？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script src="/js/video-listing.js" defer></script>
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: var(--bg);
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  .page-hero {
    background: linear-gradient(135deg, #2c1810 0%, #4a3222 60%, #6b4a2a 100%);
    color: #fff;
    padding: 3.5rem 0 2.8rem;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .breadcrumb { font-size: 0.82rem; opacity: 0.7; margin-bottom: 0.9rem; }
  .breadcrumb a { color: #fff; }
  .page-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .hero-sub { font-size: 0.95rem; opacity: 0.82; }

  .videos-section { padding: 3rem 0 4rem; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .video-search {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin: 0 0 1.25rem;
    padding: 0.85rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(237, 232, 223, 0.95);
    box-shadow: 0 1px 0 rgba(44, 24, 16, 0.02);
  }
  .video-search-input {
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(212, 168, 83, 0.28);
    background: #fff;
    color: var(--text-heading);
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    font-size: 1rem;
    line-height: 1.2;
    outline: none;
    font-family: inherit;
  }
  .video-search-input:focus {
    border-color: rgba(212, 168, 83, 0.6);
    box-shadow: 0 0 0 4px rgba(212, 168, 83, 0.18);
  }
  .video-search-clear {
    flex: none;
    background: transparent;
    border: 1px solid rgba(44, 24, 16, 0.22);
    color: #4a2c1a;
    border-radius: 12px;
    padding: 0.7rem 0.9rem;
    font-size: 0.92rem;
    cursor: pointer;
    white-space: nowrap;
    font-family: inherit;
  }
  .video-search-clear:hover {
    border-color: rgba(212, 168, 83, 0.6);
    background: rgba(212, 168, 83, 0.08);
  }
  .video-search-meta {
    margin: -0.35rem 0 1.25rem;
    color: rgba(44, 24, 16, 0.72);
    font-size: 0.92rem;
    min-height: 1.35em;
  }
  .video-search-results { margin: 0 0 1.25rem; }
  .video-search-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.4rem;
  }
  .video-search-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(74, 58, 42, 0.08);
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(237, 232, 223, 0.95);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .video-search-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(74, 58, 42, 0.14);
    border-color: rgba(212, 168, 83, 0.35);
  }
  .video-search-card__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #222;
    overflow: hidden;
  }
  .video-search-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-search-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.28);
    opacity: 0;
    transition: opacity 0.18s;
    pointer-events: none;
  }
  .video-search-card:hover .video-search-card__play { opacity: 1; }
  .video-search-card__body {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .video-search-card__topic {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #c9a168;
  }
  .video-search-card__title {
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.5;
    color: var(--text-heading);
  }
  .video-search-empty {
    margin: 0;
    padding: 1rem 0;
    color: rgba(44, 24, 16, 0.72);
    font-size: 0.95rem;
  }
  .video-search-empty a {
    color: #6b4a2a;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .video-listing--searching .video-listing-topics { display: none !important; }

  .topic-group { margin-bottom: 3rem; }
  .topic-heading {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-heading);
    padding-bottom: 0.6rem;
    border-bottom: 2px solid #D4A853;
    margin-bottom: 1.4rem;
    display: inline-block;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.4rem;
  }

  .topic-learn-more {
    display: inline-flex;
    align-items: center;
    margin-top: 1.1rem;
    font-size: 0.92rem;
    font-weight: 700;
    color: #6b4a2a;
    text-decoration: none;
    border-bottom: 2px solid #D4A853;
    padding-bottom: 0.15rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .topic-learn-more:hover {
    color: #4a3222;
    border-color: #b8923f;
  }

  .contact-card {
    margin-top: 3rem;
    background: linear-gradient(135deg, #2c1810, #4a3222);
    border-radius: 12px;
    padding: 2rem 2.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-info h2 { font-size: 1.1rem; color: #fff; margin-bottom: 0.4rem; }
  .contact-info p { font-size: 0.88rem; color: rgba(255,255,255,0.78); }
  .contact-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn-primary {
    background: #D4A853;
    color: #2c1810;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .btn-secondary {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.5);
    color: #fff;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .video-grid { grid-template-columns: 1fr; }
    .video-search-results-grid { grid-template-columns: 1fr; }
    .contact-card { flex-direction: column; align-items: flex-start; }
    .video-search { padding: 0.65rem; gap: 0.6rem; }
    .video-search-input { padding: 0.8rem 0.85rem; }
    .video-search-clear { padding: 0.72rem 0.82rem; }
  }
</style>
