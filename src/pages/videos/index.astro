---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VideoCard from '../../components/VideoCard.astro';
import { videoItems, getVideosByTopic } from '../../data/videos';
import { SITE_URL } from '../../consts';

const byTopic = getVideosByTopic();
const totalVideos = videoItems.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: '法律视频 | 何淼律师',
  description: `何淼律师${totalVideos}条家庭法实用视频，涵盖婚房、分居、抚养费与离婚、婚姻协议等话题。`,
  url: `${SITE_URL}/videos/`,
  publisher: {
    '@type': 'Person',
    name: '何淼 Miao (Mia) He',
    url: SITE_URL,
  },
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title="法律视频 | 何淼律师 多伦多华人家庭法"
    description={`何淼律师${totalVideos}条家庭法实用视频，涵盖婚房、分居、抚养费与离婚、婚姻协议等话题。普通话讲解，通俗易懂。`}
  />
  <meta name="keywords" content="安省家庭法视频,多伦多离婚律师视频,华人家庭法普通话,婚房分居抚养费离婚视频,财产分割讲解,何淼律师视频" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json">{`{
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"首页","item":"${SITE_URL}/"},
      {"@type":"ListItem","position":2,"name":"法律视频","item":"${SITE_URL}/videos/"}
    ]
  }`}</script>
</head>
<body>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb"><a href="/">首页</a> › 法律视频</div>
        <h1>法律视频</h1>
        <p class="hero-sub">何淼律师以普通话讲解安省家庭法实务，通俗易懂 · 共 {totalVideos} 条视频</p>
      </div>
    </section>

    <section class="videos-section">
      <div class="container">
        {Array.from(byTopic.entries()).map(([topic, videos]) => (
          <div class="topic-group">
            <h2 class="topic-heading">{topic}</h2>
            <div class="video-grid">
              {videos.map(v => <VideoCard video={v} />)}
            </div>
          </div>
        ))}

        <div class="contact-card">
          <div class="contact-info">
            <h2>有具体问题想咨询？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: var(--bg);
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  .page-hero {
    background: linear-gradient(135deg, #2c1810 0%, #4a3222 60%, #6b4a2a 100%);
    color: #fff;
    padding: 3.5rem 0 2.8rem;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .breadcrumb { font-size: 0.82rem; opacity: 0.7; margin-bottom: 0.9rem; }
  .breadcrumb a { color: #fff; }
  .page-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .hero-sub { font-size: 0.95rem; opacity: 0.82; }

  .videos-section { padding: 3rem 0 4rem; }

  .topic-group { margin-bottom: 3rem; }
  .topic-heading {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-heading);
    padding-bottom: 0.6rem;
    border-bottom: 2px solid #D4A853;
    margin-bottom: 1.4rem;
    display: inline-block;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.4rem;
  }

  .contact-card {
    margin-top: 3rem;
    background: linear-gradient(135deg, #2c1810, #4a3222);
    border-radius: 12px;
    padding: 2rem 2.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-info h2 { font-size: 1.1rem; color: #fff; margin-bottom: 0.4rem; }
  .contact-info p { font-size: 0.88rem; color: rgba(255,255,255,0.78); }
  .contact-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn-primary {
    background: #D4A853;
    color: #2c1810;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .btn-secondary {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.5);
    color: #fff;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .video-grid { grid-template-columns: 1fr; }
    .contact-card { flex-direction: column; align-items: flex-start; }
  }
</style>
