---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import VideoCard from '../../../components/VideoCard.astro';
import { videoItems } from '../../../data/videos';
import { SITE_URL } from '../../../consts';

export function getStaticPaths() {
  const slugs = [...new Set(videoItems.map((v) => v.topicSlug))];
  return slugs.map((topicSlug) => ({
    params: { topicSlug },
    props: {
      videos: videoItems.filter((v) => v.topicSlug === topicSlug),
    },
  }));
}

const { videos } = Astro.props;
const topic = videos[0]?.topic ?? '法律视频';
const topicSlug = Astro.params.topicSlug!;
const pageUrl = `${SITE_URL}/videos/topic/${topicSlug}/`;
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead
    title={`${topic} | 法律视频 | 何淼律师`}
    description={`何淼律师「${topic}」相关视频共 ${videos.length} 条，普通话讲解安省家庭法实务。`}
  />
  <meta name="keywords" content={`${topic},安省家庭法视频,多伦多离婚律师视频,何淼律师`} />
  <script type="application/ld+json">{`{
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"首页","item":"${SITE_URL}/"},
      {"@type":"ListItem","position":2,"name":"法律视频","item":"${SITE_URL}/videos/"},
      {"@type":"ListItem","position":3,"name":${JSON.stringify(topic)},"item":"${pageUrl}"}
    ]
  }`}</script>
</head>
<body>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">首页</a> › <a href="/videos/">法律视频</a> › {topic}
        </div>
        <h1>{topic}</h1>
        <p class="hero-sub">共 {videos.length} 条视频 · <a class="hero-back" href="/videos/">← 返回全部话题</a></p>
      </div>
    </section>

    <section class="videos-section">
      <div class="container">
        <div class="video-grid">
          {videos.map((v) => <VideoCard video={v} />)}
        </div>

        <div class="contact-card">
          <div class="contact-info">
            <h2>有具体问题想咨询？</h2>
            <p>何淼律师提供普通话全程服务，初次咨询30分钟 · $220+HST</p>
          </div>
          <div class="contact-actions">
            <a href="tel:6479306688" class="btn-primary">📞 647-930-6688</a>
            <a href="/contact" class="btn-secondary">预约咨询</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: var(--bg);
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  .page-hero {
    background: linear-gradient(135deg, #2c1810 0%, #4a3222 60%, #6b4a2a 100%);
    color: #fff;
    padding: 3.5rem 0 2.8rem;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .breadcrumb { font-size: 0.82rem; opacity: 0.7; margin-bottom: 0.9rem; }
  .breadcrumb a { color: #fff; }
  .page-hero h1 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 0.6rem;
    line-height: 1.25;
  }
  .hero-sub { font-size: 0.95rem; opacity: 0.82; }
  .hero-back {
    color: #D4A853;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .hero-back:hover { opacity: 0.92; }

  .videos-section { padding: 3rem 0 4rem; }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.4rem;
  }

  .contact-card {
    margin-top: 3rem;
    background: linear-gradient(135deg, #2c1810, #4a3222);
    border-radius: 12px;
    padding: 2rem 2.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-info h2 { font-size: 1.1rem; color: #fff; margin-bottom: 0.4rem; }
  .contact-info p { font-size: 0.88rem; color: rgba(255,255,255,0.78); }
  .contact-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn-primary {
    background: #D4A853;
    color: #2c1810;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .btn-secondary {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.5);
    color: #fff;
    padding: 0.65rem 1.3rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .video-grid { grid-template-columns: 1fr; }
    .contact-card { flex-direction: column; align-items: flex-start; }
  }
</style>
