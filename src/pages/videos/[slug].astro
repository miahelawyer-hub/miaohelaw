---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { videoItems } from '../../data/videos';
import { SITE_URL } from '../../consts';

export function getStaticPaths() {
  return videoItems.map((v) => ({
    params: { slug: v.slug },
    props: { video: v },
  }));
}

const { video } = Astro.props;
const thumbUrl = `https://img.youtube.com/vi/${video.youtubeId}/maxresdefault.jpg`;
const embedUrl = `https://www.youtube.com/embed/${video.youtubeId}`;
const watchUrl = `https://www.youtube.com/watch?v=${video.youtubeId}`;
const pageUrl  = `${SITE_URL}/videos/${video.slug}/`;

const metaTitle = video.metaTitle ?? `${video.title} | 何淼律师`;
const metaDesc  = video.metaDescription ?? video.summary;

const videoObjectSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: video.title,
  description: video.description,
  thumbnailUrl: thumbUrl,
  uploadDate: video.uploadDate,
  embedUrl,
  contentUrl: watchUrl,
  publisher: {
    '@type': 'Person',
    name: '何淼 Miao (Mia) He',
    url: SITE_URL,
  },
};
---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead title={metaTitle} description={metaDesc} />
  <meta name="keywords" content={video.keywords} />
  <script type="application/ld+json" set:html={JSON.stringify(videoObjectSchema)} />
  <script type="application/ld+json">{`{
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"首页","item":"${SITE_URL}/"},
      {"@type":"ListItem","position":2,"name":"法律视频","item":"${SITE_URL}/videos/"},
      {"@type":"ListItem","position":3,"name":"${video.title}","item":"${pageUrl}"}
    ]
  }`}</script>
</head>
<body>
  <Header />
  <main>
    <section class="video-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">首页</a> › <a href="/videos/">法律视频</a> › <span>{video.topic}</span>
        </div>
        <h1>{video.title}</h1>
      </div>
    </section>

    <section class="video-body">
      <div class="container">
        <div class="video-embed-wrap">
          <div class="video-embed">
            <iframe
              src={embedUrl}
              title={video.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <div class="video-content">
          <div class="video-summary">
            <h2>视频简介</h2>
            <p set:html={video.description} />
          </div>

          <div class="video-keypoints">
            <h2>核心观点</h2>
            <ul>
              {video.keyPoints.map(pt => <li set:html={pt} />)}
            </ul>
            <p class="disclaimer">本视频内容仅供参考，不构成针对您个人案件的法律意见。如有具体问题，欢迎预约一对一咨询。</p>
          </div>

          <div class="video-cta">
            <h3 class="cta-heading">咨询何淼律师</h3>
            <p class="cta-intro">普通话与英文 · 万锦事务所 · 服务 GTA 及安大略省</p>
            <div class="cta-fee">初次咨询 30 分钟 · $220 + HST · 按每 6 分钟计费</div>
            <div class="cta-buttons">
              <a href="tel:6479306688" class="btn-cta-phone">📞 647-930-6688</a>
              <a href="mailto:miao@miaohelaw.ca" class="btn-cta-email">✉️ miao@miaohelaw.ca</a>
            </div>
          </div>

          <div class="back-link">
            <a href="/videos/">← 返回法律视频列表</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: ui-serif, "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    background: var(--bg);
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  .video-hero {
    background: linear-gradient(135deg, #2c1810 0%, #4a3222 60%, #6b4a2a 100%);
    color: #fff;
    padding: 3rem 0 2.4rem;
  }
  .container { max-width: 860px; margin: 0 auto; padding: 0 1.5rem; }
  .breadcrumb {
    font-size: 0.82rem;
    opacity: 0.72;
    margin-bottom: 0.9rem;
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: #fff; }
  .breadcrumb span { color: rgba(255,255,255,0.7); }
  .video-hero h1 {
    font-size: clamp(1.35rem, 3.5vw, 1.9rem);
    font-weight: 800;
    line-height: 1.45;
    color: #fff;
  }

  .video-body { padding: 2.5rem 0 4rem; }

  /* 16:9 responsive embed */
  .video-embed-wrap { margin-bottom: 2.2rem; }
  .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-content { display: flex; flex-direction: column; gap: 2rem; }

  .video-summary h2,
  .video-keypoints h2 {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid #D4A853;
    display: inline-block;
  }
  .video-summary p {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--text-primary);
  }
  .video-keypoints ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .video-keypoints li {
    font-size: 0.93rem;
    line-height: 1.7;
    padding-left: 1.2rem;
    position: relative;
    color: var(--text-primary);
  }
  .video-keypoints li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: #D4A853;
    font-size: 0.8rem;
    top: 0.18em;
  }
  .video-keypoints li a,
  .video-summary p a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .video-keypoints li a:hover,
  .video-summary p a:hover {
    color: var(--accent-dark);
  }

  .video-cta {
    padding: 2rem 1.5rem;
    text-align: center;
    border-radius: 12px;
    background: #1c2b3f;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 14px 32px rgba(12,22,38,0.35);
  }
  .cta-heading {
    font-family: "Noto Serif SC", "Songti SC", Georgia, serif;
    font-size: clamp(1.28rem, 2.8vw, 1.6rem);
    font-weight: 700;
    color: #fac775;
    margin: 0 0 0.55rem;
    line-height: 1.35;
    text-shadow: 0 1px 2px rgba(0,0,0,0.35);
  }
  .cta-intro {
    color: #d4cfc3;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.65;
    margin: 0 auto 0.9rem;
  }
  .cta-fee {
    display: inline-block;
    background: #263649;
    color: rgba(248,250,252,0.92);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.45rem 1rem;
    border-radius: 20px;
    margin-bottom: 0.9rem;
    border: 1px solid rgba(255,255,255,0.14);
  }
  .disclaimer {
    font-size: 0.78rem;
    font-style: italic;
    color: var(--text-primary);
    opacity: 0.55;
    line-height: 1.7;
    margin-top: 1rem;
  }
  .cta-buttons { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn-cta-phone {
    display: inline-block;
    background: #c9a168;
    color: #1c2b3f;
    padding: 0.72rem 1.35rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 14px 32px rgba(0,0,0,0.38);
    transition: filter 0.15s ease;
  }
  .btn-cta-phone:hover { filter: brightness(1.04); }
  .btn-cta-email {
    display: inline-block;
    background: transparent;
    color: rgba(248,250,252,0.95);
    border: 1px solid #c9a168;
    padding: 0.72rem 1.35rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    transition: background 0.15s ease;
  }
  .btn-cta-email:hover { background: rgba(201,161,104,0.14); }

  .back-link { font-size: 0.88rem; }
  .back-link a { color: var(--accent); font-weight: 600; }
  .back-link a:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .cta-buttons { flex-direction: column; }
  }
</style>
