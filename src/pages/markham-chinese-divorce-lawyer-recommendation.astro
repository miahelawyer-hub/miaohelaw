    .prose strong { color: var(--text-heading); }
    .insight-box { background: #FDF6EC; border-left: 4px solid #D4A853; border-radius: 0 8px 8px 0; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
    .insight-box p { color: #4A2C1A; font-size: 0.92rem; line-height: 1.75; margin: 0; }
    .check-list { list-style: none; padding: 0; margin: 1rem 0 1.5rem; }
    .check-list li { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.5rem 0; font-size: 0.92rem; color: #4A2C1A; line-height: 1.6; border-bottom: 1px solid #f0ebe3; }
    .check-list li:last-child { border-bottom: none; }
    .check-list .icon { color: #D4A853; font-weight: 700; flex-shrink: 0; }
    .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e8e0d5; border: 1px solid #e8e0d5; border-radius: 10px; overflow: hidden; margin: 1.5rem 0 2.5rem; }
    .stat { background: white; padding: 1.1rem 1rem; text-align: center; }
