    .final-cta p { color: rgba(255,255,255,0.88); margin: 0 0 1.25rem; font-size: 0.92rem; line-height: 1.7; }
    .lawyer-card { background: white; border: 1px solid #e8e0d5; border-radius: 10px; padding: 1.5rem; margin-bottom: 2.5rem; border-left: 4px solid #D4A853; }
    .lawyer-card h3 { color: var(--text-heading); margin: 0 0 0.5rem; font-size: 1rem; }
    .lawyer-card p { color: #5a3e2b; font-size: 0.88rem; line-height: 1.65; margin: 0 0 0.5rem; }
