  .key-point{background:#fff8ee;border:1.5px solid #D4A853;border-radius:10px;padding:1.25rem 1.5rem;margin:1.75rem 0;position:relative}
  .key-point::before{content:"💡";position:absolute;top:-0.75rem;left:1rem;background:#fff8ee;padding:0 0.3rem;font-size:1rem}
